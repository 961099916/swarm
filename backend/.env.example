# File: backend/.env.example
# 慢任务智能编排系统环境变量配置文件示例

# 内部通信密钥，用于网关向 Admin Worker 发起 Service Binding 请求时进行身份验证，防止绕过网关直接调用
INTERNAL_SECRET="REPLACE_WITH_YOUR_INTERNAL_SECRET"

# JWT 签名密钥
JWT_SECRET="REPLACE_WITH_YOUR_JWT_SECRET"

# 微信小程序 AppID 和 AppSecret
WX_APP_ID="REPLACE_WITH_YOUR_WX_APP_ID"
WX_APP_SECRET="REPLACE_WITH_YOUR_WX_APP_SECRET"

# 邮件发送服务配置（如 Resend API Key，用于 Workflow 步骤中发送邮件）
EMAIL_API_KEY="REPLACE_WITH_YOUR_EMAIL_API_KEY"
EMAIL_FROM="noreply@yourdomain.com"

# 和风天气 API Key（用于天气查询工具）
WEATHER_API_KEY="REPLACE_WITH_YOUR_WEATHER_API_KEY"

# 搜索服务 API Key（留空则自动降级为 DuckDuckGo 免费搜索）
SEARCH_API_KEY=""
