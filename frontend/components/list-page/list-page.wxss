/* list-page 组件样式 — 依赖 app.wxss 中的全局设计 Token */

.lp-root {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: var(--bg-root);
  box-sizing: border-box;
}

/* ── 筛选栏 ── */
.lp-filter-bar {
  width: 100%;
  white-space: nowrap;
  padding: 24rpx 24rpx 0;
  box-sizing: border-box;
  flex-shrink: 0;
}
.lp-filter-items {
  display: inline-flex;
  gap: 12rpx;
}

/* ── 搜索框 ── */
.lp-search-wrap {
  padding: 16rpx 24rpx 0;
  flex-shrink: 0;
}
.lp-search-inner {
  display: flex;
  align-items: center;
  height: 72rpx;
  background: var(--glass-bg);
  backdrop-filter: var(--glass-blur);
  -webkit-backdrop-filter: var(--glass-blur);
  border: 1rpx solid var(--glass-border);
  border-radius: var(--radius-full);
  padding: 0 24rpx;
  box-sizing: border-box;
}
.lp-search-input {
  flex: 1;
  height: 100%;
  font-size: 24rpx;
  color: var(--text-primary);
  background: transparent;
  border: none;
  outline: none;
}
.lp-search-placeholder {
  color: var(--text-placeholder);
  font-size: 24rpx;
}
.lp-search-clear {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

/* ── 滚动列表（flex:1 撑满剩余空间） ── */
.lp-scroll {
  flex: 1;
  height: 0;
  padding: 0 24rpx;
  box-sizing: border-box;
}

/* ── 骨架屏外层 ── */
.lp-skeleton-wrap {
  padding-top: 16rpx;
}

/* ── 加载更多 ── */
.lp-load-more {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 32rpx 0;
}
.lp-load-more-text {
  font-size: 22rpx;
  color: var(--text-muted);
}
.lp-load-more-end {
  font-size: 22rpx;
  color: var(--text-placeholder);
  letter-spacing: 2rpx;
}
