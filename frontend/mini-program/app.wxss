@import "./static/styles/icon.wxss";
@import "./static/styles/tailwind.wxss";
@import "./miniprogram_npm/tdesign-miniprogram/icon/icon.wxss";

/* ══════════════════════════════════════════════════════
   Swarm 暖绒奶油设计体系 v3 — Warm Cream UI
   定位：小红书暖白奶油风格 · 适合中国年轻人的视觉语言
   原则：暖色基底、珊瑚橙渐变、大圆角毛玻璃、柔和阴影、微动效
   ══════════════════════════════════════════════════════ */

/* ── 1. 设计 Token（暗色默认）── */
page {
  /* 硬编码回退色：防止页面跳转时底部白闪 */
  background: #2D2A24;
  
  /* ── 背景色阶（暖暗色系）── */
  --bg-root: #2D2A24;
  --bg-surface: rgba(255, 248, 240, 0.08);
  --bg-surface-solid: #3D3832;
  --bg-surface-hover: rgba(255, 248, 240, 0.12);
  --bg-surface-active: rgba(255, 248, 240, 0.16);
  --bg-mask: rgba(0, 0, 0, 0.65);

  /* ── 毛玻璃体系 ── */
  --glass-bg: rgba(255, 248, 240, 0.07);
  --glass-border: rgba(255, 248, 240, 0.12);
  --glass-blur: blur(24rpx);
  --glass-saturate: saturate(1.4);

  /* ── 品牌色（珊瑚橙渐变）── */
  --brand: #FF6B6B;
  --brand-gradient: linear-gradient(135deg, #FF6B6B, #FFA07A);
  --brand-light: #FF8E8E;
  --brand-subtle: rgba(255, 107, 107, 0.13);
  --brand-border: rgba(255, 107, 107, 0.30);

  /* ── 辅助色 ── */
  --accent-coral: #FF6B6B;
  --accent-peach: #FFA07A;
  --accent-warm: #FDB99B;
  --accent-lavender: #B8A9D4;

  /* ── 功能色 ── */
  --success: #2ECC71;
  --success-subtle: rgba(46, 204, 113, 0.13);
  --success-border: rgba(46, 204, 113, 0.30);
  --warning: #F39C12;
  --warning-subtle: rgba(243, 156, 18, 0.13);
  --warning-border: rgba(243, 156, 18, 0.30);
  --danger: #E74C3C;
  --danger-subtle: rgba(231, 76, 60, 0.13);
  --danger-border: rgba(231, 76, 60, 0.30);

  /* ── 文字色阶（暖调白）── */
  --text-primary: #FFF8F0;
  --text-secondary: #E8E0D8;
  --text-muted: #A09890;
  --text-placeholder: #7A726A;

  /* ── 边框色阶（暖灰）── */
  --border-subtle: rgba(255, 248, 240, 0.08);
  --border-default: rgba(255, 248, 240, 0.15);
  --border-strong: rgba(255, 248, 240, 0.25);

  /* ── 圆角体系（更大更圆润）── */
  --radius-sm: 12rpx;
  --radius-md: 20rpx;
  --radius-lg: 32rpx;
  --radius-xl: 40rpx;
  --radius-full: 999rpx;

  /* ── 阴影体系（暖棕阴影）── */
  --shadow-sm: 0 2rpx 12rpx rgba(120, 80, 50, 0.10);
  --shadow-md: 0 4rpx 24rpx rgba(120, 80, 50, 0.14);
  --shadow-lg: 0 8rpx 40rpx rgba(120, 80, 50, 0.18);
  --shadow-glow: 0 0 24rpx rgba(255, 107, 107, 0.25);

  /* ── 字号梯级（企业级语义化）── */
  --font-caption: 20rpx;
  --font-body: 24rpx;
  --font-body-lg: 26rpx;
  --font-h5: 28rpx;
  --font-h4: 30rpx;
  --font-h3: 32rpx;
  --font-h2: 36rpx;
  --font-h1: 44rpx;
  --font-display: 64rpx;

  /* ── 行高比例 ── */
  --leading-tight: 1.2;
  --leading-normal: 1.5;
  --leading-relaxed: 1.8;

  /* ── 间距体系（4rpx 基准网格）── */
  --space-xxs: 4rpx;
  --space-xs: 8rpx;
  --space-sm: 12rpx;
  --space-md: 16rpx;
  --space-lg: 24rpx;
  --space-xl: 32rpx;
  --space-2xl: 48rpx;
  --space-3xl: 64rpx;
  --space-4xl: 80rpx;

  /* ── 动效时长 ── */
  --duration-instant: 0.05s;
  --duration-fast: 0.15s;
  --duration-normal: 0.25s;
  --duration-slow: 0.35s;
  --duration-slide: 0.4s;

  /* ── 缓动曲线 ── */
  --ease-spring: cubic-bezier(0.34, 1.56, 0.64, 1);
  --ease-out-expo: cubic-bezier(0.19, 1, 0.22, 1);
  --ease-in-out: cubic-bezier(0.4, 0, 0.2, 1);
  --ease-out: cubic-bezier(0, 0, 0.2, 1);
  --ease-in: cubic-bezier(0.4, 0, 1, 1);

  /* ── 字体（保留系统字族）── */
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", "Microsoft YaHei", sans-serif;
  -webkit-font-smoothing: antialiased;
  background: var(--bg-root);
  color: var(--text-primary);
  min-height: 100vh;
  box-sizing: border-box;

  /* ── 兼容旧版别名映射 ── */
  --text: var(--text-primary);
  --text-light: var(--text-primary);
  --text-dark: #3D3832;
  --neon-pink: var(--accent-coral);
  --primary-purple: var(--accent-lavender);
  --neon-cyan: #2ECC71;
}

/* ── 2. 亮色主题覆盖（暖白奶油基底）── */
.theme-light {
  --bg-root: #FFF8F0;
  --bg-surface: rgba(255, 248, 240, 0.7);
  --bg-surface-solid: #FFFFFF;
  --bg-surface-hover: rgba(0, 0, 0, 0.04);
  --bg-surface-active: rgba(0, 0, 0, 0.08);
  --bg-mask: rgba(0, 0, 0, 0.30);

  --glass-bg: rgba(255, 255, 255, 0.75);
  --glass-border: rgba(0, 0, 0, 0.06);

  --text-primary: #2D2A24;
  --text-secondary: #5A544C;
  --text-muted: #9A928A;
  --text-placeholder: #B8B0A8;

  --border-subtle: rgba(0, 0, 0, 0.06);
  --border-default: rgba(0, 0, 0, 0.10);
  --border-strong: rgba(0, 0, 0, 0.18);

  --brand-subtle: rgba(255, 107, 107, 0.08);
  --success-subtle: rgba(46, 204, 113, 0.08);
  --warning-subtle: rgba(243, 156, 18, 0.08);
  --danger-subtle: rgba(231, 76, 60, 0.08);

  --shadow-sm: 0 1rpx 6rpx rgba(120, 80, 50, 0.06);
  --shadow-md: 0 4rpx 16rpx rgba(120, 80, 50, 0.10);
  --shadow-lg: 0 8rpx 32rpx rgba(120, 80, 50, 0.12);
  --shadow-glow: 0 0 20rpx rgba(255, 107, 107, 0.15);

  --text: var(--text-primary);
}

/* ── 3. 卡片系统（毛玻璃暖色卡片）── */
.card {
  background: var(--glass-bg);
  backdrop-filter: var(--glass-blur);
  -webkit-backdrop-filter: var(--glass-blur);
  border: 1rpx solid var(--glass-border);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-sm);
  position: relative;
  overflow: hidden;
  box-sizing: border-box;
  color: var(--text-primary);
  transition: all 0.25s ease;
}

.card-premium {
  background: var(--glass-bg);
  backdrop-filter: var(--glass-blur);
  -webkit-backdrop-filter: var(--glass-blur);
  border: 2rpx solid var(--brand-border);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-md), 0 0 24rpx rgba(255, 107, 107, 0.08);
  position: relative;
  overflow: hidden;
  padding: 16rpx;
  color: var(--text-primary);
}

.card-actionable {
  cursor: pointer;
  transition: all 0.2s ease;
}
.card-actionable:active {
  background: var(--bg-surface-hover);
  border-color: var(--border-strong);
  transform: scale(0.98);
}

.card-stat {
  background: var(--glass-bg);
  backdrop-filter: var(--glass-blur);
  -webkit-backdrop-filter: var(--glass-blur);
  border: 1rpx solid var(--glass-border);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-sm);
  padding: 20rpx;
  min-height: 120rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  color: var(--text-primary);
  position: relative;
  overflow: hidden;
}

/* ── 4. 按钮系统（渐变主按钮 + 毛玻璃次按钮）── */
.btn-primary {
  background: var(--brand-gradient);
  color: #FFFFFF;
  border: none;
  border-radius: var(--radius-lg);
  height: 88rpx;
  line-height: 88rpx;
  font-size: 28rpx;
  font-weight: 600;
  text-align: center;
  transition: all 0.2s ease;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: var(--shadow-glow);
}
.btn-primary:active {
  opacity: 0.9;
  transform: scale(0.97);
  box-shadow: 0 0 12rpx rgba(255, 107, 107, 0.15);
}

.btn-secondary {
  background: var(--glass-bg);
  backdrop-filter: var(--glass-blur);
  -webkit-backdrop-filter: var(--glass-blur);
  color: var(--text-primary);
  border: 1rpx solid var(--glass-border);
  border-radius: var(--radius-lg);
  height: 88rpx;
  line-height: 86rpx;
  font-size: 28rpx;
  font-weight: 500;
  text-align: center;
  transition: all 0.2s ease;
}
.btn-secondary:active {
  background: var(--bg-surface-hover);
  transform: scale(0.98);
}

.btn-danger {
  background: var(--danger);
  color: #FFFFFF;
  border: none;
  border-radius: var(--radius-lg);
  height: 88rpx;
  line-height: 88rpx;
  font-size: 28rpx;
  font-weight: 600;
  text-align: center;
  transition: all 0.2s ease;
}
.btn-danger:active {
  opacity: 0.9;
  transform: scale(0.97);
}

/* ── 5. 标签/徽章系统（毛玻璃底 + 大圆角）── */
.tag {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  padding: 6rpx 18rpx;
  border-radius: var(--radius-full);
  font-size: 20rpx;
  font-weight: 500;
  line-height: 1.4;
  background: var(--glass-bg);
  color: var(--text-secondary);
  border: 1rpx solid var(--glass-border);
  backdrop-filter: var(--glass-blur);
  -webkit-backdrop-filter: var(--glass-blur);
}

.tag-running {
  background: var(--brand-subtle);
  color: var(--brand);
  border-color: var(--brand-border);
}
.tag-success {
  background: var(--success-subtle);
  color: var(--success);
  border-color: var(--success-border);
}
.tag-failed {
  background: var(--danger-subtle);
  color: var(--danger);
  border-color: var(--danger-border);
}
.tag-pending {
  background: var(--glass-bg);
  color: var(--text-secondary);
  border-color: var(--glass-border);
}
.tag-sleeping {
  background: var(--warning-subtle);
  color: var(--warning);
  border-color: var(--warning-border);
}
.tag-cancelled {
  background: var(--glass-bg);
  color: var(--text-muted);
  border-color: var(--border-subtle);
}

/* ── 6. 状态圆点（加发光效果）── */
.status-dot {
  display: inline-block;
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: var(--text-muted);
}
.status-dot-running {
  background: var(--brand);
  box-shadow: 0 0 10rpx rgba(255, 107, 107, 0.6);
  animation: dot-pulse 1.2s ease-in-out infinite;
}
.status-dot-success { background: var(--success); box-shadow: 0 0 8rpx rgba(46, 204, 113, 0.5); }
.status-dot-failed { background: var(--danger); box-shadow: 0 0 8rpx rgba(231, 76, 60, 0.5); }
.status-dot-pending { background: var(--text-muted); }
.status-dot-sleeping { background: var(--warning); box-shadow: 0 0 8rpx rgba(243, 156, 18, 0.5); }

@keyframes dot-pulse {
  0%, 100% { opacity: 0.5; transform: scale(0.9); }
  50% { opacity: 1; transform: scale(1.3); }
}

/* ── 7. 筛选胶囊（暖色圆润胶囊）── */
.pill-filter {
  display: inline-flex;
  align-items: center;
  padding: 12rpx 32rpx;
  border-radius: var(--radius-full);
  font-size: 24rpx;
  font-weight: 500;
  background: var(--glass-bg);
  color: var(--text-secondary);
  border: 1rpx solid var(--glass-border);
  transition: all 0.2s ease;
  white-space: nowrap;
  backdrop-filter: var(--glass-blur);
  -webkit-backdrop-filter: var(--glass-blur);
}
.pill-filter:active {
  background: var(--bg-surface-hover);
  transform: scale(0.96);
}
.pill-filter.active {
  background: var(--brand-gradient);
  color: #FFFFFF;
  border-color: transparent;
  box-shadow: var(--shadow-glow);
}

/* ── 8. 输入框（毛玻璃底 + 加粗聚焦）── */
.input-field {
  width: 100%;
  height: 88rpx;
  background: var(--glass-bg);
  backdrop-filter: var(--glass-blur);
  -webkit-backdrop-filter: var(--glass-blur);
  border: 1rpx solid var(--glass-border);
  border-radius: var(--radius-lg);
  padding: 0 28rpx;
  color: var(--text-primary);
  font-size: 28rpx;
  box-sizing: border-box;
  transition: border-color 0.2s ease;
}
.input-field:focus {
  border-color: var(--brand);
  box-shadow: 0 0 0 3rpx var(--brand-subtle);
}
.input-field::placeholder {
  color: var(--text-placeholder);
}

/* ── 9. 分割线 ── */
.separator {
  height: 0;
  border-top: 1rpx solid var(--border-subtle);
}

/* ── 10. 骨架屏（暖色渐变流光）── */
@keyframes skeleton-shimmer {
  0% { opacity: 0.3; }
  50% { opacity: 0.6; }
  100% { opacity: 0.3; }
}

.skeleton {
  background: var(--glass-bg);
  border-radius: var(--radius-sm);
  animation: skeleton-shimmer 1.5s ease-in-out infinite;
  backdrop-filter: var(--glass-blur);
  -webkit-backdrop-filter: var(--glass-blur);
}

.skeleton-line {
  height: 24rpx;
  margin-bottom: 16rpx;
}
.skeleton-line.short { width: 60%; }
.skeleton-line.medium { width: 80%; }

.skeleton-card {
  height: 200rpx;
  margin-bottom: 24rpx;
}

/* ── 11. 空状态 ── */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 48rpx;
  text-align: center;
}

.empty-state .empty-icon {
  width: 140rpx;
  height: 140rpx;
  border-radius: var(--radius-xl);
  background: var(--glass-bg);
  backdrop-filter: var(--glass-blur);
  -webkit-backdrop-filter: var(--glass-blur);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
  border: 1rpx solid var(--glass-border);
}

.empty-state .empty-label {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 12rpx;
}

.empty-state .empty-desc {
  font-size: 24rpx;
  color: var(--text-muted);
  line-height: 1.6;
  max-width: 500rpx;
}

/* ── 12. 兼容类映射 ── */
.glass-card { background: var(--glass-bg); backdrop-filter: var(--glass-blur); -webkit-backdrop-filter: var(--glass-blur); border: 1rpx solid var(--glass-border); border-radius: var(--radius-md); box-shadow: var(--shadow-sm); }
.glass-panel { background: var(--glass-bg); backdrop-filter: var(--glass-blur); -webkit-backdrop-filter: var(--glass-blur); border: 1rpx solid var(--glass-border); border-radius: var(--radius-md); box-shadow: var(--shadow-md); }
.glass-btn-primary { background: var(--brand-gradient); color: #FFFFFF; border: none; border-radius: var(--radius-lg); height: 88rpx; line-height: 88rpx; font-size: 28rpx; font-weight: 600; text-align: center; }
.glass-divider { height: 0; border-top: 1rpx solid var(--border-subtle); }
.glass-sheet { background: var(--glass-bg); backdrop-filter: var(--glass-blur); -webkit-backdrop-filter: var(--glass-blur); border-radius: var(--radius-lg) var(--radius-lg) 0 0; border-top: 1rpx solid var(--glass-border); }
.glass-input { width: 100%; height: 88rpx; background: var(--glass-bg); backdrop-filter: var(--glass-blur); -webkit-backdrop-filter: var(--glass-blur); border: 1rpx solid var(--glass-border); border-radius: var(--radius-lg); padding: 0 28rpx; color: var(--text-primary); font-size: 28rpx; box-sizing: border-box; }
.glass-textarea { width: 100%; min-height: 180rpx; background: var(--glass-bg); backdrop-filter: var(--glass-blur); -webkit-backdrop-filter: var(--glass-blur); border: 1rpx solid var(--glass-border); border-radius: var(--radius-lg); padding: 24rpx; color: var(--text-primary); font-size: 28rpx; box-sizing: border-box; }
.pill-ios { display: inline-flex; align-items: center; padding: 12rpx 32rpx; border-radius: var(--radius-full); font-size: 24rpx; font-weight: 500; background: var(--glass-bg); backdrop-filter: var(--glass-blur); -webkit-backdrop-filter: var(--glass-blur); color: var(--text-secondary); border: 1rpx solid var(--glass-border); }
.pill-ios.active { background: var(--brand-gradient); color: #FFFFFF; border-color: transparent; box-shadow: var(--shadow-glow); }
.spinner-ios { width: 28rpx; height: 28rpx; border: 3rpx solid var(--border-subtle); border-top-color: var(--brand); border-radius: 50%; animation: spin 0.8s linear infinite; }

/* ── 13. 工具类 ── */
.arrow-right-ios {
  width: 12rpx; height: 12rpx;
  border-top: 2rpx solid var(--text-muted);
  border-right: 2rpx solid var(--text-muted);
  transform: rotate(45deg);
  flex-shrink: 0;
}

.num-font {
  font-family: "SF Mono", "PingFang SC", monospace;
  font-weight: 600;
}

button::after { border: none; }
::-webkit-scrollbar { width: 0; height: 0; }

/* ── 默认头像占位 ── */
.ag-avatar:empty::after {
  content: "AI";
  font-size: 20rpx;
  font-weight: 600;
  color: var(--text-muted);
}
.ag-avatar {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 48rpx;
  height: 48rpx;
  background: var(--glass-bg);
  backdrop-filter: var(--glass-blur);
  -webkit-backdrop-filter: var(--glass-blur);
  border: 1rpx solid var(--glass-border);
  border-radius: var(--radius-sm);
  font-size: 22rpx;
  font-weight: 600;
}

/* ── 14. 通用动画 ── */
@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

/* ── 15. 暖绒微交互动画 ── */
/* 按压弹性 */
.press-scale:active {
  transform: scale(0.96);
  transition: transform 0.15s ease;
}

/* 卡片入场淡入上滑 */
@keyframes fade-up {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.fade-up {
  animation: fade-up 0.35s ease-out both;
}

.fade-up-d1 { animation-delay: 0.05s; }
.fade-up-d2 { animation-delay: 0.10s; }
.fade-up-d3 { animation-delay: 0.15s; }
.fade-up-d4 { animation-delay: 0.20s; }

/* 渐变流光 */
@keyframes gradient-shift {
  0% { background-position: 0% 50%; }
  50% { background-position: 100% 50%; }
  100% { background-position: 0% 50%; }
}

.gradient-shift {
  background-size: 200% 200%;
  animation: gradient-shift 4s ease infinite;
}

/* 呼吸辉光 */
@keyframes glow-breathe {
  0%, 100% { box-shadow: 0 0 12rpx rgba(255, 107, 107, 0.2); }
  50% { box-shadow: 0 0 28rpx rgba(255, 107, 107, 0.4); }
}

.glow-breathe {
  animation: glow-breathe 2.5s ease-in-out infinite;
}

/* 卡片入场缩放入上滑 */
@keyframes fade-up-scale {
  from { opacity: 0; transform: translateY(24rpx) scale(0.96); }
  to   { opacity: 1; transform: translateY(0) scale(1); }
}
.fade-up-scale {
  animation: fade-up-scale 0.4s var(--ease-out-expo) both;
}

/* 右侧滑入 */
@keyframes slide-right {
  from { opacity: 0; transform: translateX(40rpx); }
  to   { opacity: 1; transform: translateX(0); }
}
.slide-right {
  animation: slide-right var(--duration-slide) var(--ease-out-expo) both;
}

/* 左侧滑入 */
@keyframes slide-left {
  from { opacity: 0; transform: translateX(-40rpx); }
  to   { opacity: 1; transform: translateX(0); }
}
.slide-left {
  animation: slide-left var(--duration-slide) var(--ease-out-expo) both;
}

/* 底部弹出（Sheet / Modal 入场） */
@keyframes slide-up {
  from { opacity: 0; transform: translateY(100%); }
  to   { opacity: 1; transform: translateY(0); }
}
.slide-up {
  animation: slide-up var(--duration-slide) var(--ease-out-expo) both;
}

/* 弹簧按压反馈（替代普通 press-scale） */
.press-spring:active {
  transform: scale(0.94);
  transition: transform var(--duration-fast) var(--ease-spring);
}

/* 数字跳动入场 */
@keyframes count-up {
  from { opacity: 0; transform: translateY(12rpx); }
  to   { opacity: 1; transform: translateY(0); }
}
.count-up {
  animation: count-up 0.4s var(--ease-out-expo) both;
}

/* 浮动呼吸（空状态图标/装饰用） */
@keyframes float-breathe {
  0%, 100% { transform: translateY(0); }
  50%      { transform: translateY(-12rpx); }
}
.float-breathe {
  animation: float-breathe 3s var(--ease-in-out) infinite;
}

/* 旋转脉冲加载 */
@keyframes spin-pulse {
  0%   { transform: rotate(0deg) scale(1); }
  50%  { transform: rotate(180deg) scale(1.1); }
  100% { transform: rotate(360deg) scale(1); }
}
.spin-pulse {
  width: 28rpx; height: 28rpx;
  border: 3rpx solid var(--border-subtle);
  border-top-color: var(--brand);
  border-radius: 50%;
  animation: spin-pulse 0.8s var(--ease-in-out) infinite;
}

/* ── 玻璃高光反射（毛玻璃卡片左上角光泽）── */
.card::before,
.card-premium::before,
.card-stat::before {
  content: '';
  position: absolute;
  top: 0; left: 0;
  right: 0;
  height: 1rpx;
  background: linear-gradient(90deg, rgba(255,255,255,0.12), rgba(255,255,255,0.02) 60%, transparent);
  border-radius: inherit;
  pointer-events: none;
}

/* 卡片微浮 hover 提升 */
.card-lift {
  transition: transform var(--duration-normal) var(--ease-out-expo),
              box-shadow var(--duration-normal) var(--ease-out-expo);
}
.card-lift:active {
  transform: translateY(-4rpx);
  box-shadow: var(--shadow-lg);
}

/* 玻璃边缘光晕（用于 premium 卡片或重要操作区） */
.glow-edge {
  position: relative;
}
.glow-edge::after {
  content: '';
  position: absolute;
  inset: -1rpx;
  border-radius: inherit;
  background: var(--brand-gradient);
  z-index: -1;
  opacity: 0.15;
  filter: blur(8rpx);
}

/* ── 16. 布局增强工具类 ── */

/* 吸底操作栏（固定在页面底部） */
.sticky-bottom {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 20rpx 28rpx calc(20rpx + env(safe-area-inset-bottom));
  background: var(--bg-root);
  border-top: 1rpx solid var(--glass-border);
  backdrop-filter: var(--glass-blur);
  -webkit-backdrop-filter: var(--glass-blur);
  z-index: 50;
  display: flex;
  gap: 16rpx;
  box-sizing: border-box;
}

/* 分段标题（带图标装饰） */
.section-divider {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 32rpx 4rpx 16rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-primary);
}
.section-divider::before {
  content: '';
  width: 4rpx;
  height: 24rpx;
  border-radius: 2rpx;
  background: var(--brand-gradient);
  flex-shrink: 0;
}

/* 大触控容器（最小 88rpx 触摸区域） */
.touch-area {
  min-height: 88rpx;
  display: flex;
  align-items: center;
}

/* 内容区最大宽度（大屏平板限定） */
.content-max {
  max-width: 720rpx;
  margin: 0 auto;
  width: 100%;
}

/* 两列网格快捷操作 */
.action-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}
.action-grid-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 24rpx;
  border-radius: var(--radius-md);
  background: var(--glass-bg);
  backdrop-filter: var(--glass-blur);
  -webkit-backdrop-filter: var(--glass-blur);
  border: 1rpx solid var(--glass-border);
  min-height: 140rpx;
}
.action-grid-item:active {
  transform: scale(0.96);
  background: var(--bg-surface-hover);
}

/* 信息留白间距 */
.spacer-sm { height: 12rpx; }
.spacer-md { height: 24rpx; }
.spacer-lg { height: 40rpx; }

/* 大号主按钮（吸底专用） */
.btn-primary-lg {
  background: var(--brand-gradient);
  color: #FFFFFF;
  border: none;
  border-radius: var(--radius-lg);
  height: 96rpx;
  line-height: 96rpx;
  font-size: 30rpx;
  font-weight: 600;
  text-align: center;
  transition: all 0.2s ease;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: var(--shadow-glow);
  flex: 1;
}
.btn-primary-lg:active {
  opacity: 0.9;
  transform: scale(0.97);
}

/* 带图标的按钮（图标+文字垂直居中） */
.btn-with-icon {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}
.btn-with-icon .t-icon {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

/* 块级主按钮（撑满容器） */
.btn-primary-block {
  flex: 1;
  height: 92rpx;
  line-height: 92rpx;
  border-radius: var(--radius-full);
  background: var(--brand-gradient);
  color: #FFFFFF;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
  margin: 0;
  box-shadow: var(--shadow-glow);
  transition: all 0.2s;
  letter-spacing: 1rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.btn-primary-block:active {
  transform: scale(0.97);
  opacity: 0.9;
}

/* ── 17. 错误状态 ── */
.error-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 48rpx;
  text-align: center;
}
.error-state .error-icon {
  width: 140rpx;
  height: 140rpx;
  border-radius: var(--radius-xl);
  background: var(--danger-subtle);
  backdrop-filter: var(--glass-blur);
  -webkit-backdrop-filter: var(--glass-blur);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
  border: 1rpx solid var(--danger-border);
  font-size: 64rpx;
  color: var(--danger);
}
.error-state .error-label {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 12rpx;
}
.error-state .error-desc {
  font-size: 24rpx;
  color: var(--text-muted);
  line-height: 1.6;
  max-width: 500rpx;
  margin-bottom: 32rpx;
}
.error-retry-btn {
  padding: 16rpx 48rpx;
  border-radius: var(--radius-full);
  background: var(--brand-gradient);
  color: #FFFFFF;
  font-size: 26rpx;
  font-weight: 600;
  border: none;
  transition: all 0.2s ease;
  box-shadow: var(--shadow-glow);
}
.error-retry-btn:active {
  transform: scale(0.96);
  opacity: 0.9;
}

/* ── 18. 顶部加载进度条 ── */
.page-loading-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  height: 3rpx;
  z-index: 9999;
  background: linear-gradient(90deg, #FF6B6B, #FFA07A, #FDCB6E, #FF6B6B);
  background-size: 200% 100%;
  animation: loading-bar 1.2s ease infinite;
  pointer-events: none;
}
@keyframes loading-bar {
  0% { background-position: -200% 0; }
  100% { background-position: 200% 0; }
}

/* ── 19. 增强骨架屏 shimmer ── */
@keyframes skeleton-shimmer-v2 {
  0% { background-position: -200% 0; }
  100% { background-position: 200% 0; }
}
.skeleton-v2 {
  background: linear-gradient(90deg, var(--glass-bg) 25%, var(--bg-surface-hover) 50%, var(--glass-bg) 75%);
  background-size: 200% 100%;
  border-radius: var(--radius-sm);
  animation: skeleton-shimmer-v2 1.5s ease-in-out infinite;
}

/* ── 17. 统一图标风格系统 ── */

/* 图标容器 — 珊瑚橙渐变圆形底 */
.icon-wrapper {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: var(--brand-gradient);
  box-shadow: var(--shadow-glow);
  flex-shrink: 0;
  color: #FFFFFF;
  font-size: 32rpx;
}

/* 图标尺寸标准化 */
.icon-xxs { font-size: 20rpx !important; }
.icon-xs  { font-size: 24rpx !important; }
.icon-sm  { font-size: 28rpx !important; }
.icon-md  { font-size: 32rpx !important; }
.icon-lg  { font-size: 40rpx !important; }
.icon-xl  { font-size: 48rpx !important; }
.icon-xxl { font-size: 64rpx !important; }

/* 图标品牌色 */
.icon-brand { color: var(--brand) !important; }
.icon-muted { color: var(--text-muted) !important; }
.icon-white { color: #FFFFFF !important; }

/* 菜单图标圆形渐变底 */
.menu-icon-rounded {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  background: var(--brand-gradient);
  box-shadow: var(--shadow-glow);
  color: #FFFFFF;
  font-size: 32rpx;
}

/* 智能体头像 — 珊瑚橙渐变圆底 + 白色图标 + 发光 */
.agent-avatar-new {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: var(--brand-gradient);
  box-shadow: var(--shadow-glow);
  flex-shrink: 0;
  color: #FFFFFF;
  font-size: 40rpx;
}

/* ── 20. 列表页通用组件 ── */

/* 搜索栏 */
.search-bar-wrap {
  padding: 0 24rpx 16rpx;
}
.search-bar-inner {
  display: flex;
  align-items: center;
  height: 72rpx;
  background: var(--glass-bg);
  backdrop-filter: var(--glass-blur);
  -webkit-backdrop-filter: var(--glass-blur);
  border: 1rpx solid var(--glass-border);
  border-radius: var(--radius-full);
  padding: 0 24rpx;
  box-sizing: border-box;
}
.search-input {
  flex: 1;
  height: 100%;
  font-size: 24rpx;
  color: var(--text-primary);
  background: transparent;
  border: none;
  outline: none;
}
.search-placeholder {
  color: var(--text-placeholder);
  font-size: 24rpx;
}
.search-clear {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

/* 列表滚动容器（在 flex 布局中需要 height: 0 才能正确计算高度） */
.list-scroll {
  flex: 1;
  height: 0;
  padding: 0 24rpx;
}

/* 骨架屏外层 */
.skeleton-wrap {
  padding-top: 8rpx;
}

/* 加载更多指示器 */
.load-more-indicator {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 32rpx 0;
}
.load-more-text {
  font-size: 22rpx;
  color: var(--text-muted);
}
.load-more-end {
  color: var(--text-placeholder);
  letter-spacing: 2rpx;
}
