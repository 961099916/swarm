/* ══════════════════════════════════════════════════════
   Custom Tabbar — 原生 tabbar 布局标准
   图标 40rpx、文字 20rpx、整体 100rpx + safe-area
   ══════════════════════════════════════════════════════ */

.tabbar-wrap {
  display: flex;
  justify-content: space-around;
  align-items: center;
  height: calc(100rpx + env(safe-area-inset-bottom));
  padding-bottom: env(safe-area-inset-bottom);
  background: #2D2A24;
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 999;
}

/* ── 顶部边框线（原生风格 1px）── */
.tabbar-divider {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 1rpx;
  background: rgba(255, 255, 255, 0.1);
}

/* ── 单个 tab 项 ── */
.tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  padding: 6rpx 0 0;
  position: relative;
  flex: 1;
  color: #7A726A;
  -webkit-tap-highlight-color: transparent;
}

/* ── 图标 ── */
.tab-icon-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 48rpx;
  height: 36rpx;
}

.tab-item .t-icon {
  color: #7A726A !important;
  transition: color 0.15s ease;
}

.tab-item.tab-active .t-icon {
  color: #FF6B6B !important;
}

/* ── 标签文字 ── */
.tab-label {
  font-size: 20rpx;
  line-height: 1;
  font-weight: 400;
  color: #7A726A;
  transition: color 0.15s ease;
}

.tab-label.label-active {
  color: #FF6B6B;
}
