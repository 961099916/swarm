/* Swarm 现代弹窗组件 — Enterprise Modal */

.cyber-modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  background: var(--bg-mask, rgba(0, 0, 0, 0.6));
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.25s ease;
}

.cyber-modal-mask.modal-show {
  opacity: 1;
  pointer-events: auto;
}

.cyber-modal-card {
  width: 580rpx;
  background: var(--bg-surface);
  border: 1rpx solid var(--border-default);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-lg);
  padding: 48rpx 40rpx;
  transform: scale(0.92) translateY(20rpx);
  transition: all 0.25s cubic-bezier(0.16, 1, 0.3, 1);
  box-sizing: border-box;
}

.cyber-modal-mask.modal-show .cyber-modal-card {
  transform: scale(1) translateY(0);
}

/* 标题 */
.modal-title-container {
  margin-bottom: 24rpx;
  text-align: center;
}

.modal-title-text {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
}

/* 内容 */
.modal-body-container {
  margin-bottom: 48rpx;
  text-align: center;
}

.modal-body-text {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.6;
  display: block;
}

/* 按钮组 */
.modal-action-row {
  display: flex;
  gap: 16rpx;
  justify-content: center;
}

.modal-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: var(--radius-md) !important;
  font-size: 28rpx;
  font-weight: 600;
  text-align: center;
  padding: 0 !important;
  margin: 0 !important;
  box-sizing: border-box;
  border: none !important;
  box-shadow: none !important;
  transition: opacity 0.2s ease;
}

.modal-btn::after {
  border: none;
}

.modal-btn:active {
  opacity: 0.85;
}

/* 取消按钮 */
.modal-btn-cancel {
  background: var(--bg-surface) !important;
  color: var(--text-primary) !important;
  border: 1rpx solid var(--border-default) !important;
}

/* 确认按钮 */
.modal-btn-confirm {
  background: var(--brand) !important;
  color: #FFFFFF !important;
}

.modal-btn-confirm.btn-danger {
  background: var(--danger) !important;
  color: #FFFFFF !important;
}

/* Loading 旋转 */
.cyber-loading-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 24rpx 0 10rpx 0;
}

.cyber-loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 3rpx solid var(--border-subtle);
  border-top-color: var(--brand);
  border-radius: 50%;
  animation: modal-spin 0.8s linear infinite;
  margin-bottom: 24rpx;
}

@keyframes modal-spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.cyber-loading-tip {
  font-size: 24rpx;
  color: var(--text-muted);
  font-weight: 500;
}
