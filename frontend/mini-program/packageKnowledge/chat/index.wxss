/* packageKnowledge/chat/index.wxss — 暖绒奶油风 & 极致交互设计 */
.page { height: 100vh; display: flex; flex-direction: column; background: var(--bg-root); position: relative; }
.header { padding: 16rpx 24rpx; background: var(--bg-surface-solid); border-bottom: 1rpx solid var(--glass-border); }
.header-left { display: flex; align-items: center; gap: 12rpx; }
.header-title { font-size: 32rpx; font-weight: 600; color: var(--text-primary); }

.docs-panel { background: var(--bg-surface-solid); border-bottom: 1rpx solid var(--glass-border); padding: 16rpx 24rpx; max-height: 300rpx; overflow-y: auto; }
.docs-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12rpx; }
.docs-title { font-size: 26rpx; font-weight: 500; color: var(--text-primary); }
.docs-count { font-size: 22rpx; color: var(--text-muted); }
.docs-loading, .docs-empty { text-align: center; color: var(--text-muted); font-size: 24rpx; padding: 20rpx 0; }
.docs-list { display: flex; flex-direction: column; gap: 12rpx; }
.doc-item { display: flex; align-items: center; gap: 12rpx; }
.doc-item-info { display: flex; align-items: center; gap: 8rpx; flex: 1; }
.doc-item-title { font-size: 24rpx; color: var(--text-secondary); flex: 1; }
.doc-item-status { font-size: 20rpx; padding: 2rpx 10rpx; border-radius: 8rpx; }
.doc-item-status.READY { background: var(--success-subtle); color: var(--success); }
.doc-item-status.PROCESSING { background: var(--warning-subtle); color: var(--warning); }
.doc-item-status.FAILED { background: var(--danger-subtle); color: var(--danger); }

.chat-area { flex: 1; padding: 24rpx; overflow-y: auto; box-sizing: border-box; }
.msg { margin-bottom: 24rpx; display: flex; }
.msg-user { justify-content: flex-end; }
.msg-assistant { justify-content: flex-start; }
.msg-bubble { max-width: 75%; padding: 20rpx 24rpx; border-radius: 16rpx; font-size: 28rpx; line-height: 1.6; word-break: break-word; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05); }
.user-bubble { background: var(--brand-gradient); color: #fff; border-bottom-right-radius: 4rpx; }
.assistant-bubble { background: var(--bg-surface-solid); color: var(--text-primary); border-bottom-left-radius: 4rpx; border: 1rpx solid var(--glass-border); }
.thinking { display: flex; align-items: center; gap: 12rpx; color: var(--text-muted); font-size: 26rpx; }

.sources { margin-top: 16rpx; padding-top: 16rpx; border-top: 1rpx solid var(--glass-border); }
.sources-label { font-size: 22rpx; color: var(--text-muted); display: block; margin-bottom: 6rpx; }
.source-tag { display: inline-block; font-size: 20rpx; color: var(--brand); background: var(--brand-subtle); padding: 4rpx 12rpx; border-radius: 8rpx; margin: 4rpx 6rpx 4rpx 0; }

/* 打字机闪烁光标 */
.assistant-content { display: inline; position: relative; }
.typing-cursor {
  display: inline-block;
  width: 4rpx;
  height: 28rpx;
  background-color: var(--brand, #FF6B6B);
  margin-left: 8rpx;
  vertical-align: middle;
  animation: cursor-blink 1s step-start infinite;
}
@keyframes cursor-blink {
  50% { opacity: 0; }
}

/* 新消息悬浮球 */
.new-msg-badge {
  position: fixed;
  bottom: calc(160rpx + env(safe-area-inset-bottom));
  right: 32rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 24rpx;
  background: var(--bg-surface-solid);
  border: 1rpx solid var(--glass-border);
  border-radius: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.15);
  z-index: 100;
  animation: slideIn 0.25s ease-out;
}
.new-msg-badge text {
  font-size: 24rpx;
  color: var(--text-secondary);
  font-weight: 500;
}
@keyframes slideIn {
  from { transform: translateY(20rpx); opacity: 0; }
  to { transform: translateY(0); opacity: 1; }
}

/* 输入框与过渡效果 */
.input-area {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 24rpx;
  background: var(--bg-root);
  border-top: 1rpx solid var(--glass-border);
  box-sizing: border-box;
  z-index: 90;
  transition: padding-bottom 0.15s ease-out;
}
.chat-input { flex: 1; height: 72rpx; background: var(--bg-surface-solid); border-radius: 12rpx; padding: 0 20rpx; font-size: 28rpx; color: var(--text-primary); }

/* ─── 文档详情抽屉样式 ─── */
.doc-detail-drawer {
  width: 80vw;
  height: 100vh;
  background: var(--bg-root);
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
}

.doc-detail-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 24rpx;
  background: var(--bg-surface-solid);
  border-bottom: 1rpx solid var(--glass-border);
}

.doc-detail-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-right: 16rpx;
}

.doc-detail-close {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--text-muted);
  background: var(--bg-root);
  border-radius: 50%;
  border: 1rpx solid var(--glass-border);
  transition: all 0.2s ease;
}

.doc-detail-close:active {
  background: var(--brand-subtle);
  color: var(--brand);
}

.doc-detail-content {
  flex: 1;
  overflow-y: auto;
}

.doc-detail-loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
  color: var(--text-muted);
}

/* ─── 大厂级奶油文章排版引擎 (Warm Cream Typography) ─── */
.doc-detail-body {
  padding: 40rpx 32rpx;
  color: var(--text-primary);
  font-size: 28rpx;
  line-height: 1.75;
  letter-spacing: 0.5rpx;
}

/* 标题分级 */
.doc-detail-body h1, .doc-detail-body ._h1 {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-top: 48rpx;
  margin-bottom: 24rpx;
  line-height: 1.3;
  border-bottom: 2rpx solid var(--glass-border);
  padding-bottom: 12rpx;
}

.doc-detail-body h2, .doc-detail-body ._h2 {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-top: 40rpx;
  margin-bottom: 20rpx;
  line-height: 1.4;
  padding-left: 16rpx;
  border-left: 6rpx solid var(--brand); /* 品牌色左边条 */
}

.doc-detail-body h3, .doc-detail-body ._h3 {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-top: 32rpx;
  margin-bottom: 16rpx;
}

/* 段落与段间距 */
.doc-detail-body p, .doc-detail-body ._p {
  margin: 0 0 24rpx 0;
  text-align: justify;
  word-break: break-all;
}

/* 强调与粗体 */
.doc-detail-body strong, .doc-detail-body ._strong {
  font-weight: 700;
  color: var(--brand); /* 粗体突出品牌色，增强奶油暖调感 */
}

/* 列表样式 */
.doc-detail-body ul, .doc-detail-body ._ul, .doc-detail-body ol, .doc-detail-body ._ol {
  margin: 0 0 24rpx 0;
  padding-left: 36rpx;
}

.doc-detail-body li, .doc-detail-body ._li {
  margin-bottom: 8rpx;
  line-height: 1.6;
}

/* 引用块美化 */
.doc-detail-body blockquote, .doc-detail-body ._blockquote {
  margin: 24rpx 0;
  padding: 20rpx 24rpx;
  background: var(--bg-surface);
  border-left: 8rpx solid var(--accent-peach, #FFA07A); /* 暖色左边线 */
  border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
  color: var(--text-secondary);
  font-style: italic;
}

/* 行内代码与代码块 */
.doc-detail-body code, .doc-detail-body ._code {
  font-family: SFMono-Regular, Consolas, Monaco, monospace;
  font-size: 24rpx;
  background: var(--bg-surface-solid);
  padding: 4rpx 10rpx;
  border-radius: var(--radius-sm);
  color: var(--accent-coral, #FF6B6B); /* 珊瑚色高亮行内代码 */
  margin: 0 4rpx;
}

.doc-detail-body pre, .doc-detail-body ._pre {
  margin: 24rpx 0;
  padding: 24rpx;
  background: var(--bg-surface-solid) !important;
  border: 1rpx solid var(--glass-border);
  border-radius: var(--radius-md);
  overflow-x: auto;
  box-shadow: var(--shadow-sm);
}

.doc-detail-body pre code, .doc-detail-body ._pre ._code {
  background: transparent !important;
  padding: 0 !important;
  border-radius: 0 !important;
  color: var(--text-secondary) !important;
  font-size: 24rpx;
  white-space: pre;
}

/* 网页图片适配 */
.doc-detail-body img, .doc-detail-body ._img {
  max-width: 100% !important;
  height: auto !important;
  border-radius: var(--radius-sm);
  margin: 16rpx 0;
  box-shadow: var(--shadow-sm);
}

/* 链接美化 */
.doc-detail-body a, .doc-detail-body ._a {
  color: var(--brand);
  text-decoration: underline;
  word-break: break-all;
}

.doc-detail-empty {
  text-align: center;
  padding: 100rpx 0;
  color: var(--text-muted);
  font-size: 26rpx;
  font-style: italic;
}

/* ─── 原件预览与链接复制工具栏 ─── */
.doc-origin-bar {
  display: flex;
  gap: 16rpx;
  margin-bottom: 32rpx;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid var(--glass-border);
}

.origin-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 16rpx 28rpx;
  font-size: 24rpx;
  font-weight: 600;
  border-radius: var(--radius-md);
  flex: 1;
  transition: all 0.2s ease;
}

.origin-btn:active {
  transform: scale(0.97);
  opacity: 0.9;
}

.btn-primary-green {
  background: linear-gradient(135deg, var(--success), #26A69A) !important;
  color: #ffffff !important;
  box-shadow: 0 4rpx 16rpx rgba(46, 204, 113, 0.15);
}

.btn-primary-green .t-icon {
  color: #ffffff !important;
}

.btn-secondary-gray {
  background: var(--bg-surface-solid) !important;
  color: var(--text-secondary) !important;
  border: 1rpx solid var(--glass-border);
}

.btn-secondary-gray .t-icon {
  color: var(--text-muted) !important;
}


