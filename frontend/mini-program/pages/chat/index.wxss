/* pages/chat/index.wxss — 暖绒奶油风 & 极致交互设计 */
.page { height: 100vh; display: flex; flex-direction: column; background: var(--bg-root); position: relative; }
.chat-area { flex: 1; padding: 24rpx; overflow-y: auto; box-sizing: border-box; }
.msg { margin-bottom: 24rpx; display: flex; }
.msg-user { justify-content: flex-end; }
.msg-assistant { justify-content: flex-start; }
.msg-bubble { max-width: 80%; padding: 20rpx 24rpx; border-radius: 16rpx; font-size: 28rpx; line-height: 1.6; word-break: break-word; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05); }
.user-bubble { background: var(--brand-gradient); color: #fff; border-bottom-right-radius: 4rpx; }
.assistant-bubble { background: var(--bg-surface-solid); color: var(--text-primary); border-bottom-left-radius: 4rpx; border: 1rpx solid var(--glass-border); }
.thinking { display: flex; align-items: center; gap: 12rpx; color: var(--text-muted); font-size: 26rpx; }

/* 打字机闪烁光标 */
.assistant-content { display: inline; position: relative; }
.typing-cursor {
  display: inline-block;
  width: 4rpx;
  height: 28rpx;
  background-color: var(--brand, #FF6B6B);
  margin-left: 8rpx;
  vertical-align: middle;
  animation: cursor-blink 1s step-start infinite;
}
@keyframes cursor-blink {
  50% { opacity: 0; }
}

/* 新消息悬浮球 */
.new-msg-badge {
  position: fixed;
  bottom: calc(160rpx + env(safe-area-inset-bottom));
  right: 32rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 24rpx;
  background: var(--bg-surface-solid);
  border: 1rpx solid var(--glass-border);
  border-radius: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.15);
  z-index: 100;
  animation: slideIn 0.25s ease-out;
}
.new-msg-badge text {
  font-size: 24rpx;
  color: var(--text-secondary);
  font-weight: 500;
}
@keyframes slideIn {
  from { transform: translateY(20rpx); opacity: 0; }
  to { transform: translateY(0); opacity: 1; }
}

/* 输入框自适应联动 */
.input-area {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 24rpx;
  background: var(--bg-root);
  border-top: 1rpx solid var(--glass-border);
  box-sizing: border-box;
  z-index: 90;
  transition: padding-bottom 0.15s ease-out;
}
.chat-input { flex: 1; height: 72rpx; background: var(--bg-surface-solid); border-radius: 12rpx; padding: 0 20rpx; font-size: 28rpx; color: var(--text-primary); }
