<!-- File: /Users/zhangjiahao/IdeaProjects/swarm/frontend/mini-program/pages/deploy/index.wxml -->
<page-meta page-style="overflow: {{showAgentModal ? 'hidden' : 'visible'}}"></page-meta>
<!-- Swarm 部署 — 智能体协同编排 -->
<view class="deploy-container {{theme}}">

  <!-- 页面标题 -->
  <view class="page-head-title mb-1">创建任务</view>
  <text class="page-subtitle mb-3">配置智能体协同编排流，自动执行 AI 任务</text>

  <!-- 表单面板 -->
  <!-- Tab 切换 -->
  <t-tabs defaultValue="{{activeTab}}" bind:change="onTabChange" class="custom-tabs">
    <t-tab-panel label="自动协同" value="{{0}}" />
    <t-tab-panel label="自定义流" value="{{1}}" />
  </t-tabs>

  <view class="card form-panel">
    <!-- 基本信息区 -->
    <t-divider text="基本信息" align="left" />
    <view class="form-body">
      <view class="form-group">
        <text class="form-label">工作流名称</text>
        <t-input class="td-input-custom" value="{{ workflowName }}" placeholder="如: 每日边缘算力分析流" placeholder-class="form-placeholder" borderless="{{false}}" bind:change="onWorkflowNameInput" />
      </view>
      
      <!-- 自动协同模式表单 -->
      <block wx:if="{{activeTab === 0}}">
        <view class="form-group {{fieldErrors.goal ? 'has-error' : ''}}">
          <text class="form-label">任务目标</text>
          <t-textarea class="td-textarea-custom" value="{{ goal }}" placeholder="请输入任务目标，系统将自动召集智能体集群完成" placeholder-class="form-placeholder" bind:change="onGoalInput" />
          <text wx:if="{{fieldErrors.goal}}" class="field-error-text">{{fieldErrors.goal}}</text>
        </view>
        
        <!-- 智能体配置区 -->
        <view class="spacer-md"></view>
        <t-divider text="智能体配置" align="left" />
        <view class="form-body">
          <view class="form-group">
            <view class="form-label-row flex justify-between items-center">
              <text class="form-label">选择协同智能体</text>
              <text class="form-link" bindtap="openAgentModal">+ 创造新模型</text>
            </view>
            <view class="agent-list">
              <block wx:if="{{loadingAgents}}">
                <t-skeleton loading="{{loadingAgents}}" row-col="{{skeletonConfig}}" />
              </block>
              <block wx:elif="{{availableAgents.length === 0}}">
                <t-empty description="暂无可用智能体，点击下方「创造新模型」创建一个" />
              </block>
              <block wx:else>
                <!-- 已选智能体芯片展示 -->
                <view wx:if="{{selectedAgentCount > 0}}" class="selected-agents-row">
                  <view wx:for="{{selectedAgentPreview}}" wx:key="id" class="agent-chip">
                    <view class="agent-chip-avatar">{{item.name ? item.name.charAt(0).toUpperCase() : '?'}}</view>
                    <text class="agent-chip-name">{{item.name}}</text>
                    <view class="agent-chip-remove" data-id="{{item.id}}" catchtap="toggleAgent">✕</view>
                  </view>
                </view>
                <view class="agent-actions-row flex gap-1">
                  <button class="btn-primary btn-with-icon" bindtap="openAgentPicker">
                    <view class="t-icon t-icon-add btn-icon-add"></view>
                    <text>{{selectedAgentCount > 0 ? '更换智能体' : '选择智能体'}}</text>
                  </button>
                  <button class="btn-secondary btn-with-icon" bindtap="openAgentModal">
                    <view class="t-icon t-icon-add btn-icon-add"></view>
                    <text>创造新模型</text>
                  </button>
                </view>
              </block>
            </view>
          </view>
          <view class="form-group">
            <view class="form-label-row flex justify-between items-center">
              <text class="form-label">最大迭代轮数: <text class="num-font num-brand">{{ maxLoops }}</text> 轮</text>
              <text class="form-hint">推荐 5 轮</text>
            </view>
            <t-slider value="{{ maxLoops }}" min="{{ 2 }}" max="{{ 8 }}" step="{{ 1 }}" bindchange="onLoopsChange" colors="{{ ['#FF6B6B', '#FF6B6B', 'rgba(255,255,255,0.08)'] }}" />
          </view>
        </view>
      </block>

      <!-- 自定义流模式表单 -->
      <block wx:else>
        <view class="form-group {{fieldErrors.goal ? 'has-error' : ''}}">
          <text class="form-label">全局初始输入</text>
          <t-textarea class="td-textarea-custom" value="{{ goal }}" placeholder="请输入该自定义工作流的全局初始目标或分析素材..." placeholder-class="form-placeholder" bind:change="onGoalInput" />
          <text wx:if="{{fieldErrors.goal}}" class="field-error-text">{{fieldErrors.goal}}</text>
        </view>

        <!-- 步骤编排区 -->
        <view class="spacer-md"></view>
        <t-divider text="步骤编排" align="left" />
        <view class="custom-flow-panel">
          <view wx:for="{{stepsList}}" wx:key="id" class="step-card">
            <!-- 步骤头部 -->
            <view class="step-card-header">
              <view class="step-card-title-row">
                <view class="step-badge">{{index + 1}}</view>
                <input class="step-title-input" value="{{item.name}}" placeholder="请输入步骤名称" data-idx="{{index}}" bindinput="onStepNameInput" />
              </view>
              <view class="step-card-actions">
                <t-icon name="arrow-up" class="step-action-icon" data-idx="{{index}}" bindtap="moveStepUp" />
                <t-icon name="arrow-down" class="step-action-icon" data-idx="{{index}}" bindtap="moveStepDown" />
                <t-icon name="delete" class="step-action-icon danger" data-idx="{{index}}" bindtap="deleteStep" />
              </view>
            </view>

            <!-- 步骤表单 -->
            <view class="step-form">
              <!-- 1. 类型选择 -->
              <view class="step-field">
                <text class="step-field-label">节点执行类型</text>
                <picker bindchange="onStepTypeChange" data-idx="{{index}}" range="{{stepTypeOptions}}" range-key="label">
                  <view class="step-picker-trigger">
                    <text>{{item.type === 'agent' ? '智能体' : item.type === 'tool' ? '系统工具' : '条件分类'}}</text>
                    <t-icon name="chevron-down" size="24rpx" color="var(--text-muted)" />
                  </view>
                </picker>
              </view>

              <!-- 2. 根据类型展示具体配置 -->
              <!-- 智能体 -->
              <view wx:if="{{item.type === 'agent'}}" class="step-field">
                <text class="step-field-label">选择执行智能体</text>
                <picker bindchange="onStepAgentChange" data-idx="{{index}}" range="{{availableAgents}}" range-key="name">
                  <view class="step-picker-trigger">
                    <text>{{item.targetAgentName || '请选择智能体...'}}</text>
                    <t-icon name="chevron-down" size="24rpx" color="var(--text-muted)" />
                  </view>
                </picker>
              </view>

              <!-- 工具 -->
              <view wx:if="{{item.type === 'tool'}}" class="step-field">
                <text class="step-field-label">选择系统边缘工具</text>
                <picker bindchange="onStepToolChange" data-idx="{{index}}" range="{{toolOptions}}" range-key="label">
                  <view class="step-picker-trigger">
                    <text>{{item.targetToolLabel || '请选择系统工具...'}}</text>
                    <t-icon name="chevron-down" size="24rpx" color="var(--text-muted)" />
                  </view>
                </picker>
              </view>

              <!-- 3. 指令/Prompt配置 -->
              <view wx:if="{{item.type !== 'condition'}}" class="step-field">
                <text class="step-field-label">附加执行指令 (可选)</text>
                <textarea class="step-textarea" value="{{item.prompt}}" placeholder="输入该步骤的具体处理 Prompt，如：请将其翻译为英文" data-idx="{{index}}" bindinput="onStepPromptInput" />
              </view>

              <!-- 4. 条件分支配置 -->
              <view wx:if="{{item.type === 'condition'}}" class="step-field">
                <text class="step-field-label">分支决策匹配规则 (LLM单选分类)</text>
                <view class="branches-container">
                  <view wx:for="{{item.branches}}" wx:for-item="branch" wx:for-index="bIdx" wx:key="bIdx" class="branch-item">
                    <view class="branch-header">
                      <text class="branch-title">判定路径分支 {{bIdx + 1}}</text>
                      <text class="branch-remove" data-sidx="{{index}}" data-bidx="{{bIdx}}" bindtap="deleteBranch">删除</text>
                    </view>
                    <input class="branch-input" placeholder="分支说明 (如: 愤怒退款)" value="{{branch.label}}" data-sidx="{{index}}" data-bidx="{{bIdx}}" bindinput="onBranchLabelInput" />
                    <view class="form-hint branch-hint">当 AI 判决结果输出判定词为：</view>
                    <input class="branch-input" placeholder="匹配单词 (必须为英文/拼音, 如: refund)" value="{{branch.matchValue}}" data-sidx="{{index}}" data-bidx="{{bIdx}}" bindinput="onBranchValueInput" />
                    
                    <view class="form-hint branch-next-hint">满足时，下一步跳转指向步骤：</view>
                    <picker bindchange="onBranchNextChange" data-sidx="{{index}}" data-bidx="{{bIdx}}" range="{{item.nextOptions}}" range-key="label">
                      <view class="step-picker-trigger">
                        <text>{{branch.targetStepName || '结束流程'}}</text>
                        <t-icon name="chevron-down" size="24rpx" color="var(--text-muted)" />
                      </view>
                    </picker>
                  </view>
                  <view class="add-branch-btn" data-idx="{{index}}" bindtap="addBranch">+ 新增分类路径</view>
                </view>

                <text class="step-field-label step-label-spacing">未匹配时默认跳转步骤</text>
                <picker bindchange="onStepDefaultNextChange" data-idx="{{index}}" range="{{item.nextOptions}}" range-key="label">
                  <view class="step-picker-trigger">
                    <text>{{item.defaultNextStepName || '结束流程'}}</text>
                    <t-icon name="chevron-down" size="24rpx" color="var(--text-muted)" />
                  </view>
                </picker>

                <text class="step-field-label step-label-spacing">判断目标提示词 (由LLM判定)</text>
                <textarea class="step-textarea" value="{{item.prompt}}" placeholder="例如：判断用户的言论是 positive 还是 negative" data-idx="{{index}}" bindinput="onStepPromptInput" />
              </view>

              <!-- 5. 下一步连线 (非条件节点展示) -->
              <view wx:if="{{item.type !== 'condition'}}" class="step-field">
                <text class="step-field-label">下一步跳转执行</text>
                <picker bindchange="onStepNextChange" data-idx="{{index}}" range="{{item.nextOptions}}" range-key="label">
                  <view class="step-picker-trigger">
                    <text>{{item.nextStepName || '结束流程'}}</text>
                    <t-icon name="chevron-down" size="24rpx" color="var(--text-muted)" />
                  </view>
                </picker>
              </view>
            </view>
          </view>

          <!-- 新增步骤与图预览 -->
          <view class="add-step-btn" bindtap="addNewStep">+ 新增步骤节点</view>
          
          <button class="add-step-btn btn-with-icon btn-flow-preview" bindtap="openFlowPreview">
            <t-icon name="view-module" size="32rpx" />
            <text>预览当前流程图</text>
          </button>
        </view>
      </block>
    </view>

    <view class="form-group {{fieldErrors.email ? 'has-error' : ''}}">
      <text class="form-label">邮件推送地址（可选）</text>
      <t-input class="td-input-custom" value="{{ email }}" placeholder="留空则仅在小程序通知" placeholder-class="form-placeholder" borderless="{{false}}" bind:change="onEmailInput" />
      <text wx:if="{{fieldErrors.email}}" class="field-error-text">{{fieldErrors.email}}</text>
    </view>
  </view>

  <!-- 算力收据 -->
  <view class="card cost-card">
    <view class="cost-head">
      <view class="cost-title">算力消耗清单</view>
      <text class="cost-status {{ isCreditsEnough ? 'ok' : 'warn' }}">{{ isCreditsEnough ? '算力充足' : '余额不足' }}</text>
    </view>
    <view class="separator"></view>
    <view class="cost-body">
      <view class="cost-row flex justify-between">
        <text class="cost-label">本次消耗</text>
        <text class="cost-minus">-5</text>
      </view>
      <view class="cost-row flex justify-between">
        <text class="cost-label">账户余额</text>
        <text class="cost-balance {{ isCreditsEnough ? 'ok' : 'warn' }} num-font">{{ userCredits }} 积分</text>
      </view>
    </view>
    <view class="separator"></view>
    <text class="cost-note {{ isCreditsEnough ? '' : 'warn' }}">{{ isCreditsEnough ? '算力充足' : '余额不足，请前往积分页面充值' }}</text>
  </view>

  <!-- 吸底操作栏 -->
  <view class="sticky-bottom">
    <button class="btn-primary-lg" loading="{{ deploying }}" bindtap="handleDeploy">提交部署</button>
  </view>

  <!-- 智能体选择器弹窗 — 三段式布局（搜索区 / 列表区 / 操作区） -->
  <t-popup visible="{{ showAgentPicker }}" placement="bottom" closeOnOverlayClick="{{true}}" showOverlay="{{true}}" bindvisible-change="onPickerVisibleChange">
    <view class="picker-sheet">
      <!-- 上区：标题 + 搜索（固定高度，不随列表滚动） -->
      <view class="picker-top">
        <view class="picker-header">
          <text class="picker-title">选择协同智能体</text>
          <view class="picker-close-btn" bindtap="closeAgentPicker">
            <view class="t-icon t-icon-close picker-icon-close-inner"></view>
          </view>
        </view>
        <view class="search-bar-wrap picker-search-wrap">
          <search-bar value="{{agentSearchQuery}}" placeholder="搜索智能体名称..." bind:change="onAgentSearchInput" />
        </view>
      </view>
      <!-- 中区：智能体列表（独立滚动，撑满剩余空间） -->
      <view class="picker-middle">
        <scroll-view scroll-y class="picker-list" enhanced>
          <view wx:if="{{filteredAgents.length === 0}}" class="picker-empty-list">
            <text class="picker-empty-text">无匹配智能体</text>
          </view>
          <view wx:for="{{filteredAgents}}" wx:key="id"
            class="picker-agent-item {{ selectedAgentIdsMap[item.id] ? 'selected' : '' }}"
            data-id="{{ item.id }}" bindtap="toggleAgent">
            <view class="agent-avatar-new agent-avatar-icon-wrap">
              <view class="t-icon t-icon-{{ item.avatar || 'service' }} agent-avatar-icon"></view>
            </view>
            <view class="picker-agent-info">
              <view class="picker-agent-name">{{ item.name }}
                <t-tag size="small" theme="{{ item.isPreset ? 'primary' : 'warning' }}" variant="light">{{ item.isPreset ? '预设' : '自定义' }}</t-tag>
              </view>
              <text class="picker-agent-role">{{ item.role }}</text>
            </view>
            <view wx:if="{{ selectedAgentIdsMap[item.id] }}" class="picker-check">
              <view class="t-icon t-icon-check picker-icon-check"></view>
            </view>
          </view>
        </scroll-view>
      </view>
      <!-- 下区：计数 + 确认按钮（固定高度，不随列表滚动） -->
      <view class="picker-bottom">
        <view class="picker-bottom-inner">
          <text class="picker-selected-count">已选 {{selectedAgentCount}} 个智能体</text>
          <button class="btn-primary btn-primary-block" bindtap="confirmAgentPicker">确认选择</button>
        </view>
      </view>
    </view>
  </t-popup>

  <!-- 流程预览弹窗 -->
  <t-popup visible="{{ showFlowPreview }}" placement="bottom" closeOnOverlayClick="{{true}}" showOverlay="{{true}}" bindvisible-change="onFlowPreviewVisibleChange">
    <view class="picker-sheet flow-preview-sheet">
      <view class="picker-top">
        <view class="picker-header">
          <text class="picker-title">工作流逻辑拓扑预览</text>
          <view class="picker-close-btn" bindtap="closeFlowPreview">
            <view class="t-icon t-icon-close flow-preview-close"></view>
          </view>
        </view>
      </view>
      <view class="picker-middle flow-preview-middle">
        <canvas type="2d" id="flowCanvas" class="flow-preview-canvas"></canvas>
      </view>
    </view>
  </t-popup>
</view>
