<view class="page {{theme}}">
  <!-- 顶部：标题 + 新建按钮 -->
  <view class="page-header">
    <text class="page-title">知识库</text>
    <view class="create-btn" bindtap="showCreate">
      <t-icon name="add" size="14" />
      <text>新建</text>
    </view>
  </view>

  <!-- 搜索栏（引入原子组件） -->
  <view class="search-bar-wrap">
    <search-bar value="{{searchQuery}}" placeholder="搜索知识库名称或描述..." bind:change="onSearch" bind:clear="onSearchClear" />
  </view>

  <!-- 统计 -->
  <view wx:if="{{!loading && total > 0}}" class="stats-row">
    <view class="stat-item">
      <text class="stat-num">{{total}}</text>
      <text class="stat-label">知识库</text>
    </view>
  </view>

  <!-- 加载 -->
  <view wx:if="{{loading}}" class="loading-wrap">
    <t-loading size="40rpx" />
    <text class="loading-text">加载中...</text>
  </view>

  <!-- 知识库列表 -->
  <view wx:elif="{{kbList.length > 0}}" class="kb-list">
    <view wx:for="{{kbList}}" wx:key="id" class="kb-card" data-kb="{{item}}" bindtap="goToChat">
      <!-- 左侧彩色装饰条 -->
      <view class="kb-accent {{item.isPublic ? 'accent-public' : 'accent-private'}}"></view>
      <view class="kb-card-body">
        <!-- 标题行 -->
        <view class="kb-header-row">
          <text class="kb-name">{{item.name}}</text>
          <view class="kb-badge {{item.isPublic ? 'badge-public' : 'badge-private'}}">
            {{item.isPublic ? '公开' : '私有'}}
          </view>
        </view>
        <!-- 描述 -->
        <text class="kb-desc" wx:if="{{item.description}}">{{item.description}}</text>
        <!-- 指标行 -->
        <view class="kb-metrics">
          <view class="metric-item">
            <t-icon name="file-txt" size="14" />
            <text>{{item.documentCount || 0}} 篇</text>
          </view>
          <view class="metric-item">
            <t-icon name="time" size="14" />
            <text>{{item.createdAt ? item.createdAt.slice(0, 10) : ''}}</text>
          </view>
        </view>
        <!-- 操作栏 -->
        <view class="kb-actions">
          <view class="action-chip" data-kb="{{item}}" catchtap="goToChat">
            <t-icon name="chat" size="13" /><text>问答</text>
          </view>
          <view class="action-chip" data-kb="{{item}}" catchtap="goToDetail">
            <t-icon name="view-list" size="13" /><text>文档</text>
          </view>
          <view class="action-chip chip-danger" data-kb="{{item}}" catchtap="onDeleteKB">
            <t-icon name="delete" size="13" /><text>删除</text>
          </view>
        </view>
      </view>
    </view>
    <!-- 加载更多指示器 -->
    <view wx:if="{{loading}}" class="load-more-wrap">
      <t-loading size="28rpx" /><text>加载中...</text>
    </view>
    <view wx:elif="{{!hasMore && total > 0}}" class="load-more-end">— 已全部加载 —</view>
  </view>

  <!-- 空状态（引入原子组件） -->
  <empty-state
    wx:elif="{{!loading && kbList.length === 0}}"
    icon="bookmark"
    label="暂无知识库"
    desc="点击右上角「新建」创建你的第一个知识库"
    iconSize="{{40}}"
    iconWrapSize="{{70}}"
  />

  <!-- 创建知识库弹窗（底部弹出） -->
  <t-popup visible="{{showCreateDialog}}" placement="bottom" bindvisiblechange="onCreateCancel">
    <view class="popup-sheet">
      <view class="popup-header">
        <text class="popup-title">新建知识库</text>
        <view class="popup-close" bindtap="onCreateCancel">
          <t-icon name="close" size="16" />
        </view>
      </view>
      <view class="popup-body">
        <t-input label="名称" placeholder="知识库名称（必填）" value="{{newKBName}}" bind:change="onNameInput" />
        <t-input label="描述" placeholder="可选：知识库用途说明" value="{{newKBDesc}}" bind:change="onDescInput" />
      </view>
      <view class="popup-footer">
        <t-button theme="default" size="medium" block bindtap="onCreateCancel">取消</t-button>
        <t-button theme="primary" size="medium" block bindtap="onCreateKB">创建</t-button>
      </view>
    </view>
  </t-popup>
</view>
