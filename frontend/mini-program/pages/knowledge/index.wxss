.page { min-height: 100vh; background: var(--bg-root); color: var(--text-primary); }
.page-header { display: flex; justify-content: space-between; align-items: center; padding: 20rpx 24rpx 0; }
.page-title { font-size: 40rpx; font-weight: 700; color: var(--text-primary); }
.create-btn { display: flex; align-items: center; gap: 6rpx; color: var(--brand); font-size: 26rpx; padding: 8rpx 16rpx; border-radius: 20rpx; background: var(--brand-subtle); border: 1rpx solid var(--brand-border); }
.create-btn .t-icon { color: var(--brand) !important; }

/* 搜索栏由 app.wxss 统一定义，并使用抽离的 search-bar 原子组件 */
.search-bar-wrap { padding: 20rpx 24rpx; }

.stats-row {
  display: flex;
  justify-content: center;
  margin: 0 24rpx 20rpx;
  background: var(--glass-bg);
  backdrop-filter: var(--glass-blur);
  -webkit-backdrop-filter: var(--glass-blur);
  border: 1rpx solid var(--glass-border);
  border-radius: var(--radius-md);
  padding: 20rpx;
  box-shadow: var(--shadow-sm);
}
.stat-item { display: flex; flex-direction: column; align-items: center; gap: 4rpx; }
.stat-num { font-size: 36rpx; font-weight: 700; color: var(--brand); }
.stat-label { font-size: 22rpx; color: var(--text-muted); }

.loading-wrap { display: flex; flex-direction: column; align-items: center; padding: 80rpx 0; gap: 16rpx; }
.loading-text { color: var(--text-muted); font-size: 26rpx; }

/* ── 卡片列表 ── */
.kb-list { padding: 0 24rpx; display: flex; flex-direction: column; gap: 20rpx; padding-bottom: 120rpx; }

.kb-card {
  display: flex; overflow: hidden;
  background: var(--glass-bg);
  backdrop-filter: var(--glass-blur);
  -webkit-backdrop-filter: var(--glass-blur);
  border: 1rpx solid var(--glass-border);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-sm);
  transition: all 0.2s ease;
  position: relative;
}
.kb-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 1rpx;
  background: linear-gradient(90deg, rgba(255,255,255,0.12), rgba(255,255,255,0.02) 60%, transparent);
  pointer-events: none;
}
.kb-card:active {
  background: var(--bg-surface-hover);
  border-color: var(--border-strong);
  transform: scale(0.98);
}

/* 左侧彩色装饰条 */
.kb-accent { width: 6rpx; flex-shrink: 0; }
.accent-public { background: var(--brand-gradient); }
.accent-private { background: linear-gradient(180deg, #7A726A, #999); }

/* 卡片主体 */
.kb-card-body { flex: 1; padding: 20rpx 20rpx 16rpx; min-width: 0; }

/* 标题行 */
.kb-header-row { display: flex; justify-content: space-between; align-items: center; gap: 12rpx; margin-bottom: 8rpx; }
.kb-name { font-size: 30rpx; font-weight: 600; color: var(--text-primary); flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.kb-badge { font-size: 20rpx; padding: 2rpx 14rpx; border-radius: 20rpx; flex-shrink: 0; }
.badge-public { background: var(--brand-subtle); color: var(--brand); }
.badge-private { background: var(--bg-surface-hover); color: var(--text-muted); }

/* 描述 */
.kb-desc { font-size: 24rpx; color: var(--text-muted); display: block; margin-bottom: 12rpx; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

/* 指标行 */
.kb-metrics { display: flex; gap: 24rpx; margin-bottom: 14rpx; }
.metric-item { display: flex; align-items: center; gap: 6rpx; font-size: 22rpx; color: var(--text-placeholder); }
.metric-item .t-icon { color: var(--text-placeholder) !important; }

/* 操作栏 */
.kb-actions { display: flex; gap: 10rpx; padding-top: 12rpx; border-top: 1rpx solid var(--glass-border); }
.action-chip {
  display: flex; align-items: center; gap: 6rpx; padding: 8rpx 20rpx; border-radius: var(--radius-sm);
  font-size: 24rpx; color: var(--text-secondary); background: var(--glass-bg); border: 1rpx solid var(--glass-border); flex: 1; justify-content: center;
}
.action-chip .t-icon { color: var(--text-muted) !important; }
.action-chip:active { background: var(--bg-surface-hover); }
.chip-danger { color: var(--danger); border-color: var(--danger-border); }
.chip-danger .t-icon { color: var(--danger) !important; }

/* 加载更多 */
.load-more-wrap, .load-more-end { display: flex; align-items: center; justify-content: center; gap: 8rpx; padding: 20rpx 0; font-size: 24rpx; color: var(--text-placeholder); }

.popup-sheet {
  background: var(--glass-bg);
  backdrop-filter: var(--glass-blur);
  -webkit-backdrop-filter: var(--glass-blur);
  border-top: 1rpx solid var(--glass-border);
  border-radius: var(--radius-lg) var(--radius-lg) 0 0;
  padding: 32rpx;
  box-shadow: var(--shadow-lg);
}
.popup-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24rpx; }
.popup-title { font-size: 32rpx; font-weight: 600; color: var(--text-primary); }
.popup-close { padding: 8rpx; }
.popup-close .t-icon { color: var(--text-muted) !important; }
.popup-body { display: flex; flex-direction: column; gap: 20rpx; margin-bottom: 32rpx; }
.popup-footer { display: flex; gap: 16rpx; }
.popup-footer .t-button { flex: 1; border-radius: var(--radius-lg); }
