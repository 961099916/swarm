<view class="login-container {{theme}}">
  <view class="glow-blob blob-1"></view>
  <view class="glow-blob blob-2"></view>
  <view class="login-body">
    <view class="login-logo">
      <view class="logo-ring"><text class="logo-symbol">◉</text></view>
      <text class="logo-name">智能体工作台</text>
    </view>
    <view class="login-hero">
      <text class="login-title">智能体慢任务管家</text>
      <text class="login-sub">云端托管 · 零成本 · 24小时自动运行</text>
    </view>
    <view class="login-features">
      <text class="feature-tag">无需服务器</text>
      <text class="feature-tag">安全合规</text>
      <text class="feature-tag">实时控制面板</text>
    </view>
    <view class="login-btn-wrap">
      <t-button theme="primary" size="large" block loading="{{loading}}" class="login-btn" bindtap="handleWeixinLogin">微信一键登录</t-button>
    </view>
    <view class="login-invite">
      <view class="invite-divider">
        <view class="invite-line"></view>
        <text class="invite-div-txt">好友邀请（选填）</text>
        <view class="invite-line"></view>
      </view>
      <t-input class="invite-input" value="{{inviteCode}}" placeholder="输入好友的邀请码" maxlength="8" borderless align="center" bindchange="onInviteCodeChange" />
    </view>
    <view class="login-protocol">
      <text>登录即代表同意 </text><text class="link" bindtap="viewAgreement">《用户协议》</text><text> 与 </text><text class="link" bindtap="viewPrivacy">《隐私政策》</text>
    </view>
  </view>
  <t-toast id="t-toast" />
</view>
