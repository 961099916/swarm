<!-- File: /Users/zhangjiahao/IdeaProjects/swarm/frontend/mini-program/pages/task/list/index.wxml -->
<view class="task-container {{theme}}">

  <!-- 顶部：页面标题 + 积分徽章 -->
  <view class="credits-row">
    <text class="page-head-title">任务</text>
    <view class="credits-badge" bindtap="goToCredits">
      <text class="dot-breathe"></text>
      <text class="credits-num">{{userCredits}}</text>
      <text class="credits-unit">算力</text>
    </view>
  </view>

  <!-- 统计概览 — 企业级 KPI 卡 -->
  <view class="kpi-grid">
    <view class="card kpi-card {{filterValue === 'RUNNING' ? 'active' : ''}}" data-value="RUNNING" bindtap="onFilterChange">
      <view class="kpi-head">
        <text class="kpi-label">运行中</text>
        <view class="status-dot status-dot-running"></view>
      </view>
      <text class="kpi-num num-font">{{stats.running}}</text>
      <text class="kpi-sub">个任务运行中</text>
    </view>

    <view class="card kpi-card {{filterValue === 'ALL' ? 'active' : ''}}" data-value="ALL" bindtap="onFilterChange">
      <view class="kpi-head">
        <text class="kpi-label">全部任务</text>
      </view>
      <text class="kpi-num num-font">{{stats.total}}</text>
      <text class="kpi-sub">已部署</text>
    </view>

    <view class="card kpi-card {{filterValue === 'SUCCESS' ? 'active' : ''}}" data-value="SUCCESS" bindtap="onFilterChange">
      <view class="kpi-head">
        <text class="kpi-label">已完成</text>
      </view>
      <text class="kpi-num num-font success">{{stats.success}}</text>
      <text class="kpi-sub">已归档</text>
    </view>

    <view class="card kpi-card {{filterValue === 'FAILED' ? 'active' : ''}}" data-value="FAILED" bindtap="onFilterChange">
      <view class="kpi-head">
        <text class="kpi-label">异常</text>
      </view>
      <text class="kpi-num num-font danger">{{stats.failed || 0}}</text>
      <text class="kpi-sub">需处理</text>
    </view>
  </view>

  <!-- 筛选栏 -->
  <view class="filter-section">
    <view class="filter-section-head">
      <text class="filter-section-title">任务筛选</text>
      <text class="filter-section-count">{{filteredTasks.length}} 项</text>
    </view>
    <scroll-view class="filter-bar" scroll-x enable-flex enhanced show-scrollbar="{{false}}">
      <view class="filter-items">
        <view
          wx:for="{{filterOptions}}"
          wx:key="value"
          class="pill-filter {{filterValue === item.value ? 'active' : ''}}"
          data-value="{{item.value}}"
          bindtap="onFilterChange"
        >
          {{item.label}}
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- 搜索框 (引入原子组件) -->
  <view class="search-bar-wrap">
    <search-bar
      value="{{searchQuery}}"
      placeholder="搜索任务名称或 ID..."
      bind:change="onSearchInput"
    />
  </view>

  <!-- 任务列表 -->
  <view class="task-list">
    <!-- 骨架加载 -->
    <view wx:if="{{loading && tasks.length === 0}}">
      <view class="skeleton skeleton-card" wx:for="{{[1,2,3]}}" wx:key="*this"></view>
    </view>

    <!-- 错误状态 -->
    <view wx:elif="{{loadError}}" class="error-state">
      <view class="error-icon">
        <view class="t-icon t-icon-info-circle error-indicator-icon"></view>
      </view>
      <text class="error-label">加载失败</text>
      <text class="error-desc">网络异常，请检查后重试</text>
      <button class="error-retry-btn" bindtap="onRetry">重新加载</button>
    </view>

    <!-- 空状态（引入原子组件） -->
    <empty-state
      wx:elif="{{filteredTasks.length === 0}}"
      icon="mail"
      label="暂无任务"
      desc="部署智能体协同编排流，享受全自动 AI 执行服务"
    >
      <button class="btn-primary task-empty-btn" bindtap="goToDeploy">创建任务</button>
    </empty-state>

    <!-- 任务卡片（交错入场动画） -->
    <view wx:else>
      <view
        wx:for="{{filteredTasks}}"
        wx:key="id"
        class="card card-actionable task-card status-{{item.statusClass}} fade-up"
        data-id="{{item.id}}"
        bindtap="goToDetail"
        style="animation-delay: {{index * 0.06}}s;"
      >
        <view class="task-status-bar {{item.statusClass}}"></view>

        <!-- 头部：主信息 + 状态 -->
        <view class="card-head">
          <view class="task-meta">
            <view class="task-title-row">
              <text class="task-name">{{item.displayName}}</text>
              <text class="task-type-tag">协同</text>
            </view>
            <view class="task-sub-row">
              <text class="task-id">ID: {{item.id}}</text>
              <text class="task-cost">消耗 {{item.credits_cost || 0}} 积分</text>
            </view>
            <text class="task-time">{{item.formattedTime}} 创建</text>
          </view>
          <view class="tag tag-{{item.statusClass}}">
            <view wx:if="{{item.status === 'RUNNING'}}" class="status-dot status-dot-running"></view>
            <text>{{item.statusLabel}}</text>
          </view>
        </view>

        <!-- 属性网格 -->
        <view class="card-props" wx:if="{{item.result_summary || item.payload.workflowName}}">
          <view class="prop-grid">
            <view class="prop-cell span-2" wx:if="{{item.payload.workflowName}}">
              <text class="prop-label">工作流</text>
              <text class="prop-value">{{item.payload.workflowName}}</text>
            </view>
            <view class="prop-cell" wx:if="{{item.payload.goal}}">
              <text class="prop-label">目标</text>
              <text class="prop-value">{{item.payload.goal}}</text>
            </view>
            <view class="prop-cell" wx:if="{{item.payload.maxLoops}}">
              <text class="prop-label">轮数</text>
              <text class="prop-value">{{item.payload.maxLoops}} 轮</text>
            </view>
            <view class="prop-cell span-2" wx:if="{{item.result_summary}}">
              <text class="prop-label">执行结果</text>
              <text class="prop-value summary">{{item.result_summary}}</text>
            </view>
          </view>
        </view>

        <!-- 尾部 -->
        <view class="card-foot">
          <text class="foot-hint">查看详情</text>
          <view class="arrow-right-ios"></view>
        </view>
      </view>
      <!-- 上拉加载更多 -->
      <view wx:if="{{filteredTasks.length > 0 && loading}}" class="load-more-indicator">
        <view class="spinner-ios"></view>
        <text class="load-more-text">加载中...</text>
      </view>
      <view wx:elif="{{filteredTasks.length > 0 && !hasMore}}" class="load-more-indicator">
        <text class="load-more-end">— 已加载全部任务 —</text>
      </view>
    </view>  <!-- /wx:else -->
  </view>

  <!-- 自定义 Tabbar -->
</view>
