.admin-container { padding: 32rpx 24rpx 48rpx; background: var(--bg-root); min-height: 100vh; box-sizing: border-box; transition: background 0.3s ease; }
.admin-container.theme-light { background: var(--bg-root); }
.board-title { font-size: 40rpx; font-weight: 700; display: block; margin-bottom: 24rpx; }
.filter-info { padding: 20rpx; margin-bottom: 20rpx; }
.fi-title { font-size: 28rpx; font-weight: 700; display: block; }
.fi-desc { font-size: 22rpx; color: var(--text-muted); display: block; margin-top: 8rpx; margin-bottom: 20rpx; }
.admin-search { --td-input-bg-color: var(--bg-surface); --td-input-border-color: var(--border-default); --td-input-text-color: var(--text); --td-input-placeholder-text-color: var(--text-muted); border-radius: 10rpx; overflow: hidden; }
.agent-list { display: flex; flex-direction: column; gap: 12rpx; padding-bottom: 48rpx; }
.ag-card { padding: 24rpx; }
.ag-top { display: flex; align-items: center; gap: 16rpx; margin-bottom: 24rpx; }
.ag-avatar { font-size: 64rpx; width: 96rpx; height: 80rpx; border-radius: 8rpx; background: var(--bg-surface); display: flex; align-items: center; justify-content: center; border: 1rpx solid var(--border-default); flex-shrink: 0; }
.ag-meta { flex: 1; min-width: 0; }
.ag-name-row { display: flex; align-items: center; gap: 12rpx; }
.ag-name { font-size: 28rpx; font-weight: 700; color: var(--text); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; max-width: 280rpx; display: block; }
.ag-badge { font-size: 18rpx; padding: 3rpx 12rpx; border-radius: 4rpx; font-weight: 600; }
.ag-badge.preset { background: var(--success-subtle); color: var(--success); }
.ag-badge.custom { background: var(--warning-subtle); color: var(--warning); }
.ag-role { font-size: 20rpx; color: var(--text-muted); display: block; margin-top: 6rpx; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.ag-details { display: flex; flex-direction: column; gap: 12rpx; margin-bottom: 20rpx; }
.ag-drow { display: flex; justify-content: space-between; font-size: 22rpx; }
.ag-dlbl { color: var(--text-muted); }
.ag-dval { color: var(--text-secondary); }
.ag-prompt-box { margin-bottom: 20rpx; }
.ag-prompt-txt { padding: 16rpx; border-radius: 8rpx; background: rgba(0,0,0,0.2); font-size: 20rpx; color: var(--text-secondary); line-height: 1.5; max-height: 100rpx; overflow: hidden; display: block; margin-top: 8rpx; word-break: break-all; }
.ag-acts { display: flex; gap: 12rpx; }
.ag-act { flex: 1; padding: 14rpx; border-radius: 8rpx; text-align: center; font-size: 22rpx; font-weight: 600; border: 1rpx solid var(--border-default); }
.ag-act.edit { background: var(--brand-subtle); border-color: var(--brand-border); color: var(--brand); }
.ag-act.delete { background: var(--danger-subtle); border-color: var(--danger-border); color: var(--danger); }
.modal-sheet { padding: 24rpx; padding-bottom: calc(40rpx + env(safe-area-inset-bottom)); display: flex; flex-direction: column; gap: 16rpx; background: var(--bg-surface); border-radius: 24rpx 24rpx 0 0; border-top: 1rpx solid var(--border-default); }
.modal-head { display: flex; justify-content: space-between; align-items: center; }
.modal-title { font-size: 32rpx; font-weight: 700; color: var(--text); }
.modal-close { font-size: 44rpx; color: var(--text-muted); padding: 0 12rpx; }
.modal-body { display: flex; flex-direction: column; gap: 16rpx; overflow-y: auto; max-height: 60vh; }
.form-g { display: flex; flex-direction: column; gap: 10rpx; }
.form-lbl { font-size: 24rpx; font-weight: 600; color: var(--text); }
.modal-inp { --td-input-bg-color: var(--bg-surface); --td-input-border-color: var(--border-default); --td-input-text-color: var(--text); --td-input-placeholder-text-color: var(--text-muted); border-radius: 10rpx; overflow: hidden; }
.modal-tarea { --td-textarea-background-color: var(--bg-surface); --td-textarea-border-color: var(--border-default); --td-textarea-text-color: var(--text); --td-textarea-placeholder-color: var(--text-muted); height: 180rpx; border-radius: 10rpx; overflow: hidden; }
.model-opts { display: flex; flex-direction: column; gap: 12rpx; }
.mo-item { padding: 20rpx; border-radius: 10rpx; background: var(--bg-surface); border: 1rpx solid var(--border-default); }
.mo-item.active { border-color: var(--brand-border); background: var(--brand-subtle); }
.mo-name { font-size: 24rpx; font-weight: 600; color: var(--text); display: block; }
.mo-desc { font-size: 20rpx; color: var(--text-muted); display: block; margin-top: 4rpx; }
.save-admin-btn { --td-button-primary-bg-color: var(--brand) !important; border-radius: 10rpx !important; margin-top: 8rpx; }
.save-admin-btn::after { border: none; }
