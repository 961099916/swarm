/* packageAdmin/agents/index.wxss — 暖绒奶油风 */

.admin-container { padding: 24rpx 24rpx 48rpx; background: var(--bg-root); color: var(--text); min-height: 100vh; box-sizing: border-box; animation: fade-up 0.35s ease-out both; }
.admin-container.theme-light { background: var(--bg-root); }

.board-title { font-size: 32rpx; font-weight: 700; color: var(--text-primary); display: block; margin-bottom: 24rpx; }

/* 顶部说明卡片 — 毛玻璃 */
.filter-info { padding: 24rpx; margin-bottom: 24rpx; border-radius: var(--radius-lg); background: var(--glass-bg); backdrop-filter: var(--glass-blur); -webkit-backdrop-filter: var(--glass-blur); border: 1rpx solid var(--glass-border); }
.fi-title { font-size: 26rpx; font-weight: 700; color: var(--text-primary); display: block; }
.fi-desc { font-size: 22rpx; color: var(--text-muted); display: block; margin-top: 8rpx; margin-bottom: 20rpx; }

.admin-search {
  --td-input-bg-color: var(--glass-bg);
  --td-input-border-color: var(--glass-border);
  --td-input-text-color: var(--text-primary);
  --td-input-placeholder-text-color: var(--text-placeholder);
  border-radius: var(--radius-lg);
  overflow: hidden;
  backdrop-filter: var(--glass-blur);
  -webkit-backdrop-filter: var(--glass-blur);
}

.agent-list { display: flex; flex-direction: column; gap: 16rpx; padding-bottom: 48rpx; }

/* 智能体卡片 — 毛玻璃 */
.ag-card { padding: 24rpx; border-radius: var(--radius-md); background: var(--glass-bg); backdrop-filter: var(--glass-blur); -webkit-backdrop-filter: var(--glass-blur); border: 1rpx solid var(--glass-border); }

.ag-top { display: flex; align-items: center; gap: 16rpx; margin-bottom: 20rpx; }
.ag-meta { flex: 1; min-width: 0; }
.ag-name-row { display: flex; align-items: center; gap: 10rpx; flex-wrap: wrap; }
.ag-name { font-size: 26rpx; font-weight: 700; color: var(--text-primary); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; max-width: 280rpx; display: block; }

.ag-badge { font-size: 18rpx; padding: 4rpx 14rpx; border-radius: var(--radius-full); font-weight: 600; }
.ag-badge.preset { background: var(--success-subtle); color: var(--success); border: 1rpx solid var(--success-border); }
.ag-badge.custom { background: var(--warning-subtle); color: var(--warning); border: 1rpx solid var(--warning-border); }

.ag-role { font-size: 20rpx; color: var(--text-muted); display: block; margin-top: 6rpx; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

/* 详情 */
.ag-details { display: flex; flex-direction: column; gap: 12rpx; margin-bottom: 20rpx; }
.ag-drow { display: flex; justify-content: space-between; font-size: 22rpx; padding: 0 4rpx; }
.ag-dlbl { color: var(--text-muted); }
.ag-dval { color: var(--text-secondary); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; max-width: 60%; }

.ag-prompt-box { margin-bottom: 20rpx; }
.ag-prompt-txt { padding: 16rpx; border-radius: var(--radius-sm); background: var(--glass-bg); backdrop-filter: var(--glass-blur); -webkit-backdrop-filter: var(--glass-blur); border: 1rpx solid var(--glass-border); font-size: 20rpx; color: var(--text-secondary); line-height: 1.5; max-height: 100rpx; overflow: hidden; display: block; margin-top: 8rpx; word-break: break-all; }

/* 操作按钮 */
.ag-acts { display: flex; gap: 12rpx; }
.ag-act {
  flex: 1;
  padding: 14rpx;
  border-radius: var(--radius-full);
  text-align: center;
  font-size: 22rpx;
  font-weight: 600;
  transition: all 0.2s;
}
.ag-act:active { transform: scale(0.95); }
.ag-act.edit { background: var(--brand-gradient); color: #FFFFFF; box-shadow: var(--shadow-glow); border: none; }
.ag-act.delete { background: var(--glass-bg); backdrop-filter: var(--glass-blur); -webkit-backdrop-filter: var(--glass-blur); color: var(--danger); border: 1rpx solid var(--danger-border); }

/* 弹窗 */
.modal-sheet { padding: 32rpx; padding-bottom: calc(40rpx + env(safe-area-inset-bottom)); display: flex; flex-direction: column; gap: 20rpx; background: var(--bg-surface-solid); border-radius: var(--radius-xl) var(--radius-xl) 0 0; border-top: 1rpx solid var(--glass-border); }
.modal-head { display: flex; justify-content: space-between; align-items: center; }
.modal-title { font-size: 32rpx; font-weight: 700; color: var(--text-primary); }
.modal-close { font-size: 44rpx; color: var(--text-muted); padding: 0 12rpx; }
.modal-body { display: flex; flex-direction: column; gap: 20rpx; overflow-y: auto; max-height: 60vh; }

.form-g { display: flex; flex-direction: column; gap: 12rpx; }
.form-lbl { font-size: 24rpx; font-weight: 600; color: var(--text-primary); }

.modal-inp {
  --td-input-bg-color: var(--glass-bg);
  --td-input-border-color: var(--glass-border);
  --td-input-text-color: var(--text-primary);
  --td-input-placeholder-text-color: var(--text-placeholder);
  border-radius: var(--radius-md);
  overflow: hidden;
  backdrop-filter: var(--glass-blur);
  -webkit-backdrop-filter: var(--glass-blur);
}
.modal-tarea {
  --td-textarea-background-color: var(--glass-bg);
  --td-textarea-border-color: var(--glass-border);
  --td-textarea-text-color: var(--text-primary);
  --td-textarea-placeholder-color: var(--text-placeholder);
  height: 180rpx;
  border-radius: var(--radius-md);
  overflow: hidden;
  backdrop-filter: var(--glass-blur);
  -webkit-backdrop-filter: var(--glass-blur);
}

.model-opts { display: flex; flex-direction: column; gap: 14rpx; }
.mo-item { padding: 24rpx; border-radius: var(--radius-md); background: var(--glass-bg); backdrop-filter: var(--glass-blur); -webkit-backdrop-filter: var(--glass-blur); border: 1rpx solid var(--glass-border); }
.mo-item.active { border-color: var(--brand-border); background: var(--brand-subtle); box-shadow: var(--shadow-glow); }
.mo-name { font-size: 24rpx; font-weight: 600; color: var(--text-primary); display: block; }
.mo-desc { font-size: 20rpx; color: var(--text-muted); display: block; margin-top: 4rpx; }

.save-admin-btn { --td-button-primary-bg-color: var(--brand) !important; border-radius: var(--radius-md) !important; margin-top: 8rpx; background: var(--brand-gradient) !important; border: none !important; }
.save-admin-btn::after { border: none; }

/* 搜索和列表滚动容器（继承自全局 .search-bar-wrap / .admin-list-scroll） */
