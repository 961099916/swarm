/* packageAdmin/dashboard/index.wxss — 暖绒奶油风 */

.admin-container { padding: 24rpx; padding-bottom: 160rpx; background: var(--bg-root); min-height: 100vh; box-sizing: border-box; color: var(--text); animation: fade-up 0.35s ease-out both; }
.admin-container.theme-light { background: var(--bg-root); }

.board-title { font-size: 32rpx; font-weight: 700; color: var(--text-primary); margin-bottom: 24rpx; display: block; }

/* KPI 统计 — 毛玻璃卡片 */
.kpi-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16rpx; margin-bottom: 32rpx; }

.card-stat {
  padding: 24rpx;
  min-height: 130rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  border-radius: var(--radius-lg);
  background: var(--glass-bg);
  backdrop-filter: var(--glass-blur);
  -webkit-backdrop-filter: var(--glass-blur);
  border: 1rpx solid var(--glass-border);
  box-shadow: var(--shadow-sm);
}
.card-stat.accent-brand { border-color: var(--brand-border); }
.card-stat.accent-success { border-color: var(--success-border); }

.stat-label { font-size: 22rpx; color: var(--text-secondary); display: block; margin-bottom: 8rpx; }
.stat-num { font-size: 48rpx; font-weight: 700; color: var(--text-primary); line-height: 1.1; }
.stat-num.accent { color: var(--brand); }
.stat-num.success { color: var(--success); }
.stat-sub { font-size: 18rpx; color: var(--text-muted); margin-top: 4rpx; display: block; }

/* 管理入口 */
.section-hd { font-size: 28rpx; font-weight: 600; color: var(--text-primary); margin-bottom: 16rpx; display: block; }

.menu-list { display: flex; flex-direction: column; gap: 14rpx; }
.menu-item {
  padding: 28rpx 24rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-radius: var(--radius-lg);
  background: var(--glass-bg);
  backdrop-filter: var(--glass-blur);
  -webkit-backdrop-filter: var(--glass-blur);
  border: 1rpx solid var(--glass-border);
}
.menu-item:active { background: var(--bg-surface-hover); transform: scale(0.98); }

.menu-left { display: flex; align-items: center; gap: 16rpx; flex: 1; min-width: 0; }
.menu-icon { width: 72rpx; height: 72rpx; border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.menu-texts { flex: 1; min-width: 0; }
.menu-title { font-size: 26rpx; font-weight: 600; color: var(--text-primary); display: block; }
.menu-desc { font-size: 20rpx; color: var(--text-muted); margin-top: 4rpx; display: block; }
