/* 管理看板 */

.admin-container {
  padding: 32rpx 24rpx 48rpx;
  background: var(--bg-root);
  color: var(--text);
  min-height: 100vh;
  box-sizing: border-box;
  transition: background 0.3s ease;
}

.admin-container.theme-light {
  background: var(--bg-root);
  color: var(--text);
}

.board-title {
  font-size: 40rpx;
  font-weight: 700;
  margin-bottom: 20rpx;
  display: block;
  color: var(--text);
}

.kpi-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.card-stat {
  background: var(--bg-surface);
  border: 1rpx solid var(--border-default);
  border-radius: 8rpx;
  padding: 28rpx 24rpx;
  min-height: 140rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.card-stat.accent-brand {
  background: rgba(30, 111, 255, 0.06);
  border-color: var(--brand-border);
}

.card-stat.accent-success {
  background: var(--success-subtle);
  border-color: var(--success-border);
}

.stat-label {
  font-size: 24rpx;
  color: var(--text-secondary);
  font-weight: 500;
}

.stat-num {
  font-size: 52rpx;
  font-weight: 700;
  line-height: 1;
  color: var(--text);
}

.stat-num.accent { color: var(--brand); }
.stat-num.success { color: var(--success); }

.stat-sub {
  font-size: 20rpx;
  color: var(--text-muted);
}

.section-hd {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text);
  margin-bottom: 16rpx;
  display: block;
}

.menu-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.menu-item {
  padding: 24rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.menu-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.menu-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  flex-shrink: 0;
}

.menu-texts {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.menu-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text);
}

.menu-desc {
  font-size: 22rpx;
  color: var(--text-muted);
  line-height: 1.4;
}
