<view class="page">
  <!-- 顶部操作栏 -->
  <view class="actions">
    <t-button theme="primary" size="small" bindtap="showManualDialog">手动录入</t-button>
    <t-button theme="default" size="small" bindtap="showUrlDialog">网页抓取</t-button>
    <t-button theme="default" size="small" bindtap="goToSearch">搜索</t-button>
  </view>

  <!-- 知识库信息 -->
  <view class="kb-info" wx:if="{{kbInfo}}">
    <text class="kb-desc">{{kbInfo.description || '暂无描述'}}</text>
    <view class="kb-config">
      <text>分块大小: {{kbInfo.chunkSize}}字符</text>
      <text>重叠: {{kbInfo.chunkOverlap}}字符</text>
      <text>嵌入模型: {{kbInfo.embeddingModel}}</text>
    </view>
  </view>

  <!-- 文档列表 -->
  <view class="section-title">文档列表 ({{documents.length}})</view>

  <view wx:if="{{loading}}" class="loading">加载中...</view>

  <view wx:elif="{{documents.length > 0}}" class="doc-list">
    <view wx:for="{{documents}}" wx:key="id" class="doc-card">
      <view class="doc-header">
        <text class="doc-title">{{item.title}}</text>
        <text class="doc-status {{item.status}}">
          {{item.status === 'READY' ? '就绪' : item.status === 'PROCESSING' ? '处理中' : item.status === 'FAILED' ? '失败' : '待处理'}}
        </text>
      </view>
      <view class="doc-meta">
        <text>来源: {{item.sourceType === 'WEB_SCRAPE' ? '网页' : item.sourceType === 'MANUAL' ? '手动录入' : '上传'}}</text>
        <text wx:if="{{item.chunkCount}}">分块: {{item.chunkCount}}</text>
        <text wx:if="{{item.errorMessage}}" class="error">{{item.errorMessage}}</text>
      </view>
      <view class="doc-actions">
        <t-button theme="danger" size="extra-small" variant="outline"
          data-doc="{{item}}" bindtap="onDeleteDoc">删除</t-button>
      </view>
    </view>
  </view>

  <view wx:else class="empty">
    <text>暂无文档，点击上方按钮添加</text>
  </view>

  <!-- 手动录入弹窗 -->
  <t-dialog
    visible="{{showManualDialog}}" title="手动录入"
    confirm-btn="提交" cancel-btn="取消"
    bindconfirm="onManualSubmit" bindcancel="onManualCancel"
  >
    <view class="dialog-content">
      <t-input label="标题" placeholder="文档标题" value="{{manualTitle}}" bindinput="onManualTitleInput" />
      <t-textarea label="内容" placeholder="输入文档正文内容" value="{{manualContent}}" bindinput="onManualContentInput" />
    </view>
  </t-dialog>

  <!-- 网页抓取弹窗 -->
  <t-dialog
    visible="{{showUrlDialog}}" title="网页抓取"
    confirm-btn="提交" cancel-btn="取消"
    bindconfirm="onUrlSubmit" bindcancel="onUrlCancel"
  >
    <view class="dialog-content">
      <t-input label="URL" placeholder="https://example.com/article" value="{{urlInput}}" bindinput="onUrlInput" />
      <t-input label="标题(可选)" placeholder="自定义标题" value="{{urlTitle}}" bindinput="onUrlTitleInput" />
    </view>
  </t-dialog>
</view>
