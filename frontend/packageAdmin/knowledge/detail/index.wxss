/* packageAdmin/knowledge/detail/index.wxss — 暖绒奶油风 */
.page { padding: 24rpx; min-height: 100vh; background: #F5F0E8; }
.actions { display: flex; gap: 16rpx; margin-bottom: 24rpx; flex-wrap: wrap; }

.kb-info { background: #FFFDF5; border-radius: 16rpx; padding: 20rpx; margin-bottom: 24rpx; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06); }
.kb-desc { font-size: 26rpx; color: #888; display: block; margin-bottom: 12rpx; }
.kb-config { display: flex; gap: 20rpx; font-size: 22rpx; color: #aaa; flex-wrap: wrap; }

.section-title { font-size: 30rpx; font-weight: 600; color: #3D3A35; margin-bottom: 16rpx; }

.loading, .empty { text-align: center; padding: 60rpx 0; color: #999; font-size: 28rpx; }
.doc-list { display: flex; flex-direction: column; gap: 16rpx; }
.doc-card { background: #FFFDF5; border-radius: 12rpx; padding: 20rpx; box-shadow: 0 2rpx 6rpx rgba(0,0,0,0.04); }
.doc-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 8rpx; }
.doc-title { font-size: 28rpx; font-weight: 500; color: #3D3A35; flex: 1; }
.doc-status { padding: 2rpx 12rpx; border-radius: 12rpx; font-size: 20rpx; }
.doc-status.READY { background: #E8F5E9; color: #2E7D32; }
.doc-status.PROCESSING { background: #FFF8E1; color: #F57F17; }
.doc-status.FAILED { background: #FFEBEE; color: #C62828; }
.doc-status.PENDING { background: #F5F5F5; color: #888; }
.doc-meta { font-size: 22rpx; color: #aaa; display: flex; gap: 16rpx; flex-wrap: wrap; }
.doc-meta .error { color: #C62828; }
.doc-actions { margin-top: 12rpx; display: flex; justify-content: flex-end; }
.dialog-content { padding: 16rpx 0; display: flex; flex-direction: column; gap: 16rpx; }
