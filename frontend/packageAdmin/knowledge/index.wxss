/* packageAdmin/knowledge/index.wxss — 暖绒奶油风 */
.page { padding: 24rpx; min-height: 100vh; background: #F5F0E8; }
.header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24rpx; }
.header-title { font-size: 36rpx; font-weight: bold; color: #3D3A35; }
.loading, .empty { text-align: center; padding: 80rpx 0; color: #999; font-size: 28rpx; }
.empty-hint { display: block; margin-top: 16rpx; font-size: 24rpx; color: #bbb; }

.list { display: flex; flex-direction: column; gap: 20rpx; }
.kb-card {
  background: #FFFDF5; border-radius: 16rpx; padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06); position: relative;
}
.kb-header { display: flex; align-items: center; gap: 12rpx; margin-bottom: 12rpx; }
.kb-name { font-size: 30rpx; font-weight: 600; color: #3D3A35; flex: 1; }
.kb-badge {
  padding: 4rpx 16rpx; border-radius: 20rpx; font-size: 22rpx;
}
.kb-badge.public { background: #E8F5E9; color: #2E7D32; }
.kb-badge.private { background: #FFF3E0; color: #E65100; }
.kb-desc { font-size: 26rpx; color: #888; margin-bottom: 16rpx; }
.kb-meta { display: flex; gap: 24rpx; font-size: 22rpx; color: #aaa; }
.kb-actions { margin-top: 16rpx; display: flex; justify-content: flex-end; }
.dialog-content { padding: 16rpx 0; }
