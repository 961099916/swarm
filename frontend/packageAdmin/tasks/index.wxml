<!-- 管理后台 — 任务列表（使用 list-page 通用组件） -->
<view class="admin-container {{theme}}">
  <text class="board-title">任务管理</text>

  <list-page
    list="{{list}}"
    loading="{{loading}}"
    refreshing="{{refreshing}}"
    hasMore="{{hasMore}}"
    total="{{total}}"
    errorMsg="{{errorMsg}}"
    filterOptions="{{filterOptions}}"
    filterValue="{{filterValue}}"
    searchQuery="{{searchQuery}}"
    showSearch="{{showSearch}}"
    searchPlaceholder="{{searchPlaceholder}}"
    emptyText="暂无任务"
    bind:refresh="loadFirstPage"
    bind:loadmore="loadNextPage"
    bind:search="onSearchInput"
    bind:filterchange="onFilterChange"
  >
    <!-- 任务卡片列表 -->
    <view wx:for="{{list}}" wx:key="id" class="card tcard fade-up status-{{item.statusClass}}" data-id="{{item.id}}" bindtap="goToDetail">
      <view class="tcard-bar status-{{item.statusClass}}"></view>
      <view class="tcard-head">
        <view class="tcard-left">
          <text class="tcard-name">{{item.displayName || item.taskType}}</text>
          <text class="tcard-id">{{item.id}}</text>
        </view>
        <view class="tag tag-{{item.statusClass}}">
          <text>{{item.statusLabel}}</text>
        </view>
      </view>
      <view class="tcard-props">
        <text class="tcard-credits">消耗: {{item.creditsCost || item.credits_cost || 0}} 积分</text>
        <text class="tcard-time">{{item.formattedTime}}</text>
      </view>
      <view class="tcard-foot" wx:if="{{item.cancellable}}">
        <button class="tcard-btn" data-id="{{item.id}}" catchtap="onCancelTask">取消任务</button>
      </view>
    </view>
  </list-page>
</view>
