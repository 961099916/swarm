.admin-container { padding: 32rpx 24rpx 48rpx; background: var(--bg-root); color: var(--text); min-height: 100vh; box-sizing: border-box; transition: background 0.3s ease; }
.admin-container.theme-light { background: var(--bg-root); }
.board-title { font-size: 40rpx; font-weight: 700; display: block; margin-bottom: 24rpx; }
.filter-bar { width: 100%; white-space: nowrap; margin-bottom: 24rpx; }
.filter-items { display: inline-flex; gap: 12rpx; }
.list-section { display: flex; flex-direction: column; gap: 12rpx; }
.tcard { padding: 20rpx; position: relative; overflow: hidden; }
.tcard-bar { position: absolute; left: 0; top: 0; bottom: 0; width: 6rpx; border-radius: 0 4rpx 4rpx 0; }
.tcard-bar.status-running { background: var(--brand-light); box-shadow: 0 0 8rpx rgba(30,111,255,0.3); }
.tcard-bar.status-success { background: var(--success); box-shadow: 0 0 8rpx rgba(0,179,101,0.3); }
.tcard-bar.status-failed { background: var(--danger); box-shadow: 0 0 8rpx rgba(244,63,94,0.3); }
.tcard-bar.status-sleeping { background: var(--warning); box-shadow: 0 0 8rpx rgba(245,158,11,0.3); }
.tcard-head { display: flex; justify-content: space-between; align-items: flex-start; padding-left: 8rpx; }
.tcard-left { min-width: 0; }
.tcard-name { font-size: 26rpx; font-weight: 700; display: block; }
.tcard-id { font-family: "SF Mono",monospace; font-size: 18rpx; color: var(--text-muted); display: block; margin-top: 6rpx; }
.tcard-props { display: flex; flex-direction: column; gap: 12rpx; padding-left: 8rpx; }
.tcard-foot { padding-left: 8rpx; }
.tcard-btn { width: 100%; border-radius: 8rpx; font-size: 22rpx; color: var(--danger); border: 1rpx solid var(--danger-border); background: transparent; padding: 14rpx 0; margin: 0; line-height: 1.5; }
.tcard-btn::after { border: none; }
