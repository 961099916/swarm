page {
  background: #2D2A24;
}

/* packageAdmin/tools/edit.wxss — 暖绒奶油风 */

.edit-container {
  min-height: 100vh;
  background-color: var(--bg-root);
  color: var(--text-primary);
  padding: 28rpx 28rpx 200rpx;
  box-sizing: border-box;
  animation: fade-up 0.35s ease-out both;
}

.page-title {
  font-size: 36rpx;
  font-weight: 700;
  margin-bottom: 28rpx;
  display: block;
  background: var(--brand-gradient);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

/* 分组卡片 */
.section-card {
  background: var(--glass-bg);
  backdrop-filter: var(--glass-blur);
  -webkit-backdrop-filter: var(--glass-blur);
  border-radius: var(--radius-lg);
  padding: 28rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid var(--glass-border);
  box-shadow: var(--shadow-sm);
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 24rpx;
  display: block;
  padding-left: 16rpx;
  border-left: 4rpx solid var(--brand);
}

.text-accent {
  background: var(--brand-gradient);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.section-hd-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

/* 表单元素 — 玻璃风格 */
.form-item {
  display: flex;
  flex-direction: column;
  margin-bottom: 24rpx;
}

.form-label {
  font-size: 22rpx;
  color: var(--text-muted);
  margin-bottom: 10rpx;
  font-weight: 500;
}

.form-input {
  background: var(--glass-bg);
  backdrop-filter: var(--glass-blur);
  -webkit-backdrop-filter: var(--glass-blur);
  border-radius: var(--radius-md);
  padding: 20rpx 24rpx;
  font-size: 26rpx;
  color: var(--text-primary);
  border: 1rpx solid var(--glass-border);
  transition: border-color 0.2s;
}
.form-input:focus {
  border-color: var(--brand);
  box-shadow: 0 0 0 3rpx var(--brand-subtle);
}

.form-input.disabled {
  opacity: 0.5;
  color: var(--text-muted);
  border-color: var(--border-subtle);
}

.form-textarea {
  background: var(--glass-bg);
  backdrop-filter: var(--glass-blur);
  -webkit-backdrop-filter: var(--glass-blur);
  border-radius: var(--radius-md);
  padding: 20rpx 24rpx;
  font-size: 26rpx;
  color: var(--text-primary);
  height: 140rpx;
  width: 100%;
  box-sizing: border-box;
  border: 1rpx solid var(--glass-border);
}

.script-area {
  height: 360rpx;
}

.help-text {
  font-size: 20rpx;
  color: var(--text-muted);
  margin-top: 8rpx;
}

/* 引擎模式 Tab — 玻璃切换 */
.tabs-row {
  display: flex;
  gap: 12rpx;
  margin-bottom: 24rpx;
  padding: 6rpx;
  background: var(--glass-bg);
  backdrop-filter: var(--glass-blur);
  -webkit-backdrop-filter: var(--glass-blur);
  border-radius: var(--radius-lg);
  border: 1rpx solid var(--glass-border);
}
.tab-btn {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  font-size: 24rpx;
  border-radius: var(--radius-md);
  color: var(--text-secondary);
  transition: all 0.2s ease;
  font-weight: 500;
}
.tab-btn.active {
  background: var(--brand-gradient);
  color: #FFFFFF;
  font-weight: 600;
  box-shadow: var(--shadow-glow);
}

/* Method 标签 */
.method-row {
  display: flex;
  gap: 12rpx;
  padding: 6rpx;
  background: var(--glass-bg);
  backdrop-filter: var(--glass-blur);
  -webkit-backdrop-filter: var(--glass-blur);
  border-radius: var(--radius-lg);
  border: 1rpx solid var(--glass-border);
  width: fit-content;
}
.method-tag {
  padding: 14rpx 40rpx;
  font-size: 24rpx;
  border-radius: var(--radius-md);
  color: var(--text-secondary);
  font-weight: 500;
  transition: all 0.2s ease;
}
.method-tag.active {
  background: var(--brand-gradient);
  color: #FFFFFF;
  font-weight: 600;
  box-shadow: var(--shadow-glow);
}

/* Type 选择器 */
.type-selector {
  display: flex;
  gap: 12rpx;
}
.type-opt {
  flex: 1;
  text-align: center;
  padding: 16rpx;
  font-size: 24rpx;
  border-radius: var(--radius-md);
  background: var(--glass-bg);
  backdrop-filter: var(--glass-blur);
  -webkit-backdrop-filter: var(--glass-blur);
  color: var(--text-secondary);
  border: 1rpx solid var(--glass-border);
  transition: all 0.2s;
}
.type-opt.active {
  background: var(--brand-gradient);
  color: #FFFFFF;
  border-color: transparent;
  box-shadow: var(--shadow-glow);
}

/* 参数列表 */
.add-param-lbl {
  font-size: 24rpx;
  color: var(--brand);
  font-weight: 600;
  padding: 8rpx 20rpx;
  border-radius: var(--radius-full);
  background: var(--brand-subtle);
  border: 1rpx solid var(--brand-border);
}
.add-param-lbl:active {
  transform: scale(0.96);
}

.param-empty {
  text-align: center;
  padding: 40rpx 0;
  font-size: 24rpx;
  color: var(--text-muted);
}

.param-item-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: var(--glass-bg);
  backdrop-filter: var(--glass-blur);
  -webkit-backdrop-filter: var(--glass-blur);
  border-radius: var(--radius-md);
  padding: 20rpx 24rpx;
  margin-bottom: 14rpx;
  border: 1rpx solid var(--glass-border);
}

.param-left {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.param-tag-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
}
.param-key {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.p-tag {
  font-size: 18rpx;
  padding: 2rpx 10rpx;
  border-radius: var(--radius-full);
}
.p-tag-type {
  background: var(--glass-bg);
  backdrop-filter: var(--glass-blur);
  -webkit-backdrop-filter: var(--glass-blur);
  color: var(--text-muted);
  border: 1rpx solid var(--glass-border);
}
.p-tag-req {
  background: var(--danger-subtle);
  color: var(--danger);
  border: 1rpx solid var(--danger-border);
}

.param-desc {
  font-size: 22rpx;
  color: var(--text-muted);
}

.param-del {
  padding: 12rpx;
}

/* 命令行终端盒 */
.terminal-shell {
  background: rgba(0, 0, 0, 0.3);
  backdrop-filter: var(--glass-blur);
  -webkit-backdrop-filter: var(--glass-blur);
  border-radius: var(--radius-md);
  border: 1rpx solid var(--glass-border);
  margin-top: 16rpx;
  overflow: hidden;
}
.term-header {
  background: rgba(255, 255, 255, 0.04);
  padding: 12rpx 20rpx;
  display: flex;
  align-items: center;
  border-bottom: 1rpx solid var(--border-subtle);
}
.dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  margin-right: 10rpx;
}
.red-dot { background: #FF5F56; }
.yellow-dot { background: #FFBD2E; }
.green-dot { background: #27C93F; }
.term-title {
  font-size: 20rpx;
  color: var(--text-muted);
  margin-left: 12rpx;
  font-family: monospace;
}
.term-body {
  min-height: 120rpx;
  padding: 16rpx 20rpx;
  box-sizing: border-box;
}
.term-line {
  font-size: 22rpx;
  font-family: monospace;
  margin-bottom: 8rpx;
}
.term-dir { color: #57F287; font-weight: bold; }
.term-cursor { color: #FFFFFF; }
.term-muted { color: var(--text-placeholder); }
.success-line { color: var(--success); }
.error-line { color: var(--danger); }
.term-output {
  font-size: 22rpx;
  color: var(--text-secondary);
  padding-left: 16rpx;
  white-space: pre-wrap;
  word-break: break-all;
  margin-bottom: 12rpx;
}
.text-red { color: var(--danger); }
.code-font { font-family: "Courier New", Courier, monospace; }

/* 底部操作栏 */
.actions-row {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: var(--glass-bg);
  backdrop-filter: var(--glass-blur);
  -webkit-backdrop-filter: var(--glass-blur);
  padding: 20rpx 28rpx calc(20rpx + env(safe-area-inset-bottom));
  display: flex;
  gap: 16rpx;
  border-top: 1rpx solid var(--glass-border);
  box-sizing: border-box;
  z-index: 100;
  box-shadow: var(--shadow-md);
}

/* 添加参数弹窗 */
.popup-sheet {
  background: var(--bg-surface-solid);
  border-radius: var(--radius-xl) var(--radius-xl) 0 0;
  padding: 32rpx 32rpx 60rpx;
  color: var(--text-primary);
  border-top: 1rpx solid var(--glass-border);
}
.sheet-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 28rpx;
}
.sheet-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}
.sheet-body {
  margin-bottom: 36rpx;
}
.sheet-actions {
  display: flex;
  gap: 16rpx;
}
