<!-- packageAdmin/tools/index.wxml -->
<view class="tools-container {{theme}}">
  <view class="head-row">
    <text class="page-title">动态工具库</text>
    <t-button size="small" theme="primary" icon="add" bindtap="onCreateTool">新增工具</t-button>
  </view>

  <!-- 搜索栏 -->
  <view class="search-wrap card">
    <view class="search-input-box">
      <view class="t-icon t-icon-search" style="font-size: 32rpx; color: var(--text-muted); margin-right: 12rpx;"></view>
      <input class="search-input" value="{{searchQuery}}" placeholder="输入工具标识或描述搜索" bindinput="onSearchInput" />
    </view>
  </view>

  <!-- 工具列表 -->
  <scroll-view scroll-y class="list-scroll" bindrefresherrefresh="onRefresh" refresher-enabled refresher-triggered="{{refreshing}}">
    <view class="empty-state card" wx:if="{{filteredTools.length === 0}}">
      <view class="t-icon t-icon-info-circle" style="font-size: 80rpx; color: var(--text-muted); margin-bottom: 16rpx;"></view>
      <text class="empty-text">未检索到动态工具记录</text>
    </view>

    <view class="tool-card card" wx:for="{{filteredTools}}" wx:key="name">
      <view class="tool-head">
        <view class="tool-name-wrap">
          <text class="tool-name num-font">{{item.name}}</text>
          <text class="tool-tag tag-script" wx:if="{{item.script}}">FaaS 脚本</text>
          <text class="tool-tag tag-api" wx:else>API 代理</text>
        </view>
        <t-switch checked="{{item.enabled}}" data-name="{{item.name}}" data-index="{{index}}" bindchange="onStatusChange" color="#1E6FFF" style="transform:scale(0.85);" />
      </view>

      <text class="tool-desc">{{item.description}}</text>
      
      <view class="tool-meta">
        <view class="meta-item">
          <text class="meta-label">分组：</text>
          <text class="meta-val">{{item.category}}</text>
        </view>
        <view class="meta-item">
          <text class="meta-label">路由终点：</text>
          <text class="meta-val code-font">{{item.script ? 'ctx.run()' : item.endpoint}}</text>
        </view>
      </view>

      <view class="tool-footer">
        <text class="time-lbl">更新于: {{item.formattedTime}}</text>
        <view class="action-btn-row">
          <t-button size="extra-small" theme="light" bindtap="onEditTool" data-name="{{item.name}}">配置</t-button>
          <t-button size="extra-small" theme="danger" variant="text" bindtap="onDeleteTool" data-name="{{item.name}}">删除</t-button>
        </view>
      </view>
    </view>
  </scroll-view>
</view>
