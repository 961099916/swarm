.tools-container {
  min-height: 100vh;
  background-color: var(--bg-root);
  color: var(--text-primary);
  padding: 40rpx 32rpx;
  box-sizing: border-box;
}

.head-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 40rpx;
}

.page-title {
  font-size: 44rpx;
  font-weight: 700;
  background: linear-gradient(90deg, var(--brand), var(--brand-light));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

/* 搜索栏 */
.search-wrap {
  background: var(--bg-surface);
  border-radius: 20rpx;
  padding: 24rpx 32rpx;
  margin-bottom: 40rpx;
  border: 1rpx solid var(--border-default);
}

.search-input-box {
  display: flex;
  align-items: center;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-primary);
}

/* 列表滚动区 */
.list-scroll {
  height: calc(100vh - 280rpx);
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
  text-align: center;
  background: var(--bg-surface);
  border-radius: 24rpx;
  border: 1rpx solid var(--border-default);
}

.empty-text {
  font-size: 28rpx;
  color: var(--text-muted);
}

/* 工具卡片 */
.tool-card {
  background: var(--bg-surface);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid var(--border-default);
  box-shadow: var(--shadow-sm);
  display: flex;
  flex-direction: column;
}

.tool-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.tool-name-wrap {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.tool-name {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.tool-tag {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-weight: 500;
}

.tag-script {
  background: var(--brand-subtle);
  color: var(--brand);
}

.tag-api {
  background: var(--success-subtle);
  color: var(--success);
}

.tool-desc {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.5;
  margin-bottom: 24rpx;
}

.tool-meta {
  background: var(--bg-surface-hover);
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  border: 1rpx solid var(--border-subtle);
}

.meta-item {
  display: flex;
  align-items: baseline;
}

.meta-label {
  font-size: 22rpx;
  color: var(--text-muted);
  width: 140rpx;
  flex-shrink: 0;
}

.meta-val {
  font-size: 22rpx;
  color: var(--text-secondary);
  word-break: break-all;
}

.code-font {
  font-family: "Courier New", Courier, monospace;
}

.tool-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-top: 1rpx solid var(--border-subtle);
  padding-top: 20rpx;
  margin-top: 8rpx;
}

.time-lbl {
  font-size: 20rpx;
  color: var(--text-muted);
}

.action-btn-row {
  display: flex;
  gap: 16rpx;
}
