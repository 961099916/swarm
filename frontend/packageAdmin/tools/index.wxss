/* packageAdmin/tools/index.wxss — 暖绒奶油风 v2 */

.tools-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: var(--bg-root);
  color: var(--text-primary);
  padding: 28rpx;
  box-sizing: border-box;
  animation: fade-up 0.35s ease-out both;
}

/* 头部 */
.head-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 24rpx;
}
.page-title {
  font-size: 36rpx;
  font-weight: 700;
  background: var(--brand-gradient);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  display: block;
}
.page-subtitle {
  font-size: 22rpx;
  color: var(--text-muted);
  display: block;
  margin-top: 6rpx;
}

.create-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 14rpx 28rpx;
  background: var(--brand-gradient);
  color: #FFFFFF;
  font-size: 24rpx;
  font-weight: 600;
  border: none;
  border-radius: var(--radius-full);
  margin: 0;
  line-height: 1;
  box-shadow: var(--shadow-glow);
  transition: all 0.2s ease;
}
.create-btn::after { border: none; }
.create-btn:active { transform: scale(0.95); opacity: 0.9; }

/* 搜索栏 — 毛玻璃一体式 */
.search-wrap {
  display: flex;
  align-items: center;
  padding: 16rpx 28rpx;
  margin-bottom: 24rpx;
  border-radius: var(--radius-lg);
  background: var(--glass-bg);
  backdrop-filter: var(--glass-blur);
  -webkit-backdrop-filter: var(--glass-blur);
  border: 1rpx solid var(--glass-border);
}
.search-input {
  flex: 1;
  font-size: 26rpx;
  color: var(--text-primary);
  background: transparent;
  border: none;
  outline: none;
}

/* 工具卡片 */
.tool-card {
  padding: 24rpx;
  margin-bottom: 20rpx;
  border-radius: var(--radius-md);
  background: var(--glass-bg);
  backdrop-filter: var(--glass-blur);
  -webkit-backdrop-filter: var(--glass-blur);
  border: 1rpx solid var(--glass-border);
  box-shadow: var(--shadow-sm);
  display: flex;
  flex-direction: column;
}

/* 顶栏 */
.tool-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}
.tool-head-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex: 1;
  min-width: 0;
}

/* 玻璃质感图标 — 毛玻璃圆 + 首字 + 装饰光晕环 + 光泽 */
.tool-head-info {
  flex: 1;
  min-width: 0;
}

.tool-name-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 6rpx;
}
.tool-name {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 260rpx;
}

.tool-tag {
  font-size: 18rpx;
  padding: 4rpx 14rpx;
  border-radius: var(--radius-full);
  font-weight: 500;
  white-space: nowrap;
  flex-shrink: 0;
}
.tag-script {
  background: rgba(108, 92, 231, 0.12);
  color: #A29BFE;
  border: 1rpx solid rgba(108, 92, 231, 0.25);
}
.tag-api {
  background: rgba(0, 184, 148, 0.12);
  color: #55EFC4;
  border: 1rpx solid rgba(0, 184, 148, 0.25);
}

/* 描述 */
.tool-desc {
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.5;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 元数据行 — 紧凑玻璃徽章 */
.tool-meta-row {
  display: flex;
  gap: 10rpx;
  flex-wrap: wrap;
  margin-bottom: 16rpx;
}
.meta-chip {
  display: inline-flex;
  align-items: center;
  font-size: 20rpx;
  color: var(--text-muted);
  padding: 4rpx 16rpx;
  border-radius: var(--radius-full);
  background: var(--glass-bg);
  backdrop-filter: var(--glass-blur);
  -webkit-backdrop-filter: var(--glass-blur);
  border: 1rpx solid var(--glass-border);
  max-width: 40%;
}
.endpoint-text {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 200rpx;
  font-family: "SF Mono", monospace;
  font-size: 18rpx;
}

/* 底栏 */
.tool-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-top: 1rpx solid var(--border-subtle);
  padding-top: 16rpx;
}
.tool-status {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 20rpx;
  color: var(--text-muted);
}
.tool-status.status-on {
  color: var(--success);
}

/* 操作按钮 — 圆角玻璃 */
.action-btn-row {
  display: flex;
  gap: 12rpx;
}
.tool-btn {
  padding: 8rpx 24rpx;
  font-size: 22rpx;
  font-weight: 600;
  border-radius: var(--radius-full);
  border: none;
  line-height: 1.4;
  margin: 0;
  transition: all 0.2s ease;
}
.tool-btn::after { border: none; }
.tool-btn:active { transform: scale(0.94); }
.edit-btn {
  background: var(--brand-gradient);
  color: #FFFFFF;
  box-shadow: var(--shadow-glow);
}
.del-btn {
  background: var(--glass-bg);
  backdrop-filter: var(--glass-blur);
  -webkit-backdrop-filter: var(--glass-blur);
  color: var(--danger);
  border: 1rpx solid rgba(231, 76, 60, 0.25);
}
