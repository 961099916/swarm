<page-meta page-style="overflow: {{activeModal !== 'NONE' ? 'hidden' : 'visible'}}"></page-meta>
<view class="admin-container {{theme}}">
  <text class="board-title">用户管理</text>

  <t-input class="admin-search" value="{{searchKeyword}}" placeholder="搜索微信昵称或 OpenID" bindinput="onSearchQueryChange" />

  <scroll-view class="filter-bar" scroll-x enable-flex enhanced show-scrollbar="{{false}}">
    <view class="filter-items">
      <view wx:for="{{roleFilterOptions}}" wx:key="value"
        class="pill-filter {{currentRoleFilter === item.value ? 'active' : ''}}"
        data-filter="{{item.value}}" bindtap="onSelectFilter">{{item.label}}</view>
      <view class="pill-filter {{statusFilter === 'BANNED' ? 'active' : ''}}" data-filter="banned" bindtap="onToggleBanned">已封禁</view>
    </view>
  </scroll-view>

  <view class="list-section">
    <view wx:if="{{loading}}" style="padding-top:16rpx;">
      <view class="skeleton skeleton-card" wx:for="{{[1,2,3]}}" wx:key="*this"></view>
    </view>

    <view wx:elif="{{users.length === 0}}" class="empty-state">
      <view class="empty-icon">
        <view class="t-icon t-icon-usergroup" style="font-size: 96rpx; color: var(--text-secondary);"></view>
      </view>
      <text class="empty-label">无匹配用户</text>
    </view>

    <view wx:else>
      <view wx:for="{{users}}" wx:key="id" class="card user-card {{item.is_banned === 1 ? 'banned' : ''}}">
        <view class="uc-top">
          <view class="uc-avatar">{{item.nickname ? item.nickname[0] : '?'}}</view>
          <view class="uc-meta">
            <view class="uc-name-row">
              <text class="uc-name">{{item.nickname || '未设置'}}</text>
              <text class="uc-role role-{{item.roleClass}}">{{item.roleLabel}}</text>
            </view>
            <text class="uc-id">{{item.wx_open_id}}</text>
            <text class="uc-date">{{item.created_at}}</text>
          </view>
          <view class="uc-right" style="display: flex; flex-direction: column; align-items: flex-end;">
            <view class="uc-credits num-font" style="display: flex; align-items: center; justify-content: flex-end;">
              <text style="margin-right: 4rpx;">{{item.credits}}</text>
              <view class="t-icon t-icon-lighting-circle" style="font-size: 28rpx; color: var(--warning);"></view>
            </view>
            <text wx:if="{{item.is_banned === 1}}" class="uc-banned">已封禁</text>
          </view>
        </view>

        <view class="separator" style="margin:20rpx 0;"></view>

        <view class="uc-actions">
          <button class="uc-btn" data-id="{{item.id}}" bindtap="onOpenRoleModal">角色</button>
          <button class="uc-btn" data-id="{{item.id}}" bindtap="onOpenCreditsModal">积分</button>
          <button class="uc-btn" data-id="{{item.id}}" bindtap="onKickUser">踢下线</button>
          <button class="uc-btn uc-ban" data-id="{{item.id}}" data-banned="{{item.is_banned}}" bindtap="onToggleBanUser">{{item.is_banned === 1 ? '解封' : '封禁'}}</button>
        </view>
      </view>
    </view>
  </view>

  <t-popup visible="{{activeModal === 'ROLE'}}" placement="bottom" closeOnOverlayClick="{{true}}" prevent-scroll-through="{{true}}" overlayProps="{{ { preventScrollThrough: true } }}" showOverlay="{{true}}" bindvisible-change="closeModal">
    <view class="modal-sheet">
      <text class="modal-title">更改角色</text>
      <view class="role-list">
        <view class="card card-actionable row-opt {{targetRole === 'FREE_USER' ? 'selected' : ''}}" data-role="FREE_USER" bindtap="selectTargetRole">免费用户</view>
        <view class="card card-actionable row-opt {{targetRole === 'VIP' ? 'selected' : ''}}" data-role="VIP" bindtap="selectTargetRole">VIP 高级</view>
        <view class="card card-actionable row-opt {{targetRole === 'ADMIN' ? 'selected' : ''}}" data-role="ADMIN" bindtap="selectTargetRole">管理员</view>
      </view>
      <view class="modal-btns">
        <button class="btn-primary" style="flex:2;height:80rpx;line-height:80rpx;" bindtap="onSubmitRoleChange" loading="{{roleLoading}}">确认</button>
        <button class="btn-secondary" style="flex:1;height:80rpx;line-height:80rpx;" bindtap="closeModal">取消</button>
      </view>
    </view>
  </t-popup>

  <t-popup visible="{{activeModal === 'CREDITS'}}" placement="bottom" closeOnOverlayClick="{{true}}" prevent-scroll-through="{{true}}" overlayProps="{{ { preventScrollThrough: true } }}" showOverlay="{{true}}" bindvisible-change="closeModal">
    <view class="modal-sheet">
      <text class="modal-title">调整积分</text>
      <view class="modal-form">
        <t-input class="modal-inp" type="number" value="{{creditsDelta}}" placeholder="积分变动值（正加负减）" bindchange="onCreditsDeltaChange" />
        <t-input class="modal-inp" value="{{creditsReason}}" placeholder="调整原因" bindchange="onCreditsReasonChange" />
      </view>
      <view class="modal-btns">
        <button class="btn-primary" style="flex:2;height:80rpx;line-height:80rpx;" bindtap="onSubmitCreditsChange" loading="{{creditsLoading}}">确认</button>
        <button class="btn-secondary" style="flex:1;height:80rpx;line-height:80rpx;" bindtap="closeModal">取消</button>
      </view>
    </view>
  </t-popup>
</view>
