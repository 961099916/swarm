.admin-container { padding: 32rpx 24rpx 48rpx; background: var(--bg-root); color: var(--text); min-height: 100vh; box-sizing: border-box; transition: background 0.3s ease; }
.admin-container.theme-light { background: var(--bg-root); }
.board-title { font-size: 40rpx; font-weight: 700; display: block; margin-bottom: 24rpx; }
.admin-search { --td-input-bg-color: var(--bg-surface); --td-input-border-color: var(--border-default); --td-input-text-color: var(--text); --td-input-placeholder-text-color: var(--text-muted); border-radius: 10rpx; overflow: hidden; margin-bottom: 20rpx; }
.filter-bar { width: 100%; white-space: nowrap; margin-bottom: 24rpx; }
.filter-items { display: inline-flex; gap: 12rpx; }
.list-section { display: flex; flex-direction: column; gap: 12rpx; }
.user-card { padding: 20rpx; }
.user-card.banned { background: var(--danger-subtle); border-color: var(--danger-border); }
.uc-top { display: flex; gap: 12rpx; align-items: flex-start; }
.uc-avatar { width: 96rpx; height: 80rpx; border-radius: 999rpx; display: flex; align-items: center; justify-content: center; background: var(--brand-subtle); border: 1rpx solid var(--border-default); font-size: 36rpx; color: var(--brand); flex-shrink: 0; }
.uc-meta { flex: 1; min-width: 0; }
.uc-name-row { display: flex; align-items: center; gap: 12rpx; }
.uc-name { font-size: 28rpx; font-weight: 700; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; max-width: 200rpx; }
.uc-role { font-size: 18rpx; padding: 3rpx 12rpx; border-radius: 999rpx; background: var(--bg-surface); color: var(--text-secondary); border: 1rpx solid var(--border-default); }
.uc-role.role-vip { background: var(--brand-subtle); color: var(--brand); border-color: var(--brand-border); }
.uc-role.role-admin { background: var(--danger-subtle); color: var(--danger); border-color: var(--danger-border); }
.uc-id { font-family: "SF Mono",monospace; font-size: 18rpx; color: var(--text-muted); word-break: break-all; display: block; margin-top: 8rpx; }
.uc-date { font-size: 18rpx; color: var(--text-muted); display: block; margin-top: 4rpx; }
.uc-right { display: flex; flex-direction: column; align-items: flex-end; gap: 6rpx; flex-shrink: 0; }
.uc-credits { font-size: 28rpx; font-weight: 800; color: var(--warning); }
.uc-banned { font-size: 18rpx; font-weight: 700; color: var(--danger); }
.uc-actions { display: flex; gap: 10rpx; }
.uc-btn { flex: 1; border-radius: 8rpx; font-size: 20rpx; background: var(--bg-surface); border: 1rpx solid var(--border-default); color: var(--text); padding: 12rpx 0; margin: 0; line-height: 1.5; }
.uc-btn.uc-ban { color: var(--danger); border-color: var(--danger-border); }
.modal-sheet { padding: 24rpx; padding-bottom: calc(40rpx + env(safe-area-inset-bottom)); display: flex; flex-direction: column; gap: 16rpx; background: var(--bg-surface); border-radius: 24rpx 24rpx 0 0; border-top: 1rpx solid var(--border-default); }
.modal-title { font-size: 32rpx; font-weight: 700; text-align: center; color: var(--text); }
.role-list { display: flex; flex-direction: column; gap: 14rpx; }
.row-opt { padding: 20rpx; text-align: center; font-size: 26rpx; font-weight: 600; color: var(--text); }
.row-opt.selected { border-color: var(--brand-border); background: var(--brand-subtle); }
.modal-btns { display: flex; gap: 12rpx; }
.modal-form { display: flex; flex-direction: column; gap: 12rpx; }
.modal-inp { --td-input-bg-color: var(--bg-surface); --td-input-border-color: var(--border-default); --td-input-text-color: var(--text); --td-input-placeholder-text-color: var(--text-muted); border-radius: 10rpx; overflow: hidden; }
