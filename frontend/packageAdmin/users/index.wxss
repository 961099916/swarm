/* packageAdmin/users/index.wxss — 暖绒奶油风 */

.admin-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  padding: 24rpx 0 0;
  background: var(--bg-root);
  color: var(--text);
  box-sizing: border-box;
  animation: fade-up 0.35s ease-out both;
}
.admin-container.theme-light { background: var(--bg-root); }

.board-title { font-size: 32rpx; font-weight: 700; color: var(--text-primary); display: block; padding: 0 24rpx; margin-bottom: 16rpx; flex-shrink: 0; }

/* 搜索 — 毛玻璃 */
.admin-search {
  --td-input-bg-color: var(--glass-bg);
  --td-input-border-color: var(--glass-border);
  --td-input-text-color: var(--text-primary);
  --td-input-placeholder-text-color: var(--text-placeholder);
  border-radius: var(--radius-lg);
  overflow: hidden;
  margin-bottom: 20rpx;
  backdrop-filter: var(--glass-blur);
  -webkit-backdrop-filter: var(--glass-blur);
}

.filter-bar { width: 100%; white-space: nowrap; margin-bottom: 24rpx; }
.filter-items { display: inline-flex; gap: 12rpx; }

.list-section { display: flex; flex-direction: column; gap: 16rpx; }

/* 用户卡片 — 毛玻璃 */
.user-card { padding: 24rpx; border-radius: var(--radius-md); background: var(--glass-bg); backdrop-filter: var(--glass-blur); -webkit-backdrop-filter: var(--glass-blur); border: 1rpx solid var(--glass-border); }
.user-card.banned { border-color: var(--danger-border); background: var(--danger-subtle); }

.uc-top { display: flex; gap: 16rpx; align-items: flex-start; }

/* 首字头像 — 珊瑚橙渐变圆 */
.uc-avatar { width: 80rpx; height: 80rpx; border-radius: 50%; display: flex; align-items: center; justify-content: center; background: var(--brand-gradient); color: #FFFFFF; font-size: 32rpx; font-weight: 700; flex-shrink: 0; box-shadow: var(--shadow-glow); }

.uc-meta { flex: 1; min-width: 0; }
.uc-name-row { display: flex; align-items: center; gap: 10rpx; flex-wrap: wrap; }
.uc-name { font-size: 26rpx; font-weight: 700; color: var(--text-primary); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; max-width: 200rpx; }

.uc-role { font-size: 18rpx; padding: 4rpx 14rpx; border-radius: var(--radius-full); background: var(--glass-bg); backdrop-filter: var(--glass-blur); -webkit-backdrop-filter: var(--glass-blur); color: var(--text-secondary); border: 1rpx solid var(--glass-border); }
.uc-role.role-vip { background: var(--brand-subtle); color: var(--brand); border-color: var(--brand-border); }
.uc-role.role-admin { background: var(--danger-subtle); color: var(--danger); border-color: var(--danger-border); }

.uc-id { font-family: "SF Mono",monospace; font-size: 18rpx; color: var(--text-muted); word-break: break-all; display: block; margin-top: 6rpx; }
.uc-date { font-size: 18rpx; color: var(--text-muted); display: block; margin-top: 4rpx; }

.uc-right { display: flex; flex-direction: column; align-items: flex-end; gap: 6rpx; flex-shrink: 0; }
.uc-credits { font-size: 28rpx; font-weight: 800; color: var(--warning); display: flex; align-items: center; }
.uc-banned { font-size: 18rpx; font-weight: 700; color: var(--danger); padding: 2rpx 12rpx; border-radius: var(--radius-full); background: var(--danger-subtle); }

/* 操作按钮 — 圆角玻璃 */
.uc-actions { display: flex; gap: 10rpx; }
.uc-btn {
  flex: 1;
  border-radius: var(--radius-full);
  font-size: 20rpx;
  background: var(--glass-bg);
  backdrop-filter: var(--glass-blur);
  -webkit-backdrop-filter: var(--glass-blur);
  border: 1rpx solid var(--glass-border);
  color: var(--text-primary);
  padding: 14rpx 0;
  margin: 0;
  line-height: 1.5;
  transition: all 0.2s;
}
.uc-btn:active { transform: scale(0.95); }
.uc-btn.uc-ban { color: var(--danger); border-color: var(--danger-border); }

/* 弹窗 */
.modal-sheet { padding: 32rpx; padding-bottom: calc(40rpx + env(safe-area-inset-bottom)); display: flex; flex-direction: column; gap: 20rpx; background: var(--bg-surface-solid); border-radius: var(--radius-xl) var(--radius-xl) 0 0; border-top: 1rpx solid var(--glass-border); }
.modal-title { font-size: 32rpx; font-weight: 700; text-align: center; color: var(--text-primary); }
.role-list { display: flex; flex-direction: column; gap: 14rpx; }
.row-opt { padding: 20rpx; text-align: center; font-size: 26rpx; font-weight: 600; color: var(--text-primary); border-radius: var(--radius-md); background: var(--glass-bg); backdrop-filter: var(--glass-blur); -webkit-backdrop-filter: var(--glass-blur); border: 1rpx solid var(--glass-border); }
.row-opt.selected { border-color: var(--brand-border); background: var(--brand-subtle); box-shadow: var(--shadow-glow); }
.modal-btns { display: flex; gap: 14rpx; }
.modal-form { display: flex; flex-direction: column; gap: 16rpx; }
.modal-inp {
  --td-input-bg-color: var(--glass-bg);
  --td-input-border-color: var(--glass-border);
  --td-input-text-color: var(--text-primary);
  --td-input-placeholder-text-color: var(--text-placeholder);
  border-radius: var(--radius-md);
  overflow: hidden;
  backdrop-filter: var(--glass-blur);
  -webkit-backdrop-filter: var(--glass-blur);
}

/* 滚动列表容器 */
.admin-list-scroll {
  flex: 1;
  height: 0;
  padding: 0 24rpx 24rpx;
}

/* 加载更多 */
.adm-load-more { display: flex; align-items: center; justify-content: center; gap: 12rpx; padding: 32rpx 0; }
.adm-load-more-text { font-size: 22rpx; color: var(--text-muted); }
.adm-load-more-end { font-size: 20rpx; color: var(--text-placeholder); letter-spacing: 2rpx; }
