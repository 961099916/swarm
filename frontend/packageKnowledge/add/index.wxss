/* packageKnowledge/add/index.wxss — 暖绒奶油风 */
.page { min-height: 100vh; background: var(--bg-root); padding-bottom: 40rpx; color: var(--text-primary); }
.page-header { display: flex; align-items: center; gap: 12rpx; padding: 20rpx 24rpx; background: var(--bg-surface-solid); border-bottom: 1rpx solid var(--glass-border); }
.page-title { font-size: 32rpx; font-weight: 600; color: var(--text-primary); }
.page-subtitle { font-size: 24rpx; color: var(--text-muted); flex: 1; text-align: right; }
.form-section { padding: 24rpx; display: flex; flex-direction: column; gap: 16rpx; }
.field-input { height: 72rpx; background: var(--bg-surface-solid); border-radius: 12rpx; padding: 0 20rpx; font-size: 28rpx; color: var(--text-primary); border: 1rpx solid var(--glass-border); }
.url-input { height: 72rpx; background: var(--bg-surface-solid); border-radius: 12rpx; padding: 0 20rpx; font-size: 26rpx; color: var(--text-primary); border: 1rpx solid var(--glass-border); }
.char-count { text-align: right; font-size: 22rpx; color: var(--text-muted); margin-top: 8rpx; }
.tip { font-size: 22rpx; color: var(--text-muted); line-height: 1.5; padding: 12rpx; background: var(--bg-surface); border-radius: 8rpx; }
.submit-area { padding: 0 24rpx; margin-top: 8rpx; }
.result-card { display: flex; align-items: center; gap: 12rpx; margin: 20rpx 24rpx; padding: 20rpx; border-radius: 12rpx; }
.result-success { background: var(--success-subtle); }
.result-fail { background: var(--danger-subtle); }
.result-text { flex: 1; font-size: 26rpx; color: var(--text-primary); }
.result-docid { display: block; font-size: 20rpx; color: var(--text-muted); margin-top: 4rpx; }
.back-link { display: flex; align-items: center; justify-content: center; gap: 8rpx; font-size: 26rpx; color: var(--brand); padding: 16rpx; }
.back-link .t-icon { color: var(--brand) !important; }
