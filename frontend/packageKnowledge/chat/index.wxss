/* packageKnowledge/chat/index.wxss — 暖绒奶油风 */
.page { height: 100vh; display: flex; flex-direction: column; background: var(--bg-root); }
.header { padding: 16rpx 24rpx; background: var(--bg-surface-solid); border-bottom: 1rpx solid var(--glass-border); }
.header-left { display: flex; align-items: center; gap: 12rpx; }
.header-title { font-size: 32rpx; font-weight: 600; color: var(--text-primary); }

.docs-panel { background: var(--bg-surface-solid); border-bottom: 1rpx solid var(--glass-border); padding: 16rpx 24rpx; max-height: 300rpx; overflow-y: auto; }
.docs-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12rpx; }
.docs-title { font-size: 26rpx; font-weight: 500; color: var(--text-primary); }
.docs-count { font-size: 22rpx; color: var(--text-muted); }
.docs-loading, .docs-empty { text-align: center; color: var(--text-muted); font-size: 24rpx; padding: 20rpx 0; }
.docs-list { display: flex; flex-direction: column; gap: 12rpx; }
.doc-item { display: flex; align-items: center; gap: 12rpx; }
.doc-item-info { display: flex; align-items: center; gap: 8rpx; flex: 1; }
.doc-item-title { font-size: 24rpx; color: var(--text-secondary); flex: 1; }
.doc-item-status { font-size: 20rpx; padding: 2rpx 10rpx; border-radius: 8rpx; }
.doc-item-status.READY { background: var(--success-subtle); color: var(--success); }
.doc-item-status.PROCESSING { background: var(--warning-subtle); color: var(--warning); }
.doc-item-status.FAILED { background: var(--danger-subtle); color: var(--danger); }

.chat-area { flex: 1; padding: 24rpx; overflow-y: auto; padding-bottom: 120rpx; }
.msg { margin-bottom: 20rpx; display: flex; }
.msg-user { justify-content: flex-end; }
.msg-assistant { justify-content: flex-start; }
.msg-bubble { max-width: 75%; padding: 16rpx 20rpx; border-radius: 16rpx; font-size: 28rpx; line-height: 1.6; word-break: break-word; }
.user-bubble { background: var(--brand-gradient); color: #fff; border-bottom-right-radius: 4rpx; }
.assistant-bubble { background: var(--bg-surface-solid); color: var(--text-primary); border-bottom-left-radius: 4rpx; }
.thinking { display: flex; align-items: center; gap: 12rpx; color: var(--text-muted); font-size: 26rpx; }
.sources { margin-top: 12rpx; padding-top: 12rpx; border-top: 1rpx solid var(--glass-border); }
.sources-label { font-size: 22rpx; color: var(--text-muted); display: block; margin-bottom: 6rpx; }
.source-tag { display: inline-block; font-size: 20rpx; color: var(--brand); background: var(--brand-subtle); padding: 4rpx 12rpx; border-radius: 8rpx; margin: 4rpx 6rpx 4rpx 0; }

.input-area { display: flex; align-items: center; gap: 16rpx; padding: 16rpx 24rpx; padding-bottom: calc(16rpx + env(safe-area-inset-bottom)); background: var(--bg-root); border-top: 1rpx solid var(--glass-border); }
.chat-input { flex: 1; height: 72rpx; background: var(--bg-surface-solid); border-radius: 12rpx; padding: 0 20rpx; font-size: 28rpx; color: var(--text-primary); }
