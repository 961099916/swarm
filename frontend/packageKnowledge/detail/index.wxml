<view class="page">
  <!-- 知识库信息头 -->
  <view class="kb-header" wx:if="{{kbInfo}}">
    <view class="kb-header-top">
      <view class="kb-icon {{kbInfo.isPublic ? 'icon-public' : 'icon-private'}}">
        <t-icon name="{{kbInfo.isPublic ? 'bookmark' : 'lock-on'}}" size="28" />
      </view>
      <view class="kb-header-info">
        <text class="kb-title">{{kbInfo.name}}</text>
        <text class="kb-desc">{{kbInfo.description || '暂无描述'}}</text>
      </view>
    </view>
    <view class="kb-config">
      <text>分块: {{kbInfo.chunkSize}}字符</text>
      <text>重叠: {{kbInfo.chunkOverlap}}字符</text>
    </view>
  </view>

  <!-- 操作按钮 -->
  <view class="action-bar">
    <view class="action-btn" bindtap="goToAdd">
      <t-icon name="add" size="28" /><text>添加文档</text>
    </view>
    <view class="action-btn" bindtap="loadDocuments">
      <t-icon name="refresh" size="28" /><text>刷新</text>
    </view>
    <view class="action-btn" bindtap="goToChat">
      <t-icon name="chat" size="28" /><text>智能问答</text>
    </view>
  </view>

  <!-- 文档列表 -->
  <view class="section-title">
    <text>文档列表</text>
    <text class="section-count">{{documents.length}} 篇</text>
  </view>

  <view wx:if="{{loading}}" class="loading-wrap">
    <t-loading size="40rpx" /><text>加载中...</text>
  </view>

  <view wx:elif="{{documents.length > 0}}" class="doc-list">
    <view wx:for="{{documents}}" wx:key="id" class="doc-card">
      <view class="doc-header">
        <t-icon name="file-text" size="28" />
        <view class="doc-title-area">
          <text class="doc-title">{{item.title}}</text>
          <text class="doc-source">{{item.sourceType === 'WEB_SCRAPE' ? '网页抓取' : item.sourceType === 'MANUAL' ? '手动录入' : '上传'}}</text>
        </view>
        <text class="doc-status {{item.status}}">
          {{item.status === 'READY' ? '就绪' : item.status === 'PROCESSING' ? '处理中' : item.status === 'FAILED' ? '失败' : '待处理'}}
        </text>
      </view>
      <view class="doc-meta">
        <text wx:if="{{item.chunkCount}}">{{item.chunkCount}} 个分块</text>
        <text wx:if="{{item.errorMessage}}" class="error-text">{{item.errorMessage}}</text>
        <text>{{item.createdAt ? item.createdAt.slice(0, 10) : ''}}</text>
      </view>
      <view class="doc-actions">
        <view class="action-sm-btn delete-btn" data-doc="{{item}}" bindtap="onDeleteDoc">
          <t-icon name="delete" size="22" /><text>删除</text>
        </view>
      </view>
    </view>
  </view>

  <view wx:else class="empty-wrap">
    <t-icon name="file-text" size="60" />
    <text>暂无文档</text>
    <text class="empty-hint">点击「添加文档」开始录入</text>
  </view>
</view>
