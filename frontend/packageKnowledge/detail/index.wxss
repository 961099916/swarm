/* packageKnowledge/detail/index.wxss — 暖绒奶油风 */
.page { min-height: 100vh; background: var(--bg-root); padding: 24rpx; padding-bottom: 120rpx; color: var(--text-primary); }

.kb-header { background: var(--bg-surface-solid); border-radius: var(--radius-md); padding: 20rpx; margin-bottom: 16rpx; }
.kb-header-top { display: flex; gap: 16rpx; align-items: center; }
.kb-icon { width: 56rpx; height: 56rpx; border-radius: 14rpx; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.icon-public { background: var(--brand-gradient); }
.icon-private { background: linear-gradient(135deg, #7A726A, #999); }
.kb-icon .t-icon { color: #fff !important; }
.kb-header-info { flex: 1; }
.kb-title { font-size: 32rpx; font-weight: 700; color: var(--text-primary); display: block; }
.kb-desc { font-size: 24rpx; color: var(--text-muted); margin-top: 4rpx; display: block; }
.kb-config { display: flex; gap: 16rpx; margin-top: 12rpx; font-size: 20rpx; color: var(--text-placeholder); flex-wrap: wrap; }

.action-bar { display: flex; gap: 12rpx; margin-bottom: 20rpx; }
.action-btn { display: flex; align-items: center; gap: 6rpx; padding: 10rpx 24rpx; border-radius: 20rpx; background: var(--bg-surface); font-size: 24rpx; color: var(--text-secondary); flex: 1; justify-content: center; }
.action-btn .t-icon { color: var(--text-muted) !important; }

.section-title { font-size: 28rpx; font-weight: 600; color: var(--text-primary); margin-bottom: 12rpx; display: flex; justify-content: space-between; align-items: center; }
.section-count { font-size: 22rpx; color: var(--text-muted); font-weight: 400; }

.loading-wrap { display: flex; align-items: center; justify-content: center; gap: 12rpx; padding: 60rpx 0; color: var(--text-muted); font-size: 26rpx; }

.doc-list { display: flex; flex-direction: column; gap: 12rpx; }
.doc-card { background: var(--bg-surface-solid); border-radius: 12rpx; padding: 16rpx; }
.doc-header { display: flex; align-items: center; gap: 10rpx; }
.doc-title-area { flex: 1; min-width: 0; }
.doc-title { font-size: 26rpx; font-weight: 500; color: var(--text-primary); display: block; }
.doc-source { font-size: 20rpx; color: var(--text-placeholder); }
.doc-status { padding: 2rpx 12rpx; border-radius: 10rpx; font-size: 20rpx; flex-shrink: 0; }
.doc-status.READY { background: var(--success-subtle); color: var(--success); }
.doc-status.PROCESSING { background: var(--warning-subtle); color: var(--warning); }
.doc-status.FAILED { background: var(--danger-subtle); color: var(--danger); }
.doc-status.PENDING { background: var(--bg-surface-hover); color: var(--text-placeholder); }

.doc-meta { display: flex; gap: 12rpx; font-size: 22rpx; color: var(--text-muted); margin-top: 6rpx; }
.error-text { color: var(--danger); }
.doc-actions { margin-top: 8rpx; display: flex; justify-content: flex-end; }
.action-sm-btn { display: flex; align-items: center; gap: 4rpx; font-size: 22rpx; padding: 4rpx 12rpx; }
.delete-btn { color: var(--danger); }

.empty-wrap { display: flex; flex-direction: column; align-items: center; gap: 12rpx; padding: 80rpx 0; color: var(--text-muted); font-size: 26rpx; }
.empty-wrap .t-icon { color: var(--text-placeholder); }
.empty-hint { color: var(--text-placeholder); font-size: 24rpx; }
