/* packageKnowledge/list/index.wxss — 暖绒奶油风 */
.page { min-height: 100vh; background: #F5F0E8; }

/* 顶部 */
.page-header { display: flex; justify-content: space-between; align-items: center; padding: 20rpx 24rpx 0; }
.page-title { font-size: 40rpx; font-weight: 700; color: #3D3A35; }
.create-btn { display: flex; align-items: center; gap: 6rpx; color: #FF6B6B; font-size: 26rpx; padding: 8rpx 16rpx; border-radius: 20rpx; background: rgba(255,107,107,0.08); }
.create-btn .t-icon { color: #FF6B6B !important; }

t-search { margin: 12rpx 24rpx; display: block; }

/* 统计 */
.stats-row {
  display: flex; justify-content: space-around; margin: 0 24rpx 20rpx;
  background: #FFFDF5; border-radius: 16rpx; padding: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}
.stat-item { display: flex; flex-direction: column; align-items: center; gap: 4rpx; }
.stat-num { font-size: 32rpx; font-weight: 700; color: #FF6B6B; }
.stat-label { font-size: 22rpx; color: #999; }

.loading-wrap { display: flex; flex-direction: column; align-items: center; padding: 80rpx 0; gap: 16rpx; }
.loading-text { color: #999; font-size: 26rpx; }

/* 列表 */
.kb-list { padding: 0 24rpx; display: flex; flex-direction: column; gap: 16rpx; }
.kb-card { background: #FFFDF5; border-radius: 16rpx; padding: 20rpx; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06); }
.kb-card-top { display: flex; align-items: flex-start; gap: 16rpx; }
.kb-icon {
  width: 56rpx; height: 56rpx; border-radius: 14rpx;
  display: flex; align-items: center; justify-content: center; flex-shrink: 0;
}
.icon-public { background: linear-gradient(135deg, #FF6B6B, #FFA07A); }
.icon-private { background: linear-gradient(135deg, #7A726A, #999); }
.kb-icon .t-icon { color: #fff !important; }
.kb-info { flex: 1; min-width: 0; }
.kb-name { font-size: 30rpx; font-weight: 600; color: #3D3A35; display: block; }
.kb-desc { font-size: 24rpx; color: #999; margin-top: 6rpx; display: block; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.arrow { color: #ddd; margin-top: 6rpx; flex-shrink: 0; }
.kb-meta { display: flex; gap: 20rpx; margin-top: 12rpx; padding-top: 12rpx; border-top: 2rpx solid #F0EBE0; font-size: 22rpx; color: #bbb; }

.kb-actions { display: flex; gap: 12rpx; margin-top: 12rpx; }
.action-btn {
  display: flex; align-items: center; gap: 6rpx;
  padding: 8rpx 20rpx; border-radius: 20rpx;
  background: #F5F0E8; font-size: 22rpx; color: #666;
  flex: 1; justify-content: center;
}
.action-btn .t-icon { color: #999 !important; }
.action-danger { color: #C62828; }
.action-danger .t-icon { color: #C62828 !important; }

.empty-wrap { display: flex; flex-direction: column; align-items: center; padding: 120rpx 0; gap: 16rpx; }
.empty-wrap .t-icon { color: #ddd; }
.empty-text { font-size: 28rpx; color: #999; }
.empty-hint { font-size: 24rpx; color: #ccc; }

.dialog-body { display: flex; flex-direction: column; gap: 16rpx; padding: 16rpx 0; }

/* 底部弹窗 */
.popup-sheet { background: #3D3832; border-radius: 24rpx 24rpx 0 0; padding: 32rpx; }
.popup-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24rpx; }
.popup-title { font-size: 32rpx; font-weight: 600; color: #FFF; }
.popup-close { padding: 8rpx; }
.popup-close .t-icon { color: #999 !important; }
.popup-body { display: flex; flex-direction: column; gap: 20rpx; margin-bottom: 32rpx; }
.popup-footer { display: flex; gap: 16rpx; }
.popup-footer .t-button { flex: 1; }
