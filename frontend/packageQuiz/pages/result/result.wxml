<view class="page-container">
  <!-- 转场 Loading 动效 -->
  <view class="loading-container" wx:if="{{loading}}">
    <view class="spinner"></view>
    <text class="loading-text">正在通过边缘算力分析人格特质...</text>
  </view>

  <!-- 报告主体内容 -->
  <block wx:else>
    <scroll-view scroll-y class="report-scroll">
      <!-- 顶部高光人格卡片 -->
      <view class="glass-card result-hero-card">
        <text class="result-label">您的人格类型为</text>
        <text class="result-code">{{report.code}}</text>
        <text class="result-name">「 {{report.name}} 」</text>
        
        <!-- 社交胶囊词云标签 -->
        <view class="social-tags-row" wx:if="{{tags && tags.length > 0}}">
          <block wx:for="{{tags}}" wx:key="*this">
            <text class="social-tag-capsule">{{item}}</text>
          </block>
        </view>

        <text class="result-desc">{{report.description}}</text>
      </view>

      <!-- 维度对比详情 (极精美双向比例进度条) -->
      <view class="glass-card dimension-card" wx:if="{{report.dimensions && report.dimensions.length > 0}}">
        <text class="section-title">维度分析</text>
        <view class="dimension-list">
          <block wx:for="{{report.dimensions}}" wx:key="left">
            <view class="dimension-item">
              <view class="dim-label-row">
                <text class="dim-name-left {{item.selected === item.left ? 'selected-dim' : ''}}">
                  {{item.left === 'E' ? '外倾 E' : item.left === 'S' ? '感觉 S' : item.left === 'T' ? '思考 T' : '判断 J'}}
                </text>
                <text class="dim-name-right {{item.selected === item.right ? 'selected-dim' : ''}}">
                  {{item.right === 'I' ? '内倾 I' : item.right === 'N' ? '直觉 N' : item.right === 'F' ? '情感 F' : '知觉 P'}}
                </text>
              </view>
              
              <!-- 胶囊双向滑动刻度条 -->
              <view class="slider-track">
                <!-- 游标定位 -->
                <view class="slider-thumb" style="left: {{item.percentage}}%;"></view>
                <!-- 两侧得色指示 -->
                <view class="slider-fill-left" style="width: {{100 - item.percentage}}%;"></view>
                <view class="slider-fill-right" style="width: {{item.percentage}}%; left: {{100 - item.percentage}}%;"></view>
              </view>

              <view class="dim-score-row">
                <text class="score-text">{{item.leftScore}}分</text>
                <text class="score-text">{{item.rightScore}}分</text>
              </view>
            </view>
          </block>
        </view>
      </view>

      <!-- “优势 vs 盲点”高对比卡片 -->
      <view class="glass-card balance-card" wx:if="{{strengths && strengths.length > 0}}">
        <text class="section-title">核心潜能与提升维度</text>
        <view class="balance-container">
          <!-- 优势 (左侧) -->
          <view class="balance-column strengths-col">
            <view class="col-header strengths-hdr">
              ◉
              <text class="hdr-title">核心优势</text>
            </view>
            <view class="balance-list">
              <block wx:for="{{strengths}}" wx:key="*this">
                <view class="balance-item">
                  <view class="bullet-dot"></view>
                  <text class="item-text">{{item}}</text>
                </view>
              </block>
            </view>
          </view>

          <!-- 盲点 (右侧) -->
          <view class="balance-column weaknesses-col">
            <view class="col-header weaknesses-hdr">
              ◉
              <text class="hdr-title">盲点挑战</text>
            </view>
            <view class="balance-list">
              <block wx:for="{{weaknesses}}" wx:key="*this">
                <view class="balance-item">
                  <view class="bullet-dot advice-dot"></view>
                  <text class="item-text">{{item}}</text>
                </view>
              </block>
            </view>
          </view>
        </view>
      </view>

      <!-- 性格描述详细 -->
      <view class="glass-card detail-card">
        <text class="section-title">性格特征</text>
        <view class="bullets-group">
          <block wx:for="{{report.details}}" wx:key="*this">
            <view class="bullet-item">
              <view class="bullet-dot"></view>
              <text class="bullet-text">{{item}}</text>
            </view>
          </block>
        </view>
      </view>

      <!-- 职业与生活建议 -->
      <view class="glass-card advice-card">
        <text class="section-title">成长与职业发展建议</text>
        <view class="bullets-group">
          <block wx:for="{{report.suggestions}}" wx:key="*this">
            <view class="bullet-item">
              <view class="bullet-dot advice-dot"></view>
              <text class="bullet-text advice-text">{{item}}</text>
            </view>
          </block>
        </view>
      </view>

      <!-- 底部控制按钮 (大厂级三按钮科学排版) -->
      <view class="footer-action-group">
        <view class="action-row-main">
          <button class="btn-primary btn-action-half" bindtap="onSaveCard">保存分析卡片</button>
          <button class="btn-primary btn-action-half btn-gradient-blue" open-type="share">分享给好友</button>
        </view>
        <button class="btn-secondary btn-action-full" bindtap="onBackHome">返回主页</button>
      </view>
    </scroll-view>
  </block>

  <!-- 离屏 Canvas 2D，用于物理生成测试卡片并保存至相册 -->
  <canvas type="2d" id="shareCanvas" class="offscreen-canvas"></canvas>

  <!-- 全局自定义赛博弹窗 (Cyber Modal) -->
  <cyber-modal
    show="{{showCyberModal}}"
    title="{{modalTitle}}"
    content="{{modalContent}}"
    showCancel="{{modalShowCancel}}"
    confirmText="{{modalConfirmText}}"
    cancelText="{{modalCancelText}}"
    isDanger="{{modalIsDanger}}"
    isLoading="{{modalIsLoading}}"
    bind:confirm="onCyberModalConfirm"
    bind:cancel="onCyberModalCancel"
  />
</view>
