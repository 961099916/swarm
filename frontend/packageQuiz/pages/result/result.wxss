.page-container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background: var(--bg-root);
  padding: 30rpx 40rpx;
  box-sizing: border-box;
}

/* Loading */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex: 1;
  min-height: 80vh;
}

.spinner {
  width: 64rpx;
  height: 64rpx;
  border: 3rpx solid var(--border-subtle);
  border-top-color: var(--brand);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 40rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 26rpx;
  color: var(--text-muted);
  font-weight: 500;
}

/* 报告主体 */
.report-scroll {
  flex: 1;
  height: 100vh;
}

.result-hero-card {
  text-align: center;
  padding: 56rpx 40rpx;
  margin-bottom: 24rpx;
}

.result-label {
  font-size: 22rpx;
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: 4rpx;
  margin-bottom: 20rpx;
  display: block;
  font-weight: 600;
}

.result-code {
  font-size: 96rpx;
  font-weight: 800;
  letter-spacing: 4rpx;
  color: var(--brand);
  display: block;
  line-height: 1.1;
  margin-bottom: 16rpx;
}

.result-name {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 32rpx;
  display: block;
}

.result-desc {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.7;
  font-weight: 400;
}

/* 模块小标题 */
.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 36rpx;
  display: block;
  border-left: 6rpx solid var(--brand);
  padding-left: 16rpx;
  line-height: 1;
}

/* 维度滑动对比条 */
.dimension-list {
  display: flex;
  flex-direction: column;
  gap: 48rpx;
}

.dimension-item {
  display: flex;
  flex-direction: column;
}

.dim-label-row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.dim-name-left, .dim-name-right {
  font-size: 24rpx;
  color: var(--text-secondary);
  font-weight: 500;
}

.selected-dim {
  color: var(--text-primary);
  font-weight: 700;
}

/* 滑道 */
.slider-track {
  height: 16rpx;
  background: var(--bg-surface-active);
  border-radius: 8rpx;
  position: relative;
  overflow: hidden;
}

.slider-thumb {
  width: 24rpx;
  height: 32rpx;
  border-radius: 6rpx;
  background: var(--brand);
  position: absolute;
  top: 50%;
  transform: translate(-50%, -50%);
  z-index: 10;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.3);
}

.slider-fill-left {
  position: absolute;
  height: 100%;
  left: 0;
  top: 0;
  border-radius: 8rpx;
  background: var(--danger);
  opacity: 0.7;
}

.slider-fill-right {
  position: absolute;
  height: 100%;
  right: 0;
  top: 0;
  border-radius: 8rpx;
  background: var(--success);
  opacity: 0.7;
}

.dim-score-row {
  display: flex;
  justify-content: space-between;
  margin-top: 12rpx;
}

.score-text {
  font-size: 22rpx;
  color: var(--text-muted);
  font-weight: 500;
}

/* 细节列表 */
.bullets-group {
  display: flex;
  flex-direction: column;
  gap: 28rpx;
}

.bullet-item {
  display: flex;
  align-items: flex-start;
}

.bullet-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: var(--danger);
  margin-top: 14rpx;
  margin-right: 18rpx;
  flex-shrink: 0;
}

.advice-dot {
  background: var(--success);
}

.bullet-text {
  font-size: 26rpx;
  color: var(--text-primary);
  line-height: 1.7;
}

/* 社交词云胶囊 */
.social-tags-row {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 16rpx;
  margin: 32rpx 0;
}

.social-tag-capsule {
  background: var(--brand-subtle);
  border: 1rpx solid var(--brand-border);
  color: var(--brand);
  font-size: 22rpx;
  font-weight: 600;
  padding: 8rpx 20rpx;
  border-radius: var(--radius-full);
  box-shadow: none;
}

/* 优势与盲点对比卡片 */
.balance-card {
  padding: 32rpx 24rpx !important;
}

.balance-container {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
  margin-top: 24rpx;
}

.balance-column {
  flex: 1;
  background: var(--bg-surface);
  border: 1rpx solid var(--border-default);
  border-radius: var(--radius-md);
  padding: 20rpx;
}

.col-header {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 20rpx;
  padding-bottom: 12rpx;
}

.strengths-hdr {
  border-bottom: 2rpx solid var(--success);
}

.weaknesses-hdr {
  border-bottom: 2rpx solid var(--danger);
}

.hdr-icon {
  font-size: 24rpx;
}

.hdr-title {
  font-size: 24rpx;
  font-weight: 700;
}

.strengths-hdr .hdr-title {
  color: var(--success);
}

.weaknesses-hdr .hdr-title {
  color: var(--danger);
}

.balance-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.balance-item .item-text {
  font-size: 22rpx;
  color: var(--text-secondary);
  line-height: 1.5;
}

.balance-item .bullet-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  margin-top: 10rpx;
  margin-right: 10rpx;
  flex-shrink: 0;
}

.strengths-col .bullet-dot {
  background: var(--success);
}

.weaknesses-col .bullet-dot {
  background: var(--danger);
}

/* 操作按钮组 */
.footer-action-group {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  margin-top: 48rpx;
  padding-bottom: 80rpx;
}

.action-row-main {
  display: flex;
  gap: 20rpx;
  width: 100%;
}

.btn-action-half {
  flex: 1 !important;
}

.btn-action-full {
  width: 100% !important;
}

.btn-gradient-blue {
  background: var(--brand) !important;
  color: #FFFFFF !important;
  border: none !important;
  border-radius: var(--radius-md) !important;
  height: 80rpx;
  line-height: 80rpx !important;
  font-size: 28rpx;
  font-weight: 600;
  text-align: center;
  box-shadow: none !important;
  transition: opacity 0.2s ease;
}

.btn-gradient-blue:active {
  opacity: 0.85;
}
