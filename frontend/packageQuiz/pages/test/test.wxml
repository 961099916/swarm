<view class="page-container">
  <!-- 进度区域 -->
  <view class="progress-section">
    <view class="progress-text-row">
      <text class="progress-label">测评进度</text>
      <text class="progress-count">{{currentIndex + 1}} / {{questions.length}}</text>
    </view>
    <view class="progress-bar-bg">
      <view class="progress-bar-fill" style="width: {{progress}}%;"></view>
    </view>
  </view>

  <!-- AVG 游戏化立绘区域 -->
  <view class="avatar-section" wx:if="{{questions.length > 0}}">
    <view class="hologram-podium"></view>
    <view class="avatar-wrapper">
      <view class="hologram-projection" style="background-image: url('{{avatarSvg}}');"></view>
    </view>
    <view class="hologram-scanner"></view>
  </view>

  <!-- 题目主卡片 -->
  <view class="question-container" wx:if="{{questions.length > 0}}">
    <view class="glass-card question-card-avg" bindtap="onTapDialogue">
      <!-- 导师称呼标签 -->
      <view class="speaker-tag">AI 测评导师</view>
      
      <!-- 科幻发光直角装饰器 -->
      <view class="card-corner top-left"></view>
      <view class="card-corner top-right"></view>
      <view class="card-corner bottom-left"></view>
      <view class="card-corner bottom-right"></view>
      
      <view class="question-title">
        <text>{{displayText}}</text>
        <text class="typing-cursor" wx:if="{{isTyping}}"></text>
      </view>
    </view>


    <!-- 选项卡片组 -->
    <view class="options-group">
      <block wx:for="{{questions[currentIndex].options}}" wx:key="id">
        <view class="glass-card option-card {{selectedOptionId === item.id ? 'option-selected' : ''}}" 
              bindtap="onSelectOption" 
              data-id="{{item.id}}">
          <text class="option-marker">{{item.id}}</text>
          <text class="option-text">{{item.text}}</text>
        </view>
      </block>
    </view>
  </view>

  <!-- 底部操作导航栏 -->
  <view class="footer-action">
    <button class="btn-secondary" bindtap="onPrevQuestion" disabled="{{currentIndex === 0}}">上一题</button>
    <button class="btn-cancel" bindtap="onExitTest">放弃测试</button>
  </view>

  <!-- 全局自定义赛博弹窗 (Cyber Modal) -->
  <cyber-modal
    show="{{showCyberModal}}"
    title="{{modalTitle}}"
    content="{{modalContent}}"
    showCancel="{{modalShowCancel}}"
    confirmText="{{modalConfirmText}}"
    cancelText="{{modalCancelText}}"
    isDanger="{{modalIsDanger}}"
    isLoading="{{modalIsLoading}}"
    bind:confirm="onCyberModalConfirm"
    bind:cancel="onCyberModalCancel"
  />

  <!-- 自定义 Tabbar -->
</view>
