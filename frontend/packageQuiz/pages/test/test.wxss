.page-container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  padding: 30rpx 40rpx;
  background: var(--bg-root);
  box-sizing: border-box;
  animation: fade-up 0.35s ease-out both;
}
.page-container.theme-light { background: var(--bg-root); }

/* 进度区域 */
.progress-section {
  margin-top: 10rpx;
  margin-bottom: 40rpx;
}

.progress-text-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.progress-label {
  font-size: 24rpx;
  font-weight: 500;
  color: var(--text-muted);
}

.progress-count {
  font-size: 26rpx;
  font-weight: 700;
  color: var(--brand);
}

.progress-bar-bg {
  height: 16rpx;
  background: var(--bg-surface-active);
  border-radius: 8rpx;
  overflow: hidden;
  position: relative;
}

.progress-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--brand), var(--brand-light));
  border-radius: 8rpx;
  transition: width 0.4s ease;
}

/* AI 测评导师立绘区域 */
.avatar-section {
  position: relative;
  width: 100%;
  height: 320rpx;
  display: flex;
  justify-content: center;
  align-items: flex-end;
  margin-top: 10rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.avatar-wrapper {
  position: relative;
  width: 192rpx;
  height: 288rpx;
  display: flex;
  justify-content: center;
  align-items: flex-end;
  z-index: 2;
  transform-origin: bottom center;
  animation: avatar-bounce 2s ease-in-out infinite;
}

.hologram-projection {
  width: 100%;
  height: 100%;
  background-repeat: no-repeat;
  background-position: bottom center;
  background-size: contain;
  transition: all 0.2s ease;
}

@keyframes avatar-bounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-8rpx); }
}

/* 对话框气泡 */
.question-container {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.question-card-avg {
  position: relative;
  padding: 56rpx 40rpx 40rpx 40rpx;
  margin-bottom: 40rpx;
  min-height: 150rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  background: var(--bg-surface);
  border: 1rpx solid var(--border-default);
  box-shadow: var(--shadow-md);
  border-radius: var(--radius-md);
}

/* 导师称呼标签 */
.speaker-tag {
  position: absolute;
  top: -22rpx;
  left: 32rpx;
  background: var(--brand);
  color: #FFFFFF;
  font-size: 20rpx;
  font-weight: 600;
  padding: 6rpx 20rpx;
  border-radius: var(--radius-sm);
  z-index: 3;
}

.question-title {
  font-size: 28rpx;
  font-weight: 500;
  line-height: 1.6;
  color: var(--text-primary);
}

/* 打字机光标 */
.typing-cursor {
  display: inline-block;
  width: 3rpx;
  height: 26rpx;
  background: var(--brand);
  margin-left: 6rpx;
  animation: cursor-blink 0.8s infinite;
  vertical-align: middle;
}

@keyframes cursor-blink {
  0%, 100% { opacity: 0; }
  50% { opacity: 1; }
}

/* 选项卡片组 */
.options-group {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.option-card {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
  border-radius: var(--radius-md);
  margin-bottom: 0;
  background: var(--bg-surface);
  border: 1rpx solid var(--border-default);
  box-shadow: var(--shadow-sm);
  transition: all 0.2s ease;
}

.option-card:active {
  background: var(--bg-surface-hover);
  border-color: var(--border-strong);
}

.option-selected {
  background: var(--brand-subtle) !important;
  border-color: var(--brand-border) !important;
}

/* 字母序号标签 */
.option-marker {
  width: 44rpx;
  height: 44rpx;
  border-radius: var(--radius-sm);
  background: var(--bg-surface-hover);
  color: var(--text-secondary);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
  margin-right: 24rpx;
  transition: all 0.2s ease;
  flex-shrink: 0;
}

.option-selected .option-marker {
  background: var(--brand);
  color: #FFFFFF;
}

.option-text {
  font-size: 26rpx;
  color: var(--text-primary);
  flex: 1;
  font-weight: 400;
}

/* 底部操作导航栏 */
.footer-action {
  display: flex;
  justify-content: space-between;
  margin-top: 40rpx;
  gap: 24rpx;
  padding-bottom: 40rpx;
}

.footer-action button {
  flex: 1;
}

.btn-cancel {
  background: var(--bg-surface) !important;
  color: var(--danger) !important;
  border: 1rpx solid var(--danger-border) !important;
  border-radius: var(--radius-md) !important;
  height: 80rpx;
  line-height: 78rpx;
  font-size: 28rpx;
  font-weight: 600;
  text-align: center;
  box-shadow: none;
  transition: background 0.2s ease;
}

.btn-cancel:active {
  background: var(--danger-subtle) !important;
}
