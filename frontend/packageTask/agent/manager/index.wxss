/* page 背景由 app.wxss 全局统管 */

.manager-container { padding: 24rpx; padding-bottom: 80rpx; background: var(--bg-root); min-height: 100vh; box-sizing: border-box; display: flex; flex-direction: column; transition: background 0.3s ease; animation: fade-up 0.35s ease-out both; }
.manager-container.theme-light { background: var(--bg-root); }
.create-card { padding: 28rpx; display: flex; justify-content: space-between; align-items: center; margin-bottom: 20rpx; overflow: hidden; border-radius: var(--radius-lg); }
.create-left { display: flex; flex-direction: column; gap: 12rpx; max-width: 70%; }
.create-title { font-size: 28rpx; font-weight: 700; color: var(--text); }
.create-desc { font-size: 22rpx; color: var(--text-muted); line-height: 1.5; }
.create-btn { background: var(--brand-gradient); color: #FFF; padding: 10rpx 32rpx; font-size: 24rpx; border-radius: var(--radius-full); font-weight: 600; margin: 0; line-height: 1.5; border: none; }
.create-btn::after { border: none; }
.agent-scroll { flex: 1; }
.section-hd { font-size: 26rpx; font-weight: 600; color: var(--text); margin: 32rpx 0 20rpx; display: block; padding-left: 4rpx; }
.agent-grid { display: flex; flex-direction: column; gap: 12rpx; padding-bottom: 24rpx; }
.agent-card { padding: 24rpx; border-radius: var(--radius-md); }
.ag-card-top { display: flex; align-items: center; gap: 16rpx; margin-bottom: 24rpx; }
.ag-avatar { width: 80rpx; height: 80rpx; border-radius: 50%; background: var(--brand-gradient); box-shadow: var(--shadow-glow); display: flex; align-items: center; justify-content: center; font-size: 40rpx; flex-shrink: 0; color: #FFFFFF; border: none; }
.ag-meta { flex: 1; min-width: 0; }
.ag-name-row { display: flex; align-items: center; gap: 12rpx; }
.ag-name { font-size: 26rpx; font-weight: 700; color: var(--text-primary); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; max-width: 280rpx; display: block; }
.ag-badge { font-size: 18rpx; padding: 3rpx 12rpx; border-radius: 4rpx; font-weight: 600; }
.ag-badge.custom { background: var(--warning-subtle); color: var(--warning); }
.ag-badge.preset { background: var(--success-subtle); color: var(--success); }
.ag-role { font-size: 20rpx; color: var(--text-muted); display: block; margin-top: 6rpx; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.ag-details { display: flex; flex-direction: column; gap: 14rpx; margin-bottom: 20rpx; }
.ag-row { display: flex; justify-content: space-between; font-size: 22rpx; }
.ag-lbl { color: var(--text-muted); }
.ag-val { color: var(--text-secondary); }
.ag-prompt { margin-bottom: 20rpx; }
.ag-prompt-txt { padding: 16rpx; border-radius: 8rpx; background: rgba(0,0,0,0.2); font-size: 20rpx; color: var(--text-secondary); line-height: 1.5; max-height: 100rpx; overflow: hidden; display: block; margin-top: 8rpx; word-break: break-all; }
.ag-actions { display: flex; gap: 12rpx; }
.ag-act { flex: 1; padding: 14rpx; border-radius: 8rpx; text-align: center; font-size: 22rpx; font-weight: 600; border: 1rpx solid var(--border-default); }
.ag-act.edit { background: var(--brand-subtle); border-color: var(--brand-border); color: var(--brand); }
.ag-act.delete { background: var(--danger-subtle); border-color: var(--danger-border); color: var(--danger); }
.modal-sheet { padding: 32rpx; padding-bottom: calc(40rpx + env(safe-area-inset-bottom)); display: flex; flex-direction: column; gap: 20rpx; max-height: 80vh; background: var(--bg-surface-solid); border-radius: var(--radius-xl) var(--radius-xl) 0 0; border-top: 1rpx solid var(--glass-border); }
.modal-head { display: flex; justify-content: space-between; align-items: center; }
.modal-title { font-size: 32rpx; font-weight: 700; color: var(--text-primary); }
.modal-close { font-size: 44rpx; color: var(--text-muted); padding: 0 12rpx; }
.modal-body { display: flex; flex-direction: column; gap: 16rpx; overflow-y: auto; max-height: 60vh; }
.form-g { display: flex; flex-direction: column; gap: 10rpx; }
.form-lbl { font-size: 24rpx; font-weight: 600; color: var(--text-primary); }
.modal-inp { --td-input-bg-color: var(--glass-bg); --td-input-border-color: var(--glass-border); --td-input-text-color: var(--text-primary); --td-input-placeholder-text-color: var(--text-placeholder); border-radius: var(--radius-md); overflow: hidden; backdrop-filter: var(--glass-blur); -webkit-backdrop-filter: var(--glass-blur); }
.modal-tarea { --td-textarea-background-color: var(--glass-bg); --td-textarea-border-color: var(--glass-border); --td-textarea-text-color: var(--text-primary); --td-textarea-placeholder-color: var(--text-placeholder); height: 180rpx; border-radius: var(--radius-md); overflow: hidden; backdrop-filter: var(--glass-blur); -webkit-backdrop-filter: var(--glass-blur); }
.model-opts { display: flex; flex-direction: column; gap: 12rpx; }
.mo-item { padding: 24rpx; border-radius: var(--radius-md); background: var(--glass-bg); backdrop-filter: var(--glass-blur); -webkit-backdrop-filter: var(--glass-blur); border: 1rpx solid var(--glass-border); }
.mo-item.active { border-color: var(--brand-border); background: var(--brand-subtle); }
.mo-name { font-size: 24rpx; font-weight: 600; color: var(--text); display: block; }
.mo-desc { font-size: 20rpx; color: var(--text-muted); display: block; margin-top: 4rpx; }
.tool-row { display: flex; gap: 12rpx; }
.to-opt { flex: 1; padding: 18rpx; text-align: center; border-radius: var(--radius-md); font-size: 22rpx; background: var(--glass-bg); backdrop-filter: var(--glass-blur); -webkit-backdrop-filter: var(--glass-blur); border: 1rpx solid var(--glass-border); color: var(--text-secondary); }
.to-opt.active { border-color: var(--brand-border); background: var(--brand-subtle); color: var(--brand); font-weight: 600; }
.save-btn { --td-button-primary-bg-color: var(--brand) !important; border-radius: var(--radius-md) !important; margin-top: 8rpx; background: var(--brand-gradient) !important; border: none !important; }
