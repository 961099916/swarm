<view class="detail-container {{theme}}">

  <!-- 状态摘要 -->
  <view class="card status-card">
    <view class="shead">
      <text class="sh-label">任务状态</text>
      <view class="tag tag-{{taskInfo.statusClass}}">
        <text>{{taskInfo.statusLabel}}</text>
      </view>
    </view>
    <text class="s-id">{{taskInfo.id}}</text>
    <view class="separator" style="margin:20rpx 0;"></view>
    <view class="s-rows">
      <view class="s-row"><text class="s-lbl">类型</text><text class="s-val">{{taskInfo.typeLabel}}</text></view>
      <view class="s-row"><text class="s-lbl">创建者</text><text class="s-val code">{{taskInfo.user_id || '—'}}</text></view>
      <view class="s-row"><text class="s-lbl">目标</text><text class="s-val">{{taskInfo.payload && taskInfo.payload.goal ? taskInfo.payload.goal : '—'}}</text></view>
      <view class="s-row"><text class="s-lbl">消耗</text><text class="s-val">{{taskInfo.credits_cost || 0}} 积分</text></view>
      <view class="s-row"><text class="s-lbl">创建时间</text><text class="s-val">{{taskInfo.created_at || '—'}}</text></view>
    </view>
  </view>

  <!-- 执行结果 -->
  <view class="result-block">
    <view class="result-band {{taskInfo.statusClass}}">
      <text class="result-band-dot {{taskInfo.status === 'SUCCESS' ? 'ok' : taskInfo.status === 'RUNNING' ? 'running' : ''}}"></text>
      <text class="result-band-label">
        {{taskInfo.status === 'SUCCESS' ? '执行成功' : taskInfo.status === 'FAILED' ? '执行失败' : taskInfo.status === 'RUNNING' ? '执行中' : taskInfo.status === 'PENDING' ? '排队等待' : taskInfo.status === 'CANCELLED' ? '已取消' : taskInfo.status === 'SLEEPING' ? '已暂停' : '执行状态'}}
      </text>
    </view>
    <view class="result-body">
      <text wx:if="{{taskInfo.result_summary}}" class="result-summary">{{taskInfo.result_summary}}</text>
      <text wx:else class="result-summary" style="color:var(--text-muted);">
        {{taskInfo.status === 'RUNNING' ? '任务正在云端执行中，请等待执行完成...' : taskInfo.status === 'PENDING' ? '任务已提交，等待系统分配算力资源...' : taskInfo.status === 'SLEEPING' ? '任务已暂停，可在管理后台恢复' : taskInfo.status === 'CANCELLED' ? '任务已被取消' : '暂无结果信息'}}
      </text>
      <view class="result-cost">
        <text class="result-cost-label">消耗：</text>
        <text class="result-cost-num">{{taskInfo.credits_cost || 0}} 积分</text>
      </view>
    </view>
  </view>

  <!-- 终端日志 -->
  <view class="card terminal-box">
    <scroll-view class="term-scroll" scroll-y scroll-with-animation scroll-top="{{scrollTop}}">
      <view class="term-body">
        <block wx:for="{{logs}}" wx:key="id">
          <view wx:if="{{item.parsed && item.parsed.type === 'ai-chat'}}" class="chat-card {{!item.parsed.body.success ? 'error' : ''}}" data-index="{{index}}" bindtap="onToggleChatExpand">
            <view class="cc-head">
              <view class="cc-left">
                <text class="cc-icon">AI</text>
                <text class="cc-agent">{{item.parsed.body.agentName || 'AI'}}</text>
                <text class="cc-model">{{item.parsed.body.model || ''}}</text>
              </view>
              <view class="cc-right">
                <view class="cc-dot {{item.parsed.body.success ? 'ok' : ''}}"></view>
                <text class="cc-arrow">{{item.expanded ? '▾' : '▸'}}</text>
              </view>
            </view>
            <view wx:if="{{item.expanded}}" class="cc-body">
              <view class="cc-section"><text class="cc-sectitle">输入消息</text><text class="cc-box">{{item.parsed.body.messages || '—'}}</text></view>
              <view class="cc-section"><text class="cc-sectitle">模型回复</text><text class="cc-box ok">{{item.parsed.body.response || '—'}}</text></view>
            </view>
          </view>
          <view wx:else class="t-line">
            <text class="t-time">{{item.formattedTime}}</text>
            <text wx:if="{{item.parsed && item.parsed.prefix}}" class="t-prefix tag tag-{{item.parsed.type}}">{{item.parsed.prefix}}</text>
            <text class="t-msg">{{item.parsed && item.parsed.body ? item.parsed.body : item.message}}</text>
          </view>
        </block>
        <view class="t-cursor"><text class="t-cursor-txt">█</text></view>
      </view>
    </scroll-view>
  </view>
</view>
