.detail-container { padding: 20rpx; padding-bottom: 32rpx; background: var(--bg-root); color: var(--text); min-height: 100vh; box-sizing: border-box; display: flex; flex-direction: column; transition: background 0.3s ease; }
.detail-container.theme-light { background: var(--bg-root); }

.status-card { padding: 24rpx; margin-bottom: 20rpx; flex-shrink: 0; }

.shead { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16rpx; }
.sh-label { font-size: 20rpx; font-weight: 700; color: var(--text-muted); text-transform: uppercase; }
.s-id { font-family: "SF Mono",monospace; font-size: 20rpx; color: var(--text-muted); word-break: break-all; }
.s-rows { display: flex; flex-direction: column; gap: 12rpx; }
.s-row { display: flex; justify-content: space-between; font-size: 22rpx; }
.s-lbl { color: var(--text-muted); flex-shrink: 0; margin-right: 24rpx; }
.s-val { font-weight: 600; color: var(--text); text-align: right; }
.s-val.code { font-family: "SF Mono",monospace; padding: 2rpx 12rpx; background: var(--bg-surface); border-radius: 6rpx; font-size: 18rpx; }

/* 执行结果 */
.result-block { margin-bottom: 20rpx; border-radius: 8rpx; overflow: hidden; border: 1rpx solid var(--border-default); }
.result-band { display: flex; align-items: center; gap: 10rpx; padding: 16rpx 24rpx; background: var(--bg-surface); border-bottom: 1rpx solid var(--border-default); }
.result-band.running { background: var(--brand-subtle); }
.result-band.success { background: var(--success-subtle); }
.result-band.failed { background: var(--danger-subtle); }
.result-band-dot { width: 10rpx; height: 10rpx; border-radius: 50%; background: var(--text-muted); }
.result-band-dot.running { background: var(--brand-light); animation: dot-pulse 1.6s ease-in-out infinite; }
.result-band-dot.ok { background: var(--success); }
.result-band-label { font-size: 24rpx; font-weight: 700; color: var(--text); }
.result-body { padding: 28rpx 24rpx; background: var(--bg-surface); }
.result-summary { font-size: 26rpx; color: var(--text); line-height: 1.6; display: block; }
.result-cost { display: flex; align-items: center; gap: 8rpx; margin-top: 20rpx; padding-top: 16rpx; border-top: 1rpx solid var(--border-default); }
.result-cost-label { font-size: 22rpx; color: var(--text-muted); }
.result-cost-num { font-size: 22rpx; font-weight: 700; color: var(--brand); font-family: "SF Mono", monospace; }

/* 终端 */
.terminal-box { flex: 1; padding: 20rpx; margin-bottom: 20rpx; min-height: 200rpx; background: rgba(12,12,16,0.97); border: 1rpx solid var(--border-default); border-radius: 8rpx; }
.term-scroll { width: 100%; height: 100%; }
.term-body { display: flex; flex-direction: column; gap: 12rpx; }
.t-line { font-size: 22rpx; display: flex; flex-wrap: wrap; align-items: baseline; gap: 6rpx; padding: 4rpx 0; }
.t-time { color: var(--text-muted); font-size: 18rpx; white-space: nowrap; margin-right: 4rpx; }
.t-msg { color: var(--text-secondary); word-break: break-all; flex: 1; }
.t-prefix { margin-right: 4rpx; }
.t-prefix.tag-supervisor { color: var(--warning); }
.t-prefix.tag-agent { color: var(--success); }
.t-prefix.tag-tool { color: var(--brand-light); }
.t-prefix.tag-system { color: var(--text-muted); }
.t-prefix.tag-normal { color: var(--text-secondary); }

.chat-card { background: var(--bg-surface); border: 1rpx solid var(--border-default); border-radius: 8rpx; overflow: hidden; margin: 6rpx 0; }
.chat-card.error { background: var(--danger-subtle); border-color: var(--danger-border); }
.cc-head { display: flex; justify-content: space-between; align-items: center; padding: 16rpx 20rpx; }
.cc-left { display: flex; align-items: center; gap: 10rpx; flex: 1; min-width: 0; }
.cc-icon { font-size: 20rpx; color: var(--brand); font-weight: 600; }
.cc-agent { font-size: 22rpx; font-weight: 600; color: var(--text); }
.cc-model { font-size: 18rpx; padding: 2rpx 10rpx; border-radius: 4rpx; background: var(--success-subtle); color: var(--success); font-family: "SF Mono",monospace; max-width: 180rpx; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.cc-right { display: flex; align-items: center; gap: 16rpx; flex-shrink: 0; }
.cc-dot { width: 8rpx; height: 8rpx; border-radius: 50%; background: var(--danger); }
.cc-dot.ok { background: var(--success); }
.cc-arrow { font-size: 16rpx; color: var(--text-muted); }
.cc-body { padding: 0 20rpx 20rpx; border-top: 1rpx solid var(--border-default); display: flex; flex-direction: column; gap: 16rpx; }
.cc-section { display: flex; flex-direction: column; gap: 8rpx; margin-top: 16rpx; }
.cc-sectitle { font-size: 18rpx; font-weight: 700; color: var(--text-muted); }
.cc-box { padding: 16rpx; font-family: "SF Mono",monospace; font-size: 18rpx; background: rgba(0,0,0,0.3); border: 1rpx solid var(--border-subtle); border-radius: 6rpx; word-break: break-all; white-space: pre-wrap; max-height: 360rpx; overflow-y: auto; color: var(--text-secondary); line-height: 1.5; }
.cc-box.ok { border-left: 3rpx solid var(--success); }

.t-cursor { color: var(--success); font-size: 22rpx; margin-top: 8rpx; }
.t-cursor-txt { animation: cursor-blink 1s step-end infinite; }
@keyframes dot-pulse { 0%,100% { opacity:1; } 50% { opacity:0.4; } }

@keyframes cursor-blink { 0%,100% { opacity: 1; } 50% { opacity: 0; } }

/* 亮色 */
.theme-light .terminal-box { background: rgba(248,248,252,0.97); border-color: var(--border-default); }
.theme-light .cc-box { background: rgba(0,0,0,0.03); border-color: var(--border-default); color: var(--text); }
