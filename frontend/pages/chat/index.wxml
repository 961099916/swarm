<view class="page">
  <!-- 对话区域 -->
  <scroll-view class="chat-area" scroll-y scroll-into-view="bottom" scroll-with-animation>
    <view wx:for="{{messages}}" wx:for-index="idx" wx:key="idx" class="msg {{item.role === 'user' ? 'msg-user' : 'msg-assistant'}}">
      <view wx:if="{{item.role === 'user'}}" class="msg-bubble user-bubble">{{item.content}}</view>
      <view wx:else class="msg-bubble assistant-bubble">
        <view wx:if="{{item.thinking}}" class="thinking">
          <t-loading size="28rpx" />
          <text>思考中...</text>
        </view>
        <view wx:else>{{item.content}}</view>
      </view>
    </view>
    <view id="bottom" />
  </scroll-view>

  <!-- 输入区域 -->
  <view class="input-area">
    <t-input
      class="chat-input"
      value="{{inputValue}}"
      placeholder="输入你的问题..."
      bindinput="onInput"
      bindconfirm="onSend"
      confirm-type="send"
    />
    <t-button
      theme="primary"
      size="small"
      bindtap="onSend"
      loading="{{sending}}"
      disabled="{{!inputValue.trim() || sending}}"
    >发送</t-button>
  </view>

  <!-- 自定义 Tabbar -->
</view>
