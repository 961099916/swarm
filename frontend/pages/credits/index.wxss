/* credits/index.wxss — 暖绒奶油风 */

.credits-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: var(--bg-root);
  color: var(--text);
  animation: fade-up 0.35s ease-out both;
}
.credits-container.theme-light { background: var(--bg-root); }

/* 余额毛玻璃卡片 */
.balance-card {
  padding: 32rpx;
  margin: 24rpx 24rpx 0;
  border-radius: var(--radius-lg);
  flex-shrink: 0;
}
.bal-label { font-size: 24rpx; color: var(--text-secondary); margin-bottom: 8rpx; display: block; }
.bal-row { display: flex; align-items: baseline; gap: 12rpx; margin-bottom: 8rpx; }
.bal-num { font-size: 64rpx; font-weight: 800; background: var(--brand-gradient); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; line-height: 1.1; }
.bal-unit { font-size: 40rpx; color: var(--brand); font-weight: 600; }
.bal-desc { font-size: 22rpx; color: var(--text-muted); margin-bottom: 24rpx; display: block; }

.bal-actions { display: grid; grid-template-columns: 1fr 1fr; gap: 14rpx; }

/* 筛选栏 */
.cr-filter-bar {
  width: 100%;
  white-space: nowrap;
  padding: 16rpx 24rpx;
  box-sizing: border-box;
  flex-shrink: 0;
}

/* 滚动列表容器 */
.cr-list-scroll {
  flex: 1;
  height: 0;
  padding: 0 24rpx 24rpx;
}

/* 时间线流水 */
.history-item { display: flex; gap: 14rpx; margin-bottom: 24rpx; position: relative; padding-left: 28rpx; }
.tl-dot { position: absolute; left: 0; top: 48rpx; width: 16rpx; height: 16rpx; border-radius: 50%; border: 3rpx solid var(--bg-root); z-index: 10; }
.tl-dot.up { background: var(--brand); box-shadow: 0 0 10rpx rgba(255,107,107,0.5); }
.tl-dot.down { background: var(--danger); box-shadow: 0 0 10rpx rgba(231,76,60,0.5); }
.history-item::before { content: ''; position: absolute; left: 8rpx; top: 60rpx; bottom: -12rpx; width: 1rpx; border-left: 1rpx dashed var(--border-subtle); }
.history-item:last-child::before { display: none; }
.history-card { padding: 24rpx; width: 100%; box-sizing: border-box; border-radius: var(--radius-md); }
.hist-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12rpx; }
.hist-reason { font-size: 24rpx; font-weight: 600; color: var(--text-primary); }
.hist-time { font-size: 20rpx; color: var(--text-muted); }
.hist-amount { font-size: 40rpx; font-weight: 700; display: block; }
.hist-amount.up { color: var(--brand); background: var(--brand-gradient); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
.hist-amount.down { color: var(--danger); }
.hist-balance { font-size: 20rpx; color: var(--text-muted); display: block; margin-top: 6rpx; }

/* 日期分组标题 */
.cr-date-header {
  display: block;
  font-size: 22rpx;
  font-weight: 600;
  color: var(--text-secondary);
  padding: 20rpx 4rpx 12rpx;
}

/* 加载更多 */
.cr-load-more { display: flex; align-items: center; justify-content: center; gap: 12rpx; padding: 32rpx 0; }
.cr-load-more-text { font-size: 22rpx; color: var(--text-muted); }
.cr-load-more-end { font-size: 20rpx; color: var(--text-placeholder); letter-spacing: 2rpx; }

/* 广告弹窗 */
.ad-panel { padding: 60rpx 80rpx; text-align: center; background: var(--bg-surface-solid); border-radius: var(--radius-xl); }
.ad-title { font-size: 32rpx; font-weight: 700; color: var(--text-primary); display: block; margin-bottom: 32rpx; }
.ad-progress-bar { height: 12rpx; background: var(--bg-surface-active); border-radius: 6rpx; overflow: hidden; margin-bottom: 16rpx; }
.ad-progress-fill { height: 100%; background: var(--brand-gradient); border-radius: 6rpx; transition: width 0.3s ease; }
.ad-countdown { font-size: 48rpx; font-weight: 800; color: var(--brand); display: block; margin-bottom: 8rpx; }
.ad-hint { font-size: 22rpx; color: var(--text-muted); }
