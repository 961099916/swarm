/* page 背景由 app.wxss 全局统管 */


/* ── 全局内联样式替代类（阿里规范：结构与样式分离） ── */

/* 页面副标题 */
.page-subtitle {
  font-size: 22rpx;
  color: var(--text-muted);
  display: block;
  margin-bottom: 24rpx;
}
/* 页面主标题间距 */

/* 按钮图标 */
.btn-icon-add {
  font-size: 24rpx;
  margin-right: 6rpx;
}

/* 品牌色数字强调 */
.num-brand {
  color: var(--brand);
  font-weight: 700;
}

/* 弹窗图标 */
.picker-icon-close {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
}
.picker-empty-text {
  font-size: 24rpx;
  color: var(--text-muted);
}

/* 列表项头像容器 */
.agent-avatar-icon-wrap {
  width: 56rpx;
  height: 56rpx;
  font-size: 28rpx;
  flex-shrink: 0;
}
.agent-avatar-icon {
  font-size: 28rpx;
}

/* 勾选图标 */
.picker-icon-check {
  font-size: 24rpx;
  color: #FFFFFF;
}

.deploy-container {
  padding: 24rpx;
  padding-bottom: calc(160rpx + env(safe-area-inset-bottom));
  background: var(--bg-root);
  color: var(--text);
  min-height: 100vh;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  transition: background 0.3s ease;
  animation: fade-up 0.35s ease-out both;
}

.deploy-container.theme-light { background: var(--bg-root); }

.form-panel { padding: 28rpx; border-radius: var(--radius-lg); }

.form-body { display: flex; flex-direction: column; gap: 36rpx; }

.form-group { display: flex; flex-direction: column; gap: 14rpx; }

.form-label { font-size: 26rpx; font-weight: 600; color: var(--text-primary); }
.form-label-row { display: flex; justify-content: space-between; align-items: center; }
.form-link { font-size: 24rpx; font-weight: 600; color: var(--brand); }
.form-hint { font-size: 20rpx; color: var(--text-muted); }
.form-placeholder { color: var(--text-placeholder); }
/* TDesign 组件主题覆盖 */
.td-input-custom {
  --td-input-bg-color: var(--glass-bg);
  --td-input-border-color: var(--glass-border);
  --td-input-text-color: var(--text-primary);
  --td-input-placeholder-color: var(--text-placeholder);
  border-radius: var(--radius-lg);
}
.td-textarea-custom {
  --td-textarea-background-color: var(--glass-bg);
  --td-textarea-border-color: var(--glass-border);
  --td-textarea-text-color: var(--text-primary);
  --td-textarea-placeholder-color: var(--text-placeholder);
  --td-textarea-border-radius: var(--radius-lg);
}
/* 表单校验错误态 */
.form-group.has-error {
  border-color: var(--danger) !important;
  box-shadow: 0 0 0 3rpx var(--danger-subtle);
  border-radius: var(--radius-md);
  padding: 14rpx;
}
.field-error-text {
  font-size: 20rpx;
  color: var(--danger);
  margin-top: 4rpx;
  display: block;
}

/* ── 智能体芯片展示 ── */
.selected-agents-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 16rpx;
}
.agent-chip {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 12rpx 8rpx 8rpx;
  border-radius: var(--radius-full);
  background: var(--brand-subtle);
  border: 1rpx solid var(--brand-border);
}
.agent-chip-avatar {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: var(--brand-gradient);
  color: #FFFFFF;
  font-size: 18rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.agent-chip-name {
  font-size: 22rpx;
  font-weight: 600;
  color: var(--brand);
  max-width: 120rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.agent-chip-remove {
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
  background: rgba(0,0,0,0.15);
  color: var(--text-muted);
  font-size: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

/* 操作按钮行 */
.agent-actions-row {
  display: flex;
  gap: 12rpx;
}

/* ── 三段式智能体选择器弹窗 ──
 * 布局：搜索区(固定) | 列表区(撑满) | 操作区(固定)
 * 视觉：三区背景色分层 + 投影分隔
 */

/* 覆盖 t-popup 自带的安全区 padding，由内部 .picker-bottom-inner 自行处理
   （防止外层 padding 占用高度后被 max-height:100vh 截断内容） */
.t-popup--bottom {
  padding-bottom: 0 !important;
}

/* 弹窗容器 — 撑满屏幕大部分区域，三区 flex 竖排
   不设 overflow:hidden——防止 flex 过度撑开时裁剪底部操作栏 */
.picker-sheet {
  display: flex;
  flex-direction: column;
  max-height: 92vh;
  background: var(--bg-surface-solid);
  border-radius: var(--radius-xl) var(--radius-xl) 0 0;
  border-top: 1rpx solid var(--glass-border);
}

/* ── 上区：标题 + 搜索（固定，带底部阴影） ── */
.picker-top {
  flex-shrink: 0;
  background: var(--bg-surface-solid);
  border-radius: var(--radius-xl) var(--radius-xl) 0 0;
  overflow: hidden;            /* 仅上区负责圆角裁剪 */
  position: relative;
  z-index: 2;
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.08);
}

.picker-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 32rpx 0;
}


.picker-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-primary);
  letter-spacing: 0.5rpx;
}

.picker-close-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: var(--glass-bg);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: background 0.2s;
}
.picker-close-btn:active {
  background: var(--bg-surface-hover);
}

/* ── 中区：列表区（不同底色，撑满剩余空间） ── */
.picker-middle {
  flex: 1;
  min-height: 0;              /* 确保 flex 子项能收缩到内容高度以下 */
  overflow: hidden;          /* scroll-view 内部滚动 */
  background: var(--bg-surface);
  position: relative;
  z-index: 1;
}

.picker-list {
  height: 100%;
  overflow-y: scroll;
  padding: 12rpx 28rpx 20rpx;
  -webkit-overflow-scrolling: touch;
  box-sizing: border-box;
}

.picker-agent-item {
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 18rpx 20rpx;
  border-radius: var(--radius-md);
  margin-bottom: 6rpx;
  transition: all 0.2s;
  background: transparent;
  border: 1rpx solid transparent;
}
.picker-agent-item:active {
  background: var(--bg-surface-hover);
  transform: scale(0.98);
}
.picker-agent-item.selected {
  background: var(--brand-subtle);
  border-color: var(--brand-border);
}

.picker-agent-info { flex: 1; min-width: 0; }
.picker-agent-name {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-primary);
  display: block;
  line-height: 1.4;
}
.picker-agent-role {
  font-size: 21rpx;
  color: var(--text-muted);
  margin-top: 4rpx;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  line-height: 1.4;
}

.picker-check {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  background: var(--brand-gradient);
}

/* ── 下区：操作栏（固定，带顶部投影产生悬浮感） ── */
.picker-bottom {
  flex-shrink: 0;
  background: var(--bg-surface-solid);
  position: relative;
  z-index: 2;
  box-shadow: 0 -6rpx 28rpx rgba(0,0,0,0.08);
}

.picker-bottom-inner {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 32rpx calc(20rpx + env(safe-area-inset-bottom));
}

.picker-selected-count {
  font-size: 24rpx;
  color: var(--text-muted);
  white-space: nowrap;
  flex-shrink: 0;
}

.agent-list { display: flex; flex-direction: column; gap: 14rpx; }
.agent-item { padding: 20rpx 24rpx; display: flex; align-items: center; gap: 14rpx; border-radius: var(--radius-md); }
.agent-item.selected { border-color: var(--brand-border); background: var(--brand-subtle); box-shadow: var(--shadow-glow); }
.agent-avatar { width: 72rpx; height: 72rpx; border-radius: 50%; background: var(--brand-subtle); display: flex; align-items: center; justify-content: center; font-size: 32rpx; flex-shrink: 0; }
.agent-info { flex: 1; min-width: 0; }
.agent-name { font-size: 24rpx; font-weight: 600; color: var(--text-primary); display: block; }
.agent-role { font-size: 20rpx; color: var(--text-muted); margin-top: 4rpx; display: block; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.selected-mark { width: 36rpx; height: 36rpx; border-radius: 50%; background: var(--brand-gradient); color: #FFF; font-size: 18rpx; font-weight: 700; display: flex; align-items: center; justify-content: center; flex-shrink: 0; box-shadow: 0 0 12rpx rgba(255,107,107,0.4); }

.cost-card { padding: 28rpx; display: flex; flex-direction: column; gap: 14rpx; border-radius: var(--radius-lg); }
.cost-head { display: flex; justify-content: space-between; align-items: center; }
.cost-title { font-size: 28rpx; font-weight: 700; color: var(--text-primary); }
.cost-status { font-size: 20rpx; padding: 6rpx 20rpx; border-radius: var(--radius-full); font-weight: 600; }
.cost-status.ok { background: var(--success-subtle); color: var(--success); backdrop-filter: var(--glass-blur); -webkit-backdrop-filter: var(--glass-blur); border: 1rpx solid var(--success-border); }
.cost-status.warn { background: var(--danger-subtle); color: var(--danger); backdrop-filter: var(--glass-blur); -webkit-backdrop-filter: var(--glass-blur); border: 1rpx solid var(--danger-border); }
.cost-body { display: flex; flex-direction: column; gap: 14rpx; }
.cost-row { display: flex; justify-content: space-between; font-size: 24rpx; }
.cost-label { color: var(--text-secondary); }
.cost-minus { color: var(--danger); font-weight: 700; }
.cost-balance { font-weight: 700; }
.cost-balance.ok { color: var(--brand); }
.cost-balance.warn { color: var(--danger); }
.cost-note { font-size: 22rpx; color: var(--text-secondary); }
.cost-note.warn { color: var(--danger); }

/* 弹窗毛玻璃底部面板 */
.modal-sheet { padding: 32rpx; padding-bottom: calc(40rpx + env(safe-area-inset-bottom)); display: flex; flex-direction: column; gap: 20rpx; max-height: 80vh; background: var(--bg-surface-solid); border-radius: var(--radius-xl) var(--radius-xl) 0 0; border-top: 1rpx solid var(--glass-border); overflow: hidden; }
.modal-head { display: flex; justify-content: space-between; align-items: center; }
.modal-title { font-size: 32rpx; font-weight: 700; color: var(--text-primary); }
.modal-close { font-size: 44rpx; color: var(--text-muted); padding: 0 12rpx; }
.modal-body { display: flex; flex-direction: column; gap: 20rpx; overflow-y: auto; max-height: 60vh; }

.tool-opt { flex: 1; padding: 18rpx; text-align: center; border-radius: var(--radius-md); font-size: 22rpx; background: var(--glass-bg); backdrop-filter: var(--glass-blur); -webkit-backdrop-filter: var(--glass-blur); border: 1rpx solid var(--glass-border); color: var(--text-secondary); }
.tool-opt.active { border-color: var(--brand-border); background: var(--brand-subtle); color: var(--brand); font-weight: 600; }

.save-btn { --td-button-primary-bg-color: var(--brand) !important; border-radius: var(--radius-md) !important; margin-top: 8rpx; background: var(--brand-gradient) !important; border: none !important; }
