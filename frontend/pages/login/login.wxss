.login-container { display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 100vh; box-sizing: border-box; padding: 64rpx 48rpx; overflow: hidden; position: relative; background: var(--bg-root); color: var(--text); }
.login-container.theme-light { background: var(--bg-root); }
.glow-blob { position: absolute; border-radius: 50%; filter: blur(140rpx); z-index: 1; opacity: 0.12; }
.blob-1 { width: 600rpx; height: 600rpx; background: var(--brand); top: -180rpx; left: -120rpx; }
.blob-2 { width: 520rpx; height: 520rpx; bottom: 80rpx; right: -140rpx; background: var(--brand-light); }
.login-body { z-index: 10; width: 100%; display: flex; flex-direction: column; align-items: center; }
.login-logo { display: flex; flex-direction: column; align-items: center; margin-bottom: 52rpx; }
.logo-ring { width: 180rpx; height: 180rpx; border-radius: 32rpx; display: flex; align-items: center; justify-content: center; background: rgba(30,111,255,0.08); border: 1px solid var(--brand-border); }
.logo-symbol { font-size: 72rpx; color: var(--brand); }
.logo-name { margin-top: 28rpx; font-size: 34rpx; font-weight: 700; color: var(--text); }

.login-hero { text-align: center; margin-bottom: 24rpx; }
.login-title { font-size: 48rpx; font-weight: 700; color: var(--text); display: block; margin-bottom: 16rpx; }
.login-sub { font-size: 26rpx; color: var(--text-secondary); display: block; }

.login-features { display: flex; justify-content: center; gap: 12rpx; margin-bottom: 56rpx; flex-wrap: wrap; }
.feature-tag { padding: 12rpx 28rpx; font-size: 22rpx; border-radius: 8rpx; background: var(--bg-surface); border: 1rpx solid var(--border-default); color: var(--text-secondary); }

.login-btn-wrap { width: 100%; margin-bottom: 24rpx; }
.login-btn { --td-button-primary-bg-color: var(--brand) !important; border-radius: 12rpx !important; height: 96rpx !important; line-height: 96rpx !important; font-size: 30rpx !important; font-weight: 600 !important; }

.login-invite { width: 100%; margin-bottom: 24rpx; }
.invite-divider { display: flex; align-items: center; gap: 12rpx; margin-bottom: 20rpx; }
.invite-line { flex: 1; height: 1rpx; background: var(--border-default); }
.invite-div-txt { font-size: 22rpx; color: var(--text-muted); white-space: nowrap; }
.invite-input { --td-input-bg-color: var(--bg-surface); --td-input-border-color: var(--border-default); --td-input-text-color: var(--text); --td-input-placeholder-text-color: var(--text-muted); border-radius: 10rpx; overflow: hidden; border: 1rpx solid var(--border-default); }

.login-protocol { font-size: 22rpx; color: var(--text-muted); text-align: center; }
.link { color: var(--brand); font-weight: 500; }
