/* page 背景由 app.wxss 全局统管 */


.login-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  box-sizing: border-box;
  padding: 80rpx 48rpx 48rpx;
  overflow: hidden;
  position: relative;
  background: var(--bg-root);
  color: var(--text);
  animation: fade-up 0.35s ease-out both;
}
.login-container.theme-light { background: var(--bg-root); }

/* 暖色渐变光晕 */
.glow-blob { position: absolute; border-radius: 50%; filter: blur(120rpx); z-index: 1; opacity: 0.10; }
.blob-1 { width: 700rpx; height: 700rpx; background: var(--brand); top: -200rpx; left: -160rpx; }
.blob-2 { width: 600rpx; height: 600rpx; bottom: 60rpx; right: -180rpx; background: var(--brand-light); }

.login-body {
  z-index: 10;
  width: 100%;
  max-width: 600rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* Logo 区域 — 更大更突出 */
.login-logo {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 60rpx;
}
.logo-ring {
  width: 200rpx;
  height: 200rpx;
  border-radius: var(--radius-xl);
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--brand-gradient);
  box-shadow: var(--shadow-glow);
  margin-bottom: 28rpx;
}
.logo-symbol { font-size: 88rpx; color: #FFFFFF; }
.logo-name { font-size: 36rpx; font-weight: 700; color: var(--text-primary); letter-spacing: 2rpx; }

.login-hero { text-align: center; margin-bottom: 40rpx; }
.login-title { font-size: 44rpx; font-weight: 700; color: var(--text-primary); display: block; margin-bottom: 16rpx; line-height: 1.3; }
.login-sub { font-size: 24rpx; color: var(--text-secondary); display: block; line-height: 1.5; }

/* 特征标签 — 横向两行网格布局 */
.login-features {
  display: flex;
  justify-content: center;
  gap: 12rpx;
  margin-bottom: 60rpx;
  flex-wrap: wrap;
}
.feature-tag {
  padding: 16rpx 36rpx;
  font-size: 22rpx;
  border-radius: var(--radius-full);
  background: var(--glass-bg);
  backdrop-filter: var(--glass-blur);
  -webkit-backdrop-filter: var(--glass-blur);
  border: 1rpx solid var(--glass-border);
  color: var(--text-secondary);
  font-weight: 500;
}

/* 登录按钮区域 */
.login-btn-wrap { width: 100%; margin-bottom: 32rpx; }
.login-btn {
  --td-button-primary-bg-color: var(--brand) !important;
  border-radius: var(--radius-lg) !important;
  height: 100rpx !important;
  line-height: 100rpx !important;
  font-size: 32rpx !important;
  font-weight: 600 !important;
  background: var(--brand-gradient) !important;
  border: none !important;
  box-shadow: var(--shadow-glow) !important;
}

.login-invite { width: 100%; margin-bottom: 32rpx; }
.invite-divider { display: flex; align-items: center; gap: 16rpx; margin-bottom: 24rpx; }
.invite-line { flex: 1; height: 1rpx; background: var(--border-default); }
.invite-div-txt { font-size: 22rpx; color: var(--text-muted); white-space: nowrap; }
.invite-input {
  --td-input-bg-color: var(--glass-bg);
  --td-input-border-color: var(--glass-border);
  --td-input-text-color: var(--text-primary);
  --td-input-placeholder-text-color: var(--text-placeholder);
  border-radius: var(--radius-lg);
  overflow: hidden;
  border: 1rpx solid var(--glass-border);
  backdrop-filter: var(--glass-blur);
  -webkit-backdrop-filter: var(--glass-blur);
}

.login-protocol { font-size: 22rpx; color: var(--text-muted); text-align: center; margin-bottom: 20rpx; }
.link { color: var(--brand); font-weight: 500; }
