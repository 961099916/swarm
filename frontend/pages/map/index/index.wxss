}

/* ========== 音频控制按钮 ========== */
.hud-sound-btn {
  position: absolute;
  right: 32rpx;
  top: 340rpx;
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(180deg, #8b6b3d 0%, #6b4d2b 100%);
  border: 1rpx solid var(--border-default);
  box-shadow: var(--shadow-sm);
  pointer-events: auto;
  z-index: 96;
  transition: transform 0.15s ease;
}
.hud-sound-btn:active,
.hud-sound-btn--active {
  transform: scale(0.92);
  box-shadow: var(--shadow-sm);
}
.sound-btn-icon {
  font-size: 36rpx;
  line-height: 1;
}

/* ========== 音频控制面板 ========== */
.hud-sound-panel {
  position: absolute;
  right: 32rpx;
  top: 424rpx;
  width: 280rpx;
  background: linear-gradient(180deg, #f5e6c8 0%, #e8d5a8 100%);
  border: 1rpx solid var(--border-default);
  box-shadow: var(--shadow-sm);
  padding: 16rpx 20rpx;
  pointer-events: auto;
  z-index: 96;
  animation: panelSlideIn 0.2s ease-out;
}

@keyframes panelSlideIn {
  from { opacity: 0; transform: translateY(-10rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.sound-panel-header {
  border-bottom: 3rpx solid #c9a96e;
  padding-bottom: 10rpx;
  margin-bottom: 14rpx;
}
.sound-panel-title {
  font-size: 24rpx;
  color: #4a3520;
  font-weight: bold;
  letter-spacing: 2rpx;
}

.sound-panel-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 0;
}
.sound-item-label {
  font-size: 24rpx;
  color: #5c3d1e;
  font-weight: 500;
}

/* 像素风Toggle开关 */
.sound-toggle {
  width: 72rpx;
  height: 36rpx;
  background: #9e8e78;
  border: 3rpx solid #6b5d4d;
  position: relative;
  transition: background 0.2s ease;
  box-shadow: inset 0 2rpx 4rpx rgba(0,0,0,0.2);
}
.sound-toggle--on {
  background: var(--success);
  border-color: var(--success);
  box-shadow: inset 0 2rpx 4rpx rgba(0,0,0,0.15), 0 0 8rpx rgba(106,170,60,0.3);
}
.sound-toggle-thumb {
  width: 28rpx;
  height: 28rpx;
  background: linear-gradient(180deg, #f5e6c8 0%, #d4c4a0 100%);
  border: 2rpx solid #8b7d6b;
  position: absolute;
  top: 50%;
  left: 4rpx;
  transform: translateY(-50%);
  transition: left 0.2s ease;
  box-shadow: 0 2rpx 0 rgba(0,0,0,0.2);
}
.sound-toggle--on .sound-toggle-thumb {
  left: calc(100% - 32rpx);
  background: linear-gradient(180deg, #fff 0%, #e8e0d0 100%);
  border-color: var(--success);
}

/* 虚拟摇杆大面积手势触碰区 (限定屏幕左侧大半区域，防止多指误触 A 键) */
.joystick-touch-zone {
  position: fixed;
  left: 0;
  bottom: 0;
  width: 65%; /* 占屏幕左侧 65%，不干扰右下角交互键 */
  height: 60%; /* 占屏幕下半部 60%，不干扰上部其他 HUD */
  z-index: 90;
  pointer-events: auto;
}

/* 虚拟摇杆底盘 (截面圆木盘样式) */
.joystick-base {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: var(--bg-surface-hover);
  border: 1rpx solid var(--border-default); /* 木桩树皮 */
  box-shadow: var(--shadow-sm);
  pointer-events: none;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
}

/* 木塞操纵杆 */
.joystick-stick {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: var(--text-muted);
  border: 1rpx solid var(--border-default);
  box-shadow: inset 0 4rpx 0 rgba(255,255,255,0.2), 0 4rpx 0 rgba(0,0,0,0.3);
  position: absolute;
  z-index: 10;
  will-change: transform;
}

.joystick-center-light {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.1);
  pointer-events: none;
}

/* 交互 A 键 (粗框圆木块按键) */
.btn-action-a {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: #7f8c8d;
  border: 1rpx solid var(--border-default);
  margin-left: 56rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  pointer-events: none;
  opacity: 0.4;
  box-shadow: var(--shadow-sm);
  transition: all 0.15s cubic-bezier(0.4, 0, 0.2, 1);
}

.btn-action-a--active {
  background: #e0a96d; /* 木色 */
  border-color: var(--border-default);
  pointer-events: auto;
  opacity: 1;
  box-shadow: var(--shadow-sm);
  transform: translateY(-4rpx);
}

.btn-action-a--active:active {
  transform: translateY(2rpx);
  box-shadow: var(--shadow-sm);
}

.action-a-label {
  font-size: 36rpx;
  color: var(--text-primary);
  font-weight: 900;
  line-height: 1;
}

.action-a-sub {
  font-size: 14rpx;
  color: var(--text-muted);
  font-weight: 700;
  margin-top: 2rpx;
}

/* ==================== 5. 星露谷复古木质面板卡片 ==================== */
.wood-card {
  background-color: var(--bg-surface) !important; /* 羊皮纸米黄 */
  border: 8rpx solid var(--border-default) !important; /* 粗木框 */
  box-shadow: 0 10rpx 0 var(--bg-root) !important; /* 像素实影 */
  position: relative;
  color: var(--text-primary);
}

/* 内部金色雕花装饰边 */
.wood-card::after {
  content: '';
  position: absolute;
  top: 8rpx;
  left: 8rpx;
  right: 8rpx;
  bottom: 8rpx;
  border: 2rpx solid var(--brand); /* 金边 */
  pointer-events: none;
}

/* ==================== 6. NPC AVG 对话框 ==================== */
.dialogue-overlay {
  position: fixed;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.55);
  z-index: 999;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding-bottom: 80rpx;
}

.dialogue-box {
  width: 90%;
  margin-bottom: 40rpx;
  padding: 44rpx 44rpx 36rpx 44rpx !important;
  animation: slideDialogueUp 0.25s cubic-bezier(0.18, 0.89, 0.32, 1.1) forwards;
}

.dialogue-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-bottom: 16rpx;
  z-index: 2;
}

.dialogue-npc-badge {
  font-size: 18rpx;
  background: var(--text-muted);
  border: 1rpx solid var(--border-default);
  color: var(--bg-surface);
  padding: 1rpx 10rpx;
  font-weight: 700;
}

.dialogue-npc-name {
  font-size: 26rpx;
  font-weight: 900;
  color: var(--text-primary);
  margin-left: 16rpx;
}

.dialogue-body {
  margin-bottom: 30rpx;
  min-height: 80rpx;
  z-index: 2;
}

.dialogue-text {
  font-size: 25rpx;
  line-height: 1.5;
  color: var(--text-primary);
  font-weight: 600;
}

.dialogue-actions {
  display: flex;
  flex-direction: row;
  justify-content: flex-end;
  z-index: 2;
}

/* 纵向选项大按键布局 */
.dialogue-actions--vertical {
  flex-direction: column !important;
  align-items: stretch !important;
  width: 100%;
  gap: 16rpx;
}

.dialogue-actions--vertical .btn-option {
  margin: 0 !important;
  width: 100% !important;
  text-align: left;
  padding: 22rpx 32rpx !important;
  font-size: 24rpx !important;
  white-space: normal !important;
  line-height: 1.4 !important;
  background: var(--bg-surface-hover) !important;
  color: var(--text-primary) !important;
  border: 4rpx solid var(--border-default) !important;
  box-shadow: var(--shadow-sm) !important;
  border-radius: 0 !important;
  transition: all 0.1s ease;
}

.dialogue-actions--vertical .btn-option:active {
  transform: translateY(2rpx);
  box-shadow: var(--shadow-sm) !important;
  background: #e0a96d !important;
}

/* 像素风答题进度条 */
.dialogue-progress {
  margin-bottom: 24rpx;
  width: 100%;
  z-index: 2;
}

.dialogue-progress-text {
  font-size: 18rpx;
  font-weight: 800;
  color: var(--text-muted);
  margin-bottom: 8rpx;
  display: block;
}

.dialogue-progress-track {
  height: 20rpx;
  border: 1rpx solid var(--border-default);
  background: var(--text-muted);
  overflow: hidden;
  position: relative;
  box-shadow: inset 0 2rpx 0 rgba(0, 0, 0, 0.15);
}

.dialogue-progress-fill {
  height: 100%;
  background: #3a7d44;
  border-right: 4rpx solid var(--border-default);
  box-shadow: inset 0 -2rpx 0 rgba(0, 0, 0, 0.15),
              inset 0 2rpx 0 rgba(255, 255, 255, 0.25);
  transition: width 0.2s ease-out;
}

.dialogue-btn {
  margin: 0 0 0 24rpx !important;
  font-size: 24rpx !important;
  padding: 14rpx 32rpx !important;
  border-radius: 0 !important; /* 像素风不需要圆角 */
  border: 4rpx solid var(--border-default) !important;
  font-weight: 700 !important;
  box-shadow: var(--shadow-sm) !important;
  transition: all 0.1s ease;
}

.dialogue-btn:active {
  transform: translateY(2rpx);
  box-shadow: var(--shadow-sm) !important;
}

.btn-cancel {
  background: var(--bg-surface-hover) !important;
  color: var(--text-primary) !important;
}

.btn-primary {
  background: #e0a96d !important;
  color: var(--text-primary) !important;
}

/* ==================== 7. 个人档案背包弹窗 ==================== */
.profile-overlay {
  position: fixed;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.profile-modal {
  width: 90%;
  height: 80%;
  max-height: 80vh;
  padding: 0rpx !important;
  display: flex;
  flex-direction: column;
  overflow: hidden; /* 确保弹窗容器裁切溢出内容 */
  animation: modalZoomIn 0.25s cubic-bezier(0.18, 0.89, 0.32, 1.1) forwards;
}

.profile-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 40rpx;
  border-bottom: 4rpx solid var(--border-default);
  z-index: 2;
}

.profile-title {
  font-size: 28rpx;
  font-weight: 900;
  color: var(--text-primary);
}

.profile-close-btn {
  font-size: 32rpx;
  color: var(--text-muted);
  padding: 6rpx;
  font-weight: 900;
}

.profile-close-btn:active {
  color: #EF4444;
}

.profile-scroll {
  flex: 1;
  height: 0; /* 微信小程序中 flex: 1 的 scroll-view 必须设置 height: 0 才能正确计算高度并启用滚动 */
  padding: 32rpx;
  box-sizing: border-box;
  z-index: 2;
}

/* 玩家信息木头卡 */
.profile-user-card {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-bottom: 32rpx;
}

.avatar-picker-btn {
  position: relative;
  width: 110rpx;
  height: 110rpx;
  padding: 0 !important;
  background: var(--bg-surface-hover) !important;
  border: 4rpx solid var(--border-default) !important;
  margin: 0 !important;
  overflow: visible !important;
  border-radius: 0 !important;
}

.profile-avatar {
  width: 100%;
  height: 100%;
}

.avatar-camera-icon {
  position: absolute;
  right: -8rpx;
  bottom: -8rpx;
  background: #e0a96d;
  color: var(--text-primary);
  width: 38rpx;
  height: 38rpx;
  border: 1rpx solid var(--border-default);
  font-size: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: var(--shadow-sm);
}

.profile-name-section {
  margin-left: 28rpx;
  display: flex;
  flex-direction: column;
}

.nickname-row {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.profile-nickname {
  font-size: 30rpx;
  font-weight: 900;
  color: var(--text-primary);
  max-width: 280rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.edit-icon-pen {
  font-size: 22rpx;
  margin-left: 10rpx;
}

.nickname-input-box {
  background: var(--bg-surface-hover);
  border: 1rpx solid var(--border-default);
  color: var(--text-primary);
  font-size: 26rpx;
  padding: 4rpx 12rpx;
  width: 280rpx;
  font-weight: 700;
}

.profile-sub-uid {
  font-size: 18rpx;
  color: var(--text-muted);
  font-weight: 700;
  margin-top: 6rpx;
}

/* 星露谷木质修习经验条 */
.wood-exp-container {
  display: flex;
  flex-direction: column;
  margin-bottom: 32rpx;
  width: 100%;
}

.wood-exp-header {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}

.wood-exp-title {
  font-size: 22rpx;
  font-weight: 800;
  color: var(--text-muted);
}

.wood-exp-val {
  font-size: 20rpx;
  font-weight: 800;
  color: var(--text-primary);
}

.wood-progress-track {
  height: 44rpx;
  border: 1rpx solid var(--border-default);
  background: var(--text-muted); /* 轨道原木底色 */
  position: relative;
  display: flex;
  align-items: center;
  overflow: hidden;
  box-shadow: inset 0 4rpx 0 rgba(0, 0, 0, 0.15);
}

.wood-progress-fill {
  height: 100%;
  background: #e0a96d; /* 填充木材黄色 */
  border-right: 4rpx solid var(--border-default);
  box-shadow: inset 0 -4rpx 0 rgba(0, 0, 0, 0.15),
              inset 0 4rpx 0 rgba(255, 255, 255, 0.25);
  transition: width 0.25s ease-out;
}

.wood-progress-text {
  position: absolute;
  left: 0;
  right: 0;
  text-align: center;
  font-size: 18rpx;
  font-weight: 800;
  color: var(--text-primary);
  pointer-events: none;
  z-index: 5;
  text-shadow: 0 2rpx 0 rgba(255, 255, 255, 0.3);
}

/* RPG 指标网格 */
.profile-stats-grid {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  margin-bottom: 40rpx;
}

.stats-box {
  flex: 1;
  background: var(--bg-surface-hover);
  border: 1rpx solid var(--border-default);
  margin-right: 14rpx;
  padding: 16rpx 10rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stats-box:last-child {
  margin-right: 0;
}

.stats-value {
  font-size: 34rpx;
  font-weight: 900;
  color: var(--text-primary);
}

.stats-label {
  font-size: 16rpx;
  color: var(--text-muted);
  margin-top: 4rpx;
  font-weight: 800;
}

/* 历史背包 */
.history-title-row {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.history-title-label {
  font-size: 24rpx;
  font-weight: 900;
  color: var(--text-primary);
}

.history-count-badge {
  font-size: 16rpx;
  color: var(--bg-surface);
  background: var(--text-muted);
  padding: 2rpx 10rpx;
  border: 1rpx solid var(--border-default);
  font-weight: 700;
}

.history-list-container {
  margin-bottom: 60rpx;
}

.history-card {
  display: flex;
  flex-direction: row;
  align-items: center;
  background: var(--bg-surface);
  border: 1rpx solid var(--border-default);
  padding: 20rpx;
  margin-bottom: 16rpx;
  box-shadow: var(--shadow-sm);
  transition: all 0.15s ease;
}

.history-card:active {
  transform: translateY(2rpx);
  box-shadow: var(--shadow-sm);
}

.hist-badge-side {
  width: 90rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.hist-code-neon {
  font-size: 28rpx;
  font-weight: 900;
  color: var(--text-primary);
  background: var(--bg-surface-hover);
  border: 1rpx solid var(--border-default);
  padding: 2rpx 10rpx;
}

.hist-main-info {
  flex: 1;
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
}

.hist-title {
  font-size: 22rpx;
  font-weight: 800;
  color: var(--text-primary);
  line-height: 1.3;
}

.hist-subtitle {
  font-size: 18rpx;
  color: var(--text-muted);
  font-weight: 700;
  margin-top: 4rpx;
}

.hist-highlight {
  color: #e67e22; /* 橙色高亮 */
  font-weight: 800;
}

.hist-time {
  font-size: 15rpx;
  color: #7f8c8d;
  font-weight: 700;
  margin-top: 4rpx;
}

.hist-action-buttons {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.hist-btn-del {
  font-size: 26rpx;
  padding: 10rpx;
  color: #C0392B;
  opacity: 0.6;
}

.hist-btn-del:active {
  opacity: 1;
}

.hist-btn-view {
  font-size: 22rpx;
  color: var(--text-muted);
  padding: 10rpx;
  font-weight: 900;
}

.history-empty-tips {
  padding: 48rpx 32rpx;
  text-align: center;
  color: var(--text-muted);
  font-size: 20rpx;
  line-height: 1.5;
  font-weight: 700;
}

.faq-section-badge {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0 60rpx;
}

.faq-text-desc {
  font-size: 16rpx;
  color: var(--text-muted);
  font-weight: 700;
}

.faq-text-version {
  font-size: 15rpx;
  color: #7f8c8d;
  opacity: 0.6;
  margin-top: 4rpx;
}

/* ==================== 8. 复古公共确认弹窗 ==================== */
.cyber-modal-box {
  width: 80% !important;
  padding: 40rpx !important;
  margin: auto !important;
  display: flex;
  flex-direction: column;
  position: relative;
}

.cyber-modal-danger {
  border-color: #C0392B !important;
}

.modal-title-text {
  font-size: 28rpx;
  font-weight: 900;
  color: var(--text-primary);
  margin-bottom: 20rpx;
}

.cyber-modal-danger .modal-title-text {
  color: #C0392B;
}

.modal-body-content {
  font-size: 22rpx;
  line-height: 1.5;
  color: var(--border-default);
  font-weight: 700;
  margin-bottom: 36rpx;
}

.modal-actions-row {
  display: flex;
  flex-direction: row;
  justify-content: flex-end;
}

.modal-btn {
  margin: 0 0 0 20rpx !important;
  font-size: 22rpx !important;
  padding: 14rpx 30rpx !important;
  border-radius: 0 !important;
  border: 4rpx solid var(--border-default) !important;
  box-shadow: var(--shadow-sm) !important;
  font-weight: 700 !important;
}

.modal-btn:active {
  transform: translateY(2rpx);
  box-shadow: var(--shadow-sm) !important;
}

/* ==================== 9. 动画效果 ==================== */
@keyframes bounceTip {
  0% { transform: translateY(0); }
  100% { transform: translateY(-6px); }
}

@keyframes slideDialogueUp {
  0% { transform: translateY(120%); }
  100% { transform: translateY(0); }
}

@keyframes modalZoomIn {
  0% { transform: scale(0.95); opacity: 0; }
  100% { transform: scale(1); opacity: 1; }
}

/* ==================== 10. 结果报告弹窗微调样式 ==================== */
.result-modal {
  height: 85% !important;
}

/* 底部操作按钮行 */
.result-action-row {
  display: flex;
  flex-direction: row;
  gap: 20rpx;
  margin: 30rpx 0 10rpx;
  padding: 0 4rpx;
}

.result-save-btn {
  flex: 1;
  font-size: 24rpx !important;
  padding: 0 !important;
  height: 72rpx !important;
  line-height: 72rpx !important;
}

.result-confirm-btn {
  flex: 1;
  font-size: 24rpx !important;
  padding: 0 !important;
  height: 72rpx !important;
  line-height: 72rpx !important;
}

/* 次要按钮（保存海报）- 深褐色描边风格 */
.btn-secondary {
  background: var(--bg-surface) !important;
  color: var(--text-primary) !important;
  border: 4rpx solid var(--border-default) !important;
  box-shadow: var(--shadow-sm) !important;
}

.btn-secondary:active {
  transform: translateY(3rpx) !important;
  box-shadow: var(--shadow-sm) !important;
}

.btn-secondary[disabled] {
  opacity: 0.6 !important;
  color: var(--text-muted) !important;
}

.result-hero-panel {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx;
}

.result-label-text {
  font-size: 18rpx;
  color: var(--text-muted);
  font-weight: 800;
}

.result-code-text {
  font-size: 56rpx;
  color: var(--text-primary);
  font-weight: 900;
  margin-top: 6rpx;
  text-shadow: 0 4rpx 0 rgba(0,0,0,0.1);
}

.result-name-text {
  font-size: 28rpx;
  color: var(--text-muted);
  font-weight: 800;
  margin-top: 4rpx;
}

.result-desc-text {
  font-size: 22rpx;
  color: var(--text-primary);
  font-weight: 600;
  line-height: 1.5;
  margin-top: 16rpx;
  text-align: center;
}

/* 维度模块 */
.dim-list-container {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-top: 12rpx;
}

.dim-item-box {
  display: flex;
  flex-direction: column;
}

.dim-labels {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  margin-bottom: 6rpx;
}

.dim-label-l, .dim-label-r {
  font-size: 18rpx;
  font-weight: 700;
  color: var(--text-muted);
}

.dim-label-active {
  color: var(--text-primary) !important;
  font-weight: 900 !important;
}

.dim-scores {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  font-size: 15rpx;
  color: var(--text-muted);
  font-weight: 600;
  margin-top: 4rpx;
}

.dim-track {
  height: 20rpx !important;
}

.dim-marker {
  position: absolute;
  width: 14rpx;
  height: 100%;
  background: var(--bg-surface);
  border: 1rpx solid var(--border-default);
  z-index: 10;
  transform: translateX(-50%);
  box-shadow: 0 2rpx 0 rgba(0,0,0,0.15);
}

.dim-fill-l {
  height: 100%;
  background: #e0a96d;
  position: absolute;
  left: 0;
  z-index: 2;
}

.dim-fill-r {
  height: 100%;
  background: #4b66ad;
  position: absolute;
  z-index: 2;
}

/* 文本列表项目 */
.bullet-desc-row {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  gap: 12rpx;
  padding: 14rpx 20rpx;
  background: var(--bg-surface-hover);
  border: 1rpx solid var(--border-default);
  margin-bottom: 12rpx;
}

.bullet-symbol {
  font-size: 20rpx;
  line-height: 1.2;
}

.bullet-desc-text {
  font-size: 20rpx;
  color: var(--text-primary);
  font-weight: 600;
  line-height: 1.4;
  flex: 1;
}

/* ==================== 学科考核成绩单样式 ==================== */
.hero-passed {
  background: linear-gradient(135deg, #d4edda 0%, #c3e6cb 100%) !important;
  border-bottom: 6rpx solid #28a745 !important;
}

.hero-failed {
  background: linear-gradient(135deg, #f8d7da 0%, #f5c6cb 100%) !important;
  border-bottom: 6rpx solid #dc3545 !important;
}

.hero-passed .result-code-text {
  color: #155724 !important;
}

.hero-failed .result-code-text {
  color: #721c24 !important;
}

.wood-question-correct {
  border-left: 10rpx solid #2ecc71 !important;
}

.wood-question-incorrect {
  border-left: 10rpx solid var(--danger) !important;
  background: #fdf2f2 !important;
}

/* ==================== 4.8 关卡选择传送门弹窗样式 ==================== */
.stage-selector-modal {
  max-width: 650rpx;
  width: 90% !important;
}

.stage-selector-desc {
  font-size: 24rpx;
  color: var(--border-default);
  font-weight: bold;
  line-height: 1.5;
  margin-bottom: 25rpx;
  padding: 0 10rpx;
}

.stage-list-scroll {
  max-height: 55vh;
  margin-bottom: 20rpx;
}

.stage-item-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 20rpx;
  margin-bottom: 16rpx;
  background: #fbf0df;
  border: 1rpx solid var(--border-default);
  border-radius: 8rpx;
  box-shadow: var(--shadow-sm);
  transition: all 0.2s ease;
}

.stage-item-card:active {
  transform: translateY(2rpx);
  box-shadow: var(--shadow-sm);
}

.stage-item-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.stage-badge-status {
  font-size: 18rpx;
  font-weight: 800;
  padding: 4rpx 10rpx;
  border: 1rpx solid var(--border-default);
  border-radius: 6rpx;
  white-space: nowrap;
}

.stage-item-name {
  font-size: 28rpx;
  font-weight: bold;
  color: var(--text-primary);
}

/* 三类关卡卡片状态设计 */
/* 1. 已通关 (Completed) */
.stage-item--completed {
  background: #e8f5e9;
  border-color: #2e7d32;
}
.stage-item--completed .stage-badge-status {
  background: #2e7d32;
  color: #ffffff;
  border-color: #1b5e20;
}
.stage-item--completed .stage-item-name {
  color: #1b5e20;
}

/* 2. 进行中 / 当前修习 (Current) */
.stage-item--current {
  background: #fff3e0;
  border-color: #ef6c00;
  box-shadow: 0 0 10rpx rgba(239, 108, 0, 0.4), 0 4rpx 0 #ef6c00;
}
.stage-item--current .stage-badge-status {
  background: #ef6c00;
  color: #ffffff;
  border-color: #d84315;
  animation: pulse-badge 1.5s infinite alternate;
}
.stage-item--current .stage-item-name {
  color: #e65100;
}

/* 3. 未解锁锁定 (Locked) */
.stage-item--locked {
  background: #eaeaea;
  border-color: #7f8c8d;
  opacity: 0.6;
  filter: grayscale(1);
}
.stage-item--locked .stage-badge-status {
  background: #7f8c8d;
  color: #ffffff;
  border-color: #6c7a89;
}
.stage-item--locked .stage-item-name {
  color: #7f8c8d;
}

/* 右侧交互按键 */
.stage-action-btn {
  font-size: 22rpx;
  font-weight: bold;
  background: #e0a96d !important;
  color: var(--border-default) !important;
  border: 3rpx solid var(--border-default) !important;
  border-radius: 6rpx !important;
  padding: 8rpx 20rpx !important;
  line-height: 1.2 !important;
  min-height: 0 !important;
  width: auto !important;
}

.stage-item--completed .stage-action-btn {
  background: #81c784 !important;
  color: #1b5e20 !important;
  border-color: #2e7d32 !important;
}

.stage-item--current .stage-action-btn {
  background: #ffb74d !important;
  color: #e65100 !important;
  border-color: #ef6c00 !important;
}

.stage-item--locked .stage-action-btn {
  background: #bdc3c7 !important;
  color: #7f8c8d !important;
  border-color: #95a5a6 !important;
}

@keyframes pulse-badge {
  0% {
    opacity: 0.8;
    transform: scale(0.95);
  }
  100% {
    opacity: 1;
    transform: scale(1.05);
  }
}

/* ==================== 副本教室通道地砖 & 阻断石砖门 ==================== */

/* ==================== 大厅传送门 ==================== */

/* 传送门通用容器 */
.portal-node {
  position: absolute;
  width: 48px;
  height: 80px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-end;
  transition: transform 0.25s cubic-bezier(0.34, 1.56, 0.64, 1);
}

/* 靠近激活后轻微放大（作用于内层动画容器，不影响外层定位） */
/* 公式: 外层 .portal-node 负责 translate3d 定位，内层 .portal-anim-inner 负责 scale 动效，彻底解耦避免 transform 属性冲突 */
.portal-anim-inner {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-end;
  transition: transform 0.25s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.portal-active {
  transform: scale(1.12);
}

/* 门体图片 */
.portal-body-img {
  width: 48px;
  height: 64px;
  z-index: 3;
  position: relative;
}

/* 传送门光圈（氛围发光与呼吸脉动） */
.portal-aura {
  position: absolute;
  top: 4px;
  left: 50%;
  transform: translateX(-50%);
  width: 52px;
  height: 52px;
  border-radius: 50%;
  z-index: 2;
  animation: portalAuraPulse 2s ease-in-out infinite alternate;
  pointer-events: none;
  will-change: transform;
}

/* 「学途之门」蓝色光圈 */
.portal-study-aura {
  box-shadow: 0 0 14px rgba(74, 158, 255, 0.55), inset 0 0 10px rgba(74, 158, 255, 0.25);
  transition: box-shadow 0.25s ease;
}

.portal-active .portal-study-aura {
  box-shadow: 0 0 24px rgba(74, 158, 255, 0.95), inset 0 0 14px rgba(74, 158, 255, 0.45);
}

/* 「逍遥之门」粉色光圈 */
.portal-fun-aura {
  box-shadow: 0 0 14px rgba(255, 110, 180, 0.55), inset 0 0 10px rgba(255, 110, 180, 0.25);
  transition: box-shadow 0.25s ease;
}

.portal-active .portal-fun-aura {
  box-shadow: 0 0 24px rgba(255, 110, 180, 0.95), inset 0 0 14px rgba(255, 110, 180, 0.45);
}

.portal-active .portal-aura {
  animation-duration: 1.1s; /* 靠近激活时能量脉动加快 */
}

@keyframes portalAuraPulse {
  0%   { transform: translateX(-50%) scale(0.95); opacity: 0.7; }
  100% { transform: translateX(-50%) scale(1.05); opacity: 1.0; }
}

@keyframes portalAuraSpin {
  0%   { transform: translateX(-50%) rotate(0deg); }
  100% { transform: translateX(-50%) rotate(360deg); }
}

/* 名称标签 */
.portal-label {
  position: absolute;
  bottom: -20px;
  left: 50%;
  transform: translateX(-50%);
  padding: 2px 8px;
  border-radius: 8px;
  white-space: nowrap;
  z-index: 4;
}

.portal-study-label {
  background: rgba(26, 58, 107, 0.85);
  border: 1px solid #4a9eff;
}

.portal-fun-label {
  background: rgba(74, 26, 107, 0.85);
  border: 1px solid #ff6eb4;
}

.portal-label-text {
  font-size: 20rpx;
  font-weight: 600;
  letter-spacing: 1px;
}

.portal-study-label .portal-label-text {
  color: #a8d8ff;
}

.portal-fun-label .portal-label-text {
  color: #ffd6ec;
}

/* 「副本出口传送门」翡翠绿黑洞光圈 */
.portal-exit-aura {
  box-shadow: 0 0 16px rgba(16, 185, 129, 0.6), inset 0 0 10px rgba(16, 185, 129, 0.25);
  transition: box-shadow 0.25s ease;
}

.portal-active .portal-exit-aura {
  box-shadow: 0 0 26px rgba(16, 185, 129, 0.95), inset 0 0 14px rgba(16, 185, 129, 0.45);
}

/* 罗夏墨迹测验容器 */
.rorschach-container {
  width: 90%;
  height: 120px;
  display: flex;
  justify-content: center;
  align-items: center;
  margin: 16rpx auto;
  background: #faf6f0;
  border-radius: 8rpx;
  border: 1rpx solid var(--border-default);
  padding: 8rpx;
  box-shadow: inset 0 2rpx 6rpx rgba(0, 0, 0, 0.15);
  box-sizing: border-box;
}

.rorschach-inkblot {
  width: 100%;
  height: 100%;
}

.portal-exit-label {
  background: rgba(0, 40, 20, 0.88);
  border: 1px solid #10b981;
}

.portal-exit-label .portal-label-text {
  color: #6ee7b7;
}

/* 靠近提示气泡 */
.portal-interact-tip {
  top: auto !important;
  bottom: 84px !important;
  font-size: 20rpx !important;
}

