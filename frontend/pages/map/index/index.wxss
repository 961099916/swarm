/* ==================== 1. 2D 游戏视口与像素地图 ==================== */
.game-viewport {
  width: 100vw;
  height: 100vh;
  overflow: hidden;
  position: relative;
  background: linear-gradient(135deg, #3a7d44 0%, #2d6e3f 50%, #1e5e33 100%); /* 星露谷经典草绿 */
}

/* 2D 滚动地图大背景 */
.game-map {
  position: absolute;
  left: 0;
  top: 0;
  transform-style: preserve-3d;
  will-change: transform;
}

/* 像素杂色草地地貌（使用重复网格与错落草簇模拟 16-bit 像素草坪） */
.map-grid-bg {
  position: absolute;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  background: #3a7d44; /* 升级为经典的星露谷明亮草绿色 */
  background-image:
    /* 黄土小径路径 (模拟中心交叉黄土路效果) */
    radial-gradient(ellipse at 400px 400px, rgba(223, 177, 128, 0.4) 0%, transparent 350px),
    radial-gradient(ellipse at 850px 300px, rgba(223, 177, 128, 0.4) 0%, transparent 280px),
    /* 像素杂色草坪斑点 */
    radial-gradient(circle at 12px 12px, #447227 2px, transparent 2px),
    radial-gradient(circle at 28px 24px, #447227 2px, transparent 2px),
    radial-gradient(circle at 6px 36px, #447227 2.5px, transparent 2.5px),
    radial-gradient(circle at 22px 14px, #447227 2px, transparent 2px),
    /* 星露谷风格：小粉红野花和小黄碎花点缀 */
    radial-gradient(circle at 18px 30px, var(--danger) 1.5px, transparent 1.5px),
    radial-gradient(circle at 35px 8px, #f1c40f 1.5px, transparent 1.5px);
  background-size: 100% 100%, 100% 100%, 48px 48px, 48px 48px, 48px 48px, 48px 48px, 48px 48px, 48px 48px;
  z-index: 0;
}

/* 地图木边界围墙 (Stardew 标志性木围栏样式) */
.map-boundary-wood {
  position: absolute;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  border: 2rpx solid var(--border-default); /* 深褐原木色 */
  /* 黄铜金边装饰 */
  outline-offset: -18rpx;
  pointer-events: none;
  z-index: 1;
}

/* ==================== 2. 自然地表障碍物样式 ==================== */
.obstacle-node {
  position: absolute;
  z-index: 10;
  display: flex;
  align-items: center;
  justify-content: center;
}

.obstacle-core {
  width: 100%;
  height: 100%;
  background: var(--text-muted);
  border: 1rpx solid var(--border-default);
  box-shadow: 0 8rpx 0 rgba(0, 0, 0, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 像素荷塘 */
.obs-pond .obstacle-core {
  border-radius: 24rpx;
  border: 8rpx solid #7f6f5e; /* 环塘石块 */
  background: #4b66ad; /* 池水蓝 */
  box-shadow: 0 10rpx 0 rgba(0, 0, 0, 0.25);
}

.obs-pond::before {
  content: 'PELICAN POND';
  position: absolute;
  top: -36rpx;
  left: 50%;
  transform: translateX(-50%);
  font-size: 18rpx;
  color: var(--bg-surface);
  font-weight: 700;
  background: var(--border-default);
  padding: 2rpx 10rpx;
  border: 1rpx solid var(--brand);
  white-space: nowrap;
}

/* 古木树桩 */
.obs-stump_left .obstacle-core {
  border-radius: 12rpx;
  background: radial-gradient(circle, var(--bg-surface-hover) 30%, var(--text-muted) 70%); /* 年轮效果 */
  border-color: var(--border-default);
}

/* 复古木栅栏 */
.obs-fence_right .obstacle-core {
  background: repeating-linear-gradient(45deg, var(--border-default), var(--border-default) 8px, var(--border-default) 8px, var(--border-default) 16px);
  border-color: var(--border-default);
}

.obs-detail {
  font-size: 32rpx;
  opacity: 0.8;
}

