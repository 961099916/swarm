.t-icon--image {
  width: 1em;
  height: 1em;
  display: inline-block;
  vertical-align: middle;
}

.t-icon__image {
  width: 100%;
  height: 100%;
  display: block;
}

.t-icon {
  display: inline-block;
  width: 1em;
  height: 1em;
  background-color: currentColor;
  -webkit-mask-repeat: no-repeat;
  mask-repeat: no-repeat;
  -webkit-mask-size: 100% 100%;
  mask-size: 100% 100%;
  vertical-align: middle;
}

