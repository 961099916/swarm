{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "checkJs": true,
    "allowJs": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"]
    },
    "typeRoots": [
      "node_modules/@types",
      "miniprogram_npm/tdesign-miniprogram"
    ]
  },
  "include": [
    "app.js",
    "pages/**/*.js",
    "utils/**/*.js",
    "components/**/*.js",
    "packageAdmin/**/*.js",
    "packageKnowledge/**/*.js",
    "packageQuiz/**/*.js",
    "packageTask/**/*.js"
  ],
  "exclude": [
    "node_modules",
    "miniprogram_npm",
    "static"
  ]
}
